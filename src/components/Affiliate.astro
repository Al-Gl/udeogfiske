---
import { getProduct, formatPrice } from '../lib/feed';

interface Props {
  productId: string;
  href?: string;
  note?: string;
  cta?: string;
  image?: string;
  photo?: boolean;
}

const { productId, href, note, cta = 'Se prisen hos Fiskegrej.dk', image, photo = false } = Astro.props;
const product = getProduct(productId);

if (!product) {
  throw new Error(`Affiliate: product ${productId} not found in feed`);
}

const link = href ?? product.url;
const imageSrc = image ?? product.image;
const inStock = product.stock.toLowerCase().includes('in stock');
const hasDiscount = product.oldPrice > product.price && product.oldPrice > 0;
const discountPct = hasDiscount
  ? Math.round(((product.oldPrice - product.price) / product.oldPrice) * 100)
  : 0;
---

<aside class="aff" aria-label={`Anbefalet produkt: ${product.name}`}>
  <span class="aff-tag">
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2l2.39 6.95H22l-6.18 4.49L18.21 22 12 17.27 5.79 22l2.39-8.56L2 8.95h7.61L12 2z" />
    </svg>
    Jeg anbefaler
  </span>

  <div class="aff-body">
    <a class={`aff-image ${photo ? 'aff-image--photo' : ''}`} href={link} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
      <img src={imageSrc} alt={product.name} loading="lazy" width="320" height="320" />
    </a>

    <div class="aff-content">
      <div class="aff-head">
        <p class="aff-brand">{product.brand}</p>
        <h3 class="aff-name">
          <a href={link} target="_blank" rel="sponsored noopener">{product.name}</a>
        </h3>
      </div>

      {note && <p class="aff-note">{note}</p>}

      <div class="aff-meta">
        <span class={`aff-chip ${inStock ? 'aff-chip--ok' : 'aff-chip--out'}`}>
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            {inStock
              ? <path d="M3 8.5l3.5 3.5L13 5" />
              : <path d="M4 4l8 8M12 4l-8 8" />
            }
          </svg>
          {inStock ? 'På lager' : 'Udsolgt'}
        </span>
        {product.delivery && (
          <span class="aff-chip">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="8" cy="8" r="6.5" />
              <path d="M8 4.5V8l2.25 1.5" />
            </svg>
            Leveres {product.delivery}
          </span>
        )}
      </div>

      <div class="aff-buy">
        <div class="aff-price">
          {hasDiscount && <span class="aff-price-old">{formatPrice(product.oldPrice)} kr</span>}
          <span class="aff-price-now">
            {formatPrice(product.price)}
            <span class="aff-price-cur">kr</span>
          </span>
          {hasDiscount && <span class="aff-discount">Spar {discountPct}%</span>}
        </div>
        <a class="aff-cta" href={link} target="_blank" rel="sponsored noopener">
          <span>{cta}</span>
          <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <p class="aff-disclosure">
        Affiliate-link — køber du via linket, får jeg en lille kommission. Det koster dig ikke ekstra.
      </p>
    </div>
  </div>
</aside>

<style>
  .aff {
    position: relative;
    margin: 2.5rem 0;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 18px;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 12px 28px -16px rgba(13, 74, 94, 0.18),
      0 32px 64px -40px rgba(13, 74, 94, 0.14);
  }

  .aff::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, #c47d0a 0%, #e3a64a 45%, #c47d0a 100%);
    z-index: 2;
  }

  .aff-tag {
    position: absolute;
    top: 1.125rem;
    right: 1.125rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 0.7rem 0.35rem 0.55rem;
    background: #ffffff;
    border: 1px solid rgba(196, 125, 10, 0.28);
    color: #b45309;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 999px;
    box-shadow: 0 2px 8px rgba(196, 125, 10, 0.15);
  }

  .aff-tag svg {
    width: 11px;
    height: 11px;
    color: #c47d0a;
  }

  .aff-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0;
  }

  .aff-image {
    position: relative;
    display: block;
    background:
      radial-gradient(ellipse at 50% 60%, rgba(13, 74, 94, 0.08) 0%, transparent 60%),
      linear-gradient(160deg, #f9fbfc 0%, #eef4f6 100%);
    border-right: 1px solid rgba(15, 23, 42, 0.06);
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .aff-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.75rem;
    filter: drop-shadow(0 10px 18px rgba(13, 74, 94, 0.18));
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .aff-image--photo {
    background: transparent;
    aspect-ratio: auto;
    align-self: center;
  }

  .aff-image--photo img {
    width: 100%;
    height: auto;
    object-fit: contain;
    padding: 0;
    filter: none;
  }

  .aff:hover .aff-image img {
    transform: scale(1.05);
  }

  .aff-content {
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .aff-head {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-right: 7rem;
  }

  .aff-brand {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #6b7280;
    margin: 0;
  }

  .aff-name {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.022em;
    color: #0f172a;
    margin: 0;
  }

  .aff-name a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.3s ease, color 0.2s ease;
  }

  .aff-name a:hover {
    color: #0d4a5e;
    background-size: 100% 1px;
  }

  .aff-note {
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-size: 1rem;
    line-height: 1.6;
    color: #475569;
    margin: 0;
    padding-left: 0.875rem;
    border-left: 2px solid #c47d0a;
  }

  .aff-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .aff-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    color: #475569;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 999px;
  }

  .aff-chip svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .aff-chip--ok {
    background: #ecfdf5;
    border-color: #a7f3d0;
    color: #047857;
  }

  .aff-chip--out {
    background: #fef2f2;
    border-color: #fecaca;
    color: #b91c1c;
  }

  .aff-buy {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    margin-top: 0.25rem;
    padding-top: 1rem;
    border-top: 1px dashed #e5e7eb;
  }

  .aff-price {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.1rem;
    line-height: 1;
  }

  .aff-price-old {
    font-size: 0.8125rem;
    color: #9ca3af;
    text-decoration: line-through;
  }

  .aff-price-now {
    display: inline-flex;
    align-items: baseline;
    gap: 0.25rem;
    font-size: 1.875rem;
    font-weight: 800;
    color: #0d4a5e;
    letter-spacing: -0.028em;
  }

  .aff-price-cur {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #475569;
    letter-spacing: 0;
  }

  .aff-discount {
    margin-top: 0.25rem;
    padding: 0.15rem 0.45rem;
    background: #fef3c7;
    color: #b45309;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .aff-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.4rem;
    background: #0d4a5e;
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    white-space: nowrap;
    box-shadow: 0 4px 14px -4px rgba(13, 74, 94, 0.45);
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }

  .aff-cta svg {
    transition: transform 0.25s ease;
  }

  .aff-cta:hover {
    background: #c47d0a;
    box-shadow: 0 6px 18px -4px rgba(196, 125, 10, 0.5);
    transform: translateY(-1px);
  }

  .aff-cta:hover svg {
    transform: translateX(3px);
  }

  .aff-disclosure {
    font-size: 0.75rem;
    color: #94a3b8;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 720px) {
    .aff {
      border-radius: 16px;
    }

    .aff-body {
      grid-template-columns: 1fr;
    }

    .aff-image {
      aspect-ratio: 16 / 11;
      border-right: none;
      border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .aff-image img {
      padding: 1.25rem;
    }

    .aff-content {
      padding: 1.25rem 1.25rem 1.125rem;
      gap: 0.875rem;
    }

    .aff-head {
      padding-right: 6rem;
    }

    .aff-name {
      font-size: 1.2rem;
    }

    .aff-note {
      font-size: 0.9375rem;
    }

    .aff-buy {
      flex-direction: column;
      align-items: stretch;
      gap: 1rem;
    }

    .aff-price {
      align-items: flex-start;
    }

    .aff-price-now {
      font-size: 1.625rem;
    }

    .aff-cta {
      justify-content: center;
    }
  }
</style>
