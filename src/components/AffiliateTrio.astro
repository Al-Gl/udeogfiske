---
import { getProduct, formatPrice } from '../lib/feed';

interface ProductSpec {
  productId: string;
  badge: string;
  badgeTone?: 'teal' | 'orange' | 'slate';
  note: string;
  highlight?: boolean;
}

interface Props {
  title: string;
  intro?: string;
  products: ProductSpec[];
  cta?: string;
}

const { title, intro, products, cta = 'Se hos Fiskegrej' } = Astro.props;

const resolved = products.map((spec) => {
  const product = getProduct(spec.productId);
  if (!product) {
    throw new Error(`AffiliateTrio: product ${spec.productId} not found in feed`);
  }
  const hasDiscount = product.oldPrice > product.price && product.oldPrice > 0;
  const discountPct = hasDiscount
    ? Math.round(((product.oldPrice - product.price) / product.oldPrice) * 100)
    : 0;
  const inStock = product.stock.toLowerCase().includes('in stock');
  return { spec, product, hasDiscount, discountPct, inStock };
});
---

<section class="trio" aria-label={title}>
  <header class="trio-head">
    <span class="trio-eyebrow">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.39 6.95H22l-6.18 4.49L18.21 22 12 17.27 5.79 22l2.39-8.56L2 8.95h7.61L12 2z" />
      </svg>
      Mit valg
    </span>
    <h3 class="trio-title">{title}</h3>
    {intro && <p class="trio-intro">{intro}</p>}
  </header>

  <div class="trio-grid">
    {resolved.map(({ spec, product, hasDiscount, discountPct, inStock }) => (
      <article class={`trio-card ${spec.highlight ? 'is-highlight' : ''}`}>
        <span class={`trio-badge trio-badge--${spec.badgeTone ?? 'teal'}`}>{spec.badge}</span>

        <a class="trio-image" href={product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
          <img src={product.image} alt={product.name} loading="lazy" width="320" height="320" />
        </a>

        <div class="trio-body">
          <p class="trio-brand">{product.brand}</p>
          <h4 class="trio-name">
            <a href={product.url} target="_blank" rel="sponsored noopener">{product.name}</a>
          </h4>

          <p class="trio-note">{spec.note}</p>

          <div class="trio-buy">
            <div class="trio-price">
              {hasDiscount && <span class="trio-price-old">{formatPrice(product.oldPrice)} kr</span>}
              <span class="trio-price-now">
                {formatPrice(product.price)}
                <span class="trio-price-cur">kr</span>
              </span>
              {hasDiscount && <span class="trio-price-save">−{discountPct}%</span>}
            </div>

            <a class="trio-cta" href={product.url} target="_blank" rel="sponsored noopener">
              <span>{cta}</span>
              <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>

          <div class="trio-meta">
            <span class={`trio-dot ${inStock ? 'is-ok' : 'is-out'}`} aria-hidden="true"></span>
            <span>{inStock ? 'På lager' : 'Udsolgt'}</span>
            {product.delivery && <span class="trio-meta-sep">·</span>}
            {product.delivery && <span>Leveres {product.delivery}</span>}
          </div>
        </div>
      </article>
    ))}
  </div>

  <p class="trio-disclosure">
    Affiliate-links — køber du via knapperne, får jeg en lille kommission. Det koster dig ikke ekstra.
  </p>
</section>

<style>
  .trio {
    position: relative;
    left: 50%;
    transform: translateX(-50%);
    width: min(992px, calc(100vw - 3rem));
    margin: 2.5rem 0;
    padding: 1.75rem 1.75rem 1.5rem;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 20px;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 14px 32px -18px rgba(13, 74, 94, 0.18),
      0 40px 70px -50px rgba(13, 74, 94, 0.18);
  }

  .trio-head {
    margin-bottom: 1.5rem;
  }

  .trio-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem 0.3rem 0.5rem;
    background: #fef3c7;
    color: #b45309;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 999px;
    margin-bottom: 0.65rem;
  }

  .trio-eyebrow svg {
    width: 11px;
    height: 11px;
    color: #c47d0a;
  }

  .trio-title {
    font-size: 1.375rem;
    font-weight: 700;
    color: #0f172a;
    letter-spacing: -0.022em;
    line-height: 1.25;
    margin: 0;
  }

  .trio-intro {
    margin-top: 0.5rem;
    font-size: 0.9375rem;
    color: #475569;
    line-height: 1.7;
    max-width: 62ch;
  }

  .trio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .trio-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .trio-card:hover {
    transform: translateY(-3px);
    border-color: #0d4a5e;
    box-shadow: 0 18px 32px -16px rgba(13, 74, 94, 0.28);
  }

  .trio-card.is-highlight {
    border-color: #0d4a5e;
    box-shadow: 0 14px 28px -14px rgba(13, 74, 94, 0.22);
  }

  .trio-card.is-highlight:hover {
    box-shadow: 0 22px 38px -16px rgba(13, 74, 94, 0.34);
  }

  .trio-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 2;
    padding: 0.3rem 0.625rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 999px;
    border: 1px solid rgba(15, 23, 42, 0.04);
    backdrop-filter: blur(4px);
  }

  .trio-badge--teal {
    background: rgba(13, 74, 94, 0.95);
    color: #ffffff;
  }

  .trio-badge--orange {
    background: rgba(196, 125, 10, 0.95);
    color: #ffffff;
  }

  .trio-badge--slate {
    background: rgba(248, 250, 252, 0.95);
    color: #0f172a;
    border-color: rgba(15, 23, 42, 0.1);
  }

  .trio-image {
    display: block;
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(ellipse at 50% 60%, rgba(13, 74, 94, 0.08) 0%, transparent 60%),
      linear-gradient(160deg, #f9fbfc 0%, #eef4f6 100%);
    overflow: hidden;
  }

  .trio-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.5rem;
    filter: drop-shadow(0 8px 14px rgba(13, 74, 94, 0.18));
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .trio-card:hover .trio-image img {
    transform: scale(1.06);
  }

  .trio-body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.125rem 1.125rem 1rem;
    flex: 1;
  }

  .trio-brand {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #6b7280;
    margin: 0;
  }

  .trio-name {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.014em;
    color: #0f172a;
    margin: 0;
  }

  .trio-name a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .trio-name a:hover {
    color: #0d4a5e;
  }

  .trio-note {
    font-size: 0.8125rem;
    color: #475569;
    line-height: 1.55;
    margin: 0;
    min-height: 2.5em;
  }

  .trio-buy {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .trio-price {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .trio-price-old {
    font-size: 0.75rem;
    color: #9ca3af;
    text-decoration: line-through;
  }

  .trio-price-now {
    display: inline-flex;
    align-items: baseline;
    gap: 0.2rem;
    font-size: 1.5rem;
    font-weight: 800;
    color: #0d4a5e;
    letter-spacing: -0.028em;
    line-height: 1;
  }

  .trio-price-cur {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #475569;
    letter-spacing: 0;
  }

  .trio-price-save {
    padding: 0.1rem 0.35rem;
    background: #fef3c7;
    color: #b45309;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .trio-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    flex-shrink: 0;
    white-space: nowrap;
    padding: 0.7rem 1rem;
    background: #0d4a5e;
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    box-shadow: 0 4px 12px -4px rgba(13, 74, 94, 0.45);
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.2s ease;
  }

  .trio-cta svg {
    transition: transform 0.25s ease;
  }

  .trio-cta:hover {
    background: #c47d0a;
    box-shadow: 0 6px 16px -4px rgba(196, 125, 10, 0.5);
  }

  .trio-cta:hover svg {
    transform: translateX(3px);
  }

  .trio-meta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.6875rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }

  .trio-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d1d5db;
  }

  .trio-dot.is-ok { background: #10b981; }
  .trio-dot.is-out { background: #ef4444; }

  .trio-meta-sep {
    color: #d1d5db;
  }

  .trio-disclosure {
    margin: 1.25rem 0 0;
    font-size: 0.6875rem;
    color: #94a3b8;
    line-height: 1.5;
    text-align: center;
  }

  @media (max-width: 880px) {
    .trio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .trio {
      padding: 1.375rem 1.25rem 1.25rem;
      border-radius: 16px;
    }
    .trio-grid {
      grid-template-columns: 1fr;
    }
    .trio-image {
      aspect-ratio: 16 / 11;
    }
    .trio-title {
      font-size: 1.25rem;
    }
  }
</style>
