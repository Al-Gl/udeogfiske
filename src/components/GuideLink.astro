---
interface Props {
  /** Destination guide URL */
  href: string;
  /** Bold title, e.g. "Læs fladfisk fiskeri guiden" */
  title: string;
  /** Short descriptor under the title */
  desc: string;
}
const { href, title, desc } = Astro.props;
---

<a href={href} class="guide-link">
  <span class="gl-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
    </svg>
  </span>
  <span class="gl-body">
    <span class="gl-title">{title}</span>
    <span class="gl-desc">{desc}</span>
  </span>
  <svg class="gl-arrow" viewBox="0 0 18 18" fill="none" aria-hidden="true" width="18" height="18">
    <path d="M5 9h8M9.5 5.5l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</a>

<style>
  .guide-link {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin: 0.5rem 0 1.75rem;
    padding: 0.875rem 1.125rem;
    background: #f6f9fa;
    border: 1px solid #e1e8ea;
    border-left: 3px solid #0d4a5e;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.18s, border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .guide-link:hover {
    background: #ffffff;
    border-color: #c47d0a;
    border-left-color: #c47d0a;
    transform: translateY(-1px);
    box-shadow: 0 8px 20px -14px rgba(13, 74, 94, 0.5);
  }

  .gl-icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 9px;
    background: #0d4a5e;
    color: #ffffff;
    transition: background 0.18s;
  }
  .guide-link:hover .gl-icon { background: #c47d0a; }

  .gl-body { flex: 1; min-width: 0; }

  .gl-title {
    display: block;
    font-size: 0.9375rem;
    font-weight: 700;
    color: #0d4a5e;
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color 0.18s;
  }
  .guide-link:hover .gl-title { color: #c47d0a; }

  .gl-desc {
    display: block;
    font-size: 0.8125rem;
    color: #6b7280;
    line-height: 1.4;
    margin-top: 0.1rem;
  }

  .gl-arrow {
    flex-shrink: 0;
    color: #0d4a5e;
    transition: transform 0.18s, color 0.18s;
  }
  .guide-link:hover .gl-arrow { color: #c47d0a; transform: translateX(3px); }
</style>
