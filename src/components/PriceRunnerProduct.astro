---
interface Props {
  /** Product name shown as the card heading */
  title: string;
  /** Full PriceRunner product URL — include the ref-site/utm credit params verbatim */
  href: string;
  /** Product image URL */
  image?: string;
  /** Brand label above the title */
  brand?: string;
  /** Editorial first-person note */
  note?: string;
  /** Short spec chips, e.g. ["Komplet: stang + hjul + line", "5'6\" / 5–24 g"] */
  specs?: string[];
  /** Eyebrow pill text */
  eyebrow?: string;
  /** CTA button label */
  cta?: string;
}

const {
  title,
  href,
  image,
  brand,
  note,
  specs = [],
  eyebrow = 'Mit valg til børn',
  cta = 'Sammenlign priser hos PriceRunner',
} = Astro.props;
---

<aside class="prp" aria-label={`Anbefalet produkt: ${title}`}>
  <span class="prp-tag">Annonce</span>

  <div class="prp-body">
    {image && (
      <a class="prp-image" href={href} target="_blank" rel="nofollow sponsored noopener" tabindex="-1" aria-hidden="true">
        <img src={image} alt={title} loading="lazy" width="320" height="320" />
      </a>
    )}

    <div class="prp-content">
      <div class="prp-head">
        <span class="prp-eyebrow">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.39 6.95H22l-6.18 4.49L18.21 22 12 17.27 5.79 22l2.39-8.56L2 8.95h7.61L12 2z" />
          </svg>
          {eyebrow}
        </span>
        {brand && <p class="prp-brand">{brand}</p>}
        <h3 class="prp-name">
          <a href={href} target="_blank" rel="nofollow sponsored noopener">{title}</a>
        </h3>
      </div>

      {note && <p class="prp-note">{note}</p>}

      {specs.length > 0 && (
        <ul class="prp-specs">
          {specs.map((s) => (
            <li>
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 8.5l3.5 3.5L13 5" />
              </svg>
              {s}
            </li>
          ))}
        </ul>
      )}

      <div class="prp-buy">
        <a class="prp-cta" href={href} target="_blank" rel="nofollow sponsored noopener">
          <span>{cta}</span>
          <svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <span class="prp-foot-note">I samarbejde med <strong>PriceRunner</strong></span>
      </div>
    </div>
  </div>
</aside>

<style>
  .prp {
    position: relative;
    margin: 2.5rem 0;
    background: #ffffff;
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 18px;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 12px 28px -16px rgba(13, 74, 94, 0.18),
      0 32px 64px -40px rgba(13, 74, 94, 0.14);
  }

  .prp::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, #2563eb 0%, #0d4a5e 55%, #c47d0a 100%);
    z-index: 2;
  }

  .prp-tag {
    position: absolute;
    top: 1.125rem;
    right: 1.125rem;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.7rem;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 999px;
  }

  .prp-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0;
  }

  .prp-image {
    position: relative;
    display: block;
    background:
      radial-gradient(ellipse at 50% 60%, rgba(37, 99, 235, 0.08) 0%, transparent 60%),
      linear-gradient(160deg, #f9fbfc 0%, #eef4f6 100%);
    border-right: 1px solid rgba(15, 23, 42, 0.06);
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .prp-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 1.75rem;
    filter: drop-shadow(0 10px 18px rgba(13, 74, 94, 0.18));
    transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .prp:hover .prp-image img { transform: scale(1.05); }

  .prp-content {
    padding: 1.75rem 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .prp-head {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-right: 5rem;
  }

  .prp-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    align-self: flex-start;
    padding: 0.3rem 0.65rem 0.3rem 0.5rem;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-radius: 999px;
    margin-bottom: 0.2rem;
  }
  .prp-eyebrow svg { width: 11px; height: 11px; color: #2563eb; }

  .prp-brand {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #6b7280;
    margin: 0;
  }

  .prp-name {
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.022em;
    color: #0f172a;
    margin: 0;
  }
  .prp-name a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.3s ease, color 0.2s ease;
  }
  .prp-name a:hover { color: #0d4a5e; background-size: 100% 1px; }

  .prp-note {
    font-family: Georgia, "Times New Roman", serif;
    font-style: italic;
    font-size: 1rem;
    line-height: 1.6;
    color: #475569;
    margin: 0;
    padding-left: 0.875rem;
    border-left: 2px solid #2563eb;
  }

  .prp-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.85rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .prp-specs li {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #374151;
  }
  .prp-specs svg { width: 13px; height: 13px; color: #16a34a; flex-shrink: 0; }

  .prp-buy {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
    padding-top: 1rem;
    border-top: 1px dashed #e5e7eb;
  }

  .prp-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.4rem;
    background: #0d4a5e;
    color: #ffffff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 10px;
    white-space: nowrap;
    box-shadow: 0 4px 14px -4px rgba(13, 74, 94, 0.45);
    transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
  }
  .prp-cta svg { transition: transform 0.25s ease; }
  .prp-cta:hover {
    background: #2563eb;
    box-shadow: 0 6px 18px -4px rgba(37, 99, 235, 0.5);
    transform: translateY(-1px);
  }
  .prp-cta:hover svg { transform: translateX(3px); }

  .prp-foot-note {
    font-size: 0.75rem;
    color: #9ca3af;
    letter-spacing: 0.01em;
  }
  .prp-foot-note strong { font-weight: 700; color: #6b7280; }

  @media (max-width: 720px) {
    .prp { border-radius: 16px; }
    .prp-body { grid-template-columns: 1fr; }
    .prp-image {
      aspect-ratio: 16 / 11;
      border-right: none;
      border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }
    .prp-image img { padding: 1.25rem; }
    .prp-content { padding: 1.25rem 1.25rem 1.125rem; gap: 0.875rem; }
    .prp-head { padding-right: 5rem; }
    .prp-name { font-size: 1.2rem; }
    .prp-note { font-size: 0.9375rem; }
    .prp-buy { gap: 0.75rem; }
  }
</style>
