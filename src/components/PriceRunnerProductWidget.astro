---
interface Props {
  /** PriceRunner product id (the number in the product URL) */
  productId: string | number;
  /** Full pricerunner.dk product URL for the credit link */
  productHref: string;
  /** Product name shown as the card heading */
  title: string;
  /** Optional brand label above the title */
  brand?: string;
  /** Optional editorial first-person note */
  note?: string;
  /** Eyebrow pill text */
  eyebrow?: string;
  /** Short intro line under the title */
  subtitle?: string;
  /** Credit-link label */
  cta?: string;
  /** Max in-stock offers to show */
  offerLimit?: number;
  partnerId?: string;
  onlyInStock?: boolean;
  offerOrigin?: string;
  /** Override the DOM/widget id (defaults to a stable id per product) */
  widgetId?: string;
}

const {
  productId,
  productHref,
  title,
  brand,
  note,
  eyebrow = 'Bedste pris lige nu',
  subtitle,
  cta = 'Sammenlign priser hos PriceRunner',
  offerLimit = 3,
  partnerId = 'adrunner_dk_udeogfiske',
  onlyInStock = true,
  offerOrigin = 'NATIONAL',
  widgetId = `pr-product-widget-${productId}`,
} = Astro.props;

const params = new URLSearchParams({
  onlyInStock: String(onlyInStock),
  offerOrigin,
  offerLimit: String(offerLimit),
  productId: String(productId),
  partnerId,
  widgetId,
});
const widgetSrc = `https://api.pricerunner.com/publisher-widgets/dk/product.js?${params.toString()}`;
---

<aside class="prw" aria-label={`Prissammenligning: ${title}`}>
  <div class="prw-head">
    <span class="prw-eyebrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
        <line x1="7" y1="7" x2="7.01" y2="7" />
      </svg>
      {eyebrow}
    </span>
    <span class="prw-tag">Annonce</span>
  </div>

  {brand && <p class="prw-brand">{brand}</p>}
  <h3 class="prw-name">
    <a href={productHref} target="_blank" rel="nofollow sponsored noopener">{title}</a>
  </h3>
  {subtitle && <p class="prw-sub">{subtitle}</p>}
  {note && <p class="prw-note">{note}</p>}

  <div class="prw-widget">
    <div id={widgetId} style="display:block;width:100%;"></div>
  </div>

  <footer class="prw-foot">
    <a class="prw-foot-link" href={productHref} target="_blank" rel="nofollow sponsored noopener">
      <span>{cta}</span>
      <svg viewBox="0 0 16 16" width="15" height="15" aria-hidden="true">
        <path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
    <span class="prw-credit">I samarbejde med <strong>PriceRunner</strong></span>
  </footer>
</aside>

<!-- Gated behind marketing consent (see CookieConsent.astro). Loads only after the visitor accepts marketing cookies. -->
<script is:inline type="text/plain" data-consent="marketing" async src={widgetSrc}></script>

<style>
  .prw {
    position: relative;
    max-width: 760px;
    margin: 2rem auto 2.75rem;
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem 1.625rem 1.375rem;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 14px 30px -20px rgba(13, 74, 94, 0.2);
  }
  .prw::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, #2563eb 0%, #0d4a5e 55%, #c47d0a 100%);
  }

  .prw-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.875rem;
  }
  .prw-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #1d4ed8;
  }
  .prw-eyebrow svg { width: 13px; height: 13px; }
  .prw-tag {
    flex-shrink: 0;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #9ca3af;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
  }

  .prw-brand {
    margin: 0 0 0.15rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #94a3b8;
  }
  .prw-name {
    margin: 0;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: #0f172a;
  }
  .prw-name a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 0 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.3s ease, color 0.2s ease;
  }
  .prw-name a:hover { color: #0d4a5e; background-size: 100% 1px; }

  .prw-sub {
    margin: 0.4rem 0 0;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #6b7280;
  }
  .prw-note {
    margin: 0.875rem 0 0;
    padding: 0.75rem 1rem;
    background: #f8fbfc;
    border-left: 3px solid #2563eb;
    border-radius: 8px;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #374151;
  }

  .prw-widget {
    margin-top: 1.125rem;
    padding: 0.875rem;
    background: #f8fafc;
    border: 1px solid #eef2f6;
    border-radius: 12px;
    min-height: 96px;
  }
  /* let the injected PriceRunner widget sit flush and full-width inside the inset */
  .prw-widget :global(iframe) {
    display: block;
    width: 100% !important;
    border: 0;
    border-radius: 8px;
    background: transparent;
  }

  .prw-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.125rem;
    padding-top: 0.9rem;
    border-top: 1px dashed #e5e7eb;
  }
  .prw-foot-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.05rem;
    background: #0d4a5e;
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 9px;
    box-shadow: 0 6px 14px -8px rgba(13, 74, 94, 0.5);
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }
  .prw-foot-link svg { transition: transform 0.2s ease; }
  .prw-foot-link:hover { background: #2563eb; transform: translateY(-1px); box-shadow: 0 10px 18px -8px rgba(37, 99, 235, 0.5); }
  .prw-foot-link:hover svg { transform: translateX(3px); }
  .prw-credit { font-size: 0.75rem; color: #9ca3af; }
  .prw-credit strong { font-weight: 700; color: #6b7280; }

  @media (max-width: 560px) {
    .prw { padding: 1.25rem 1.125rem 1.125rem; }
    .prw-name { font-size: 1.15rem; }
    .prw-foot { flex-direction: column; align-items: stretch; }
    .prw-foot-link { justify-content: center; }
    .prw-credit { text-align: center; }
  }
</style>
