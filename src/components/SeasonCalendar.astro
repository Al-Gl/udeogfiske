---
type Season = 'peak' | 'good' | 'poor';

interface Props {
  /** Display name of the species (used in title and ARIA labels) */
  species: string;
  /** Exactly 12 entries, January through December */
  seasons: Season[];
  /** Optional footer note shown below the grid */
  note?: string;
  /** Override the card title. Defaults to "Sæsonkalender" */
  title?: string;
  /** Override the subtitle. Defaults to "Bedste fisketider for <species> — måned for måned" */
  subtitle?: string;
}

const { species, seasons, note, title = 'Sæsonkalender', subtitle } = Astro.props;

const monthShort = ['Jan', 'Feb', 'Mar', 'Apr', 'Maj', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dec'];
const monthFull = ['Januar', 'Februar', 'Marts', 'April', 'Maj', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'December'];
const seasonLabel: Record<Season, string> = { peak: 'Højsæson', good: 'God', poor: 'Lav' };
const seasonScore: Record<Season, number> = { peak: 3, good: 2, poor: 1 };
const currentMonth = new Date().getMonth();
const sub = subtitle ?? `Bedste fisketider for ${species.toLowerCase()} — måned for måned`;
---

<section class="fish-calendar-card" aria-labelledby={`cal-h-${species}`}>
  <header class="fcc-head">
    <svg class="fcc-waves" viewBox="0 0 240 80" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 50 Q 30 30, 60 50 T 120 50 T 180 50 T 240 50 V80 H0 Z" fill="rgba(255,255,255,0.06)" />
      <path d="M0 60 Q 30 42, 60 60 T 120 60 T 180 60 T 240 60 V80 H0 Z" fill="rgba(255,255,255,0.09)" />
      <path d="M0 70 Q 30 54, 60 70 T 120 70 T 180 70 T 240 70 V80 H0 Z" fill="rgba(255,255,255,0.12)" />
    </svg>
    <div class="fcc-head-inner">
      <div class="fcc-title-row">
        <span class="fcc-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
            <rect x="3" y="4.5" width="18" height="16" rx="2.5" />
            <path d="M3 9.5h18" />
            <path d="M8 2.5v4M16 2.5v4" />
          </svg>
        </span>
        <div class="fcc-titles">
          <h2 id={`cal-h-${species}`} class="fcc-title">{title}</h2>
          <p class="fcc-sub">{sub}</p>
        </div>
      </div>
      <ul class="fcc-legend" role="list">
        <li><span class="chip peak"></span>Højsæson</li>
        <li><span class="chip good"></span>God</li>
        <li><span class="chip poor"></span>Lav</li>
      </ul>
    </div>
  </header>

  <ol class="fcc-grid" role="list">
    {seasons.map((season, i) => {
      const isCurrent = i === currentMonth;
      const score = seasonScore[season];
      return (
        <li
          class={`m ${season}${isCurrent ? ' is-now' : ''}`}
          aria-label={`${monthFull[i]}: ${seasonLabel[season]}`}
        >
          {isCurrent && <span class="m-now">Nu</span>}
          <span class="m-name">{monthShort[i]}</span>
          <span class="m-bars" aria-hidden="true">
            <i class={score >= 1 ? 'on' : ''}></i>
            <i class={score >= 2 ? 'on' : ''}></i>
            <i class={score >= 3 ? 'on' : ''}></i>
          </span>
          <span class="m-tag">{seasonLabel[season]}</span>
        </li>
      );
    })}
  </ol>

  {note && (
    <p class="fcc-note">
      <svg class="fcc-note-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9" />
        <path d="M12 8v4M12 16h.01" />
      </svg>
      {note}
    </p>
  )}
</section>

<style>
  .fish-calendar-card {
    position: relative;
    max-width: 760px;
    margin: 0 auto 3rem;
    background: #f1f5f9;
    border: 1px solid #cbd5e1;
    border-radius: 18px;
    box-shadow:
      0 1px 2px rgba(15, 23, 42, 0.04),
      0 18px 40px -20px rgba(13, 74, 94, 0.28);
    overflow: hidden;
  }

  .fcc-head {
    position: relative;
    padding: 1.25rem 1.5rem 1.125rem;
    background: linear-gradient(135deg, #0d4a5e 0%, #14516b 45%, #1e3a8a 100%);
    overflow: hidden;
  }
  .fcc-waves {
    position: absolute;
    right: 0; bottom: 0;
    width: 55%; height: 100%;
    pointer-events: none;
  }
  .fcc-head-inner {
    position: relative;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  .fcc-title-row { display: flex; align-items: center; gap: 0.75rem; }
  .fcc-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 40px; height: 40px;
    background: rgba(255, 255, 255, 0.14);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 10px;
    backdrop-filter: blur(2px);
  }
  .fcc-titles { line-height: 1.2; }
  .fcc-title {
    font-size: 1.3125rem; font-weight: 700; color: #ffffff;
    letter-spacing: -0.02em; margin: 0;
  }
  .fcc-sub {
    font-size: 0.8125rem; color: rgba(255, 255, 255, 0.78);
    margin: 0.1875rem 0 0;
  }

  .fcc-legend {
    display: flex; gap: 0.375rem;
    list-style: none; padding: 0; margin: 0;
    flex-wrap: wrap;
  }
  .fcc-legend li {
    display: inline-flex; align-items: center; gap: 0.4375rem;
    padding: 0.3125rem 0.625rem;
    font-size: 0.75rem; font-weight: 500; color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
  }
  .fcc-legend .chip {
    width: 8px; height: 8px; border-radius: 999px; display: inline-block;
  }
  .chip.peak { background: #fbbf24; box-shadow: 0 0 6px rgba(251, 191, 36, 0.5); }
  .chip.good { background: #60a5fa; }
  .chip.poor { background: #cbd5e1; }

  .fcc-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0.375rem;
    list-style: none;
    padding: 1.25rem 1.25rem 1.125rem;
    margin: 0;
  }
  .m {
    position: relative;
    display: flex; flex-direction: column; align-items: center;
    padding: 0.75rem 0.25rem 0.625rem;
    border-radius: 10px;
    text-align: center;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    cursor: default;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  }
  .m:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 18px -10px rgba(13, 74, 94, 0.35);
  }
  .m-name {
    font-size: 0.8125rem; font-weight: 700;
    letter-spacing: 0.02em;
    color: #111827;
    margin-bottom: 0.4375rem;
  }
  .m-bars {
    display: flex; gap: 2px;
    height: 10px; align-items: flex-end;
    margin-bottom: 0.4375rem;
  }
  .m-bars i {
    width: 4px; border-radius: 2px;
    background: #e5e7eb;
    transition: background 0.15s ease;
  }
  .m-bars i:nth-child(1) { height: 40%; }
  .m-bars i:nth-child(2) { height: 70%; }
  .m-bars i:nth-child(3) { height: 100%; }
  .m-tag {
    font-size: 0.625rem; font-weight: 600;
    letter-spacing: 0.04em;
    color: #6b7280;
    text-transform: uppercase;
  }

  .m.peak {
    background: linear-gradient(180deg, #eef2ff 0%, #dbeafe 100%);
    border-color: #c7d2fe;
  }
  .m.peak .m-name { color: #1e3a8a; }
  .m.peak .m-tag { color: #1e3a8a; }
  .m.peak .m-bars i.on { background: #1e3a8a; }

  .m.good {
    background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
    border-color: #bfdbfe;
  }
  .m.good .m-name { color: #1d4ed8; }
  .m.good .m-tag { color: #2563eb; }
  .m.good .m-bars i.on { background: #3b82f6; }

  .m.poor {
    background: #ffffff;
    border-color: #e2e8f0;
  }
  .m.poor .m-name { color: #475569; }
  .m.poor .m-tag { color: #94a3b8; }
  .m.poor .m-bars i.on { background: #cbd5e1; }

  .m.is-now {
    box-shadow: 0 0 0 2px #c47d0a, 0 8px 18px -8px rgba(196, 125, 10, 0.5);
    transform: translateY(-1px);
    z-index: 1;
    animation: fcc-pulse 2.4s ease-in-out infinite;
  }
  .m.is-now:hover { transform: translateY(-3px); }
  .m-now {
    position: absolute; top: -8px; right: -4px;
    background: #c47d0a;
    color: #ffffff;
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.125rem 0.4375rem;
    border-radius: 999px;
    box-shadow: 0 2px 6px rgba(196, 125, 10, 0.4);
  }

  @keyframes fcc-pulse {
    0%, 100% {
      box-shadow: 0 0 0 2px #c47d0a, 0 0 0 0 rgba(196, 125, 10, 0.45), 0 8px 18px -8px rgba(196, 125, 10, 0.5);
    }
    50% {
      box-shadow: 0 0 0 2px #c47d0a, 0 0 0 8px rgba(196, 125, 10, 0), 0 8px 18px -8px rgba(196, 125, 10, 0.5);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .m.is-now { animation: none; }
  }

  .fcc-note {
    display: flex; align-items: flex-start; gap: 0.5rem;
    margin: 0 1.25rem 1.125rem;
    padding: 0.75rem 0.875rem;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    font-size: 0.8125rem; line-height: 1.55; color: #4b5563;
  }
  .fcc-note-icon {
    flex-shrink: 0;
    width: 16px; height: 16px;
    color: #0d4a5e;
    margin-top: 1px;
  }

  @media (max-width: 760px) {
    .fcc-head { padding: 1.125rem 1.125rem 1rem; }
    .fcc-title { font-size: 1.1875rem; }
    .fcc-grid { grid-template-columns: repeat(6, 1fr); gap: 0.5rem; padding: 1rem 1rem 0.875rem; }
    .fcc-note { margin: 0 1rem 1rem; }
    .m { padding: 0.625rem 0.25rem 0.5rem; }
    .m-name { font-size: 0.8125rem; }
  }
  @media (max-width: 480px) {
    .fcc-head-inner { flex-direction: column; align-items: flex-start; }
    .fcc-grid { grid-template-columns: repeat(4, 1fr); }
    .m-bars { height: 8px; }
  }
</style>
