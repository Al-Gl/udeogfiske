---
type IconKey = 'thermometer' | 'ruler' | 'calendar' | 'fish';

interface Props {
  /** Big display value, e.g. "8–13 °C" or "60 cm" */
  value: string;
  /** Caption underneath the number */
  caption: string;
  /** Optional icon. Defaults to "fish" */
  icon?: IconKey;
}
const { value, caption, icon = 'fish' } = Astro.props;
---

<aside class="stat">
  <span class="stat-icon" aria-hidden="true">
    {icon === 'thermometer' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4 4 0 1 0 5 0z" />
      </svg>
    )}
    {icon === 'ruler' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 8L8 21l-5-5L16 3z" />
        <path d="M7.5 11.5l2 2M11 8l2 2M14.5 4.5l2 2M4 15l2 2" />
      </svg>
    )}
    {icon === 'calendar' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" />
        <path d="M3 10h18M8 2v4M16 2v4" />
      </svg>
    )}
    {icon === 'fish' && (
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M2 12c3-5 9-6 13-4 1.5.6 3 1.6 4 2.8L23 7l-2 5 2 5-4-3.8c-1 1.2-2.5 2.2-4 2.8-4 2-10 1-13-4z" />
        <circle cx="16" cy="10.5" r="0.8" fill="#ffffff" />
      </svg>
    )}
  </span>
  <span class="stat-value">{value}</span>
  <span class="stat-caption">{caption}</span>
</aside>

<style>
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    margin: 2.25rem auto;
    padding: 1.5rem 1.75rem 1.625rem;
    max-width: 360px;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 12px 28px -18px rgba(13, 74, 94, 0.25);
  }
  .stat-icon {
    width: 36px; height: 36px;
    color: #0d4a5e;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #ecfeff;
    border-radius: 999px;
    padding: 7px;
  }
  .stat-icon svg { width: 100%; height: 100%; }
  .stat-value {
    font-size: clamp(2.25rem, 5vw, 2.875rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #0d4a5e;
    font-variant-numeric: tabular-nums;
  }
  .stat-caption {
    font-size: 0.875rem;
    color: #4b5563;
    line-height: 1.45;
    max-width: 280px;
  }
</style>
