---
import "../styles/global.css";
import CookieConsent from "../components/CookieConsent.astro";
import WelcomePopup from "../components/WelcomePopup.astro";

type PageType = 'website' | 'article' | 'category' | 'about';
type SchemaEntity = { name: string; sameAs?: string | string[] };

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  pageType?: PageType;
  breadcrumbs?: { name: string; url?: string }[];
  articleData?: {
    headline: string;
    image: string;
    datePublished: string;
    dateModified?: string;
  };
  faq?: { question: string; answer: string }[];
  about?: SchemaEntity[];
  mentions?: SchemaEntity[];
  itemList?: { name: string; url: string; image?: string }[];
}

const {
  title,
  description,
  canonical = "https://udeogfiske.dk/",
  ogImage = "https://udeogfiske.dk/images/forside_hero.jpg",
  pageType = 'website',
  breadcrumbs,
  articleData,
  faq,
  about,
  mentions,
  itemList,
} = Astro.props;

const buildEntity = (e: SchemaEntity) => ({
  "@type": "Thing",
  name: e.name,
  ...(e.sameAs ? { sameAs: e.sameAs } : {}),
});

const SITE = "https://udeogfiske.dk";
const ORG_ID = `${SITE}/#organization`;
const SITE_ID = `${SITE}/#website`;
const PERSON_ID = `${SITE}/#aldin`;
const PAGE_ID = `${canonical}#webpage`;
const BREADCRUMB_ID = `${canonical}#breadcrumb`;

const absUrl = (u: string) => (u.startsWith('http') ? u : `${SITE}${u.startsWith('/') ? '' : '/'}${u}`);

const graph: any[] = [
  {
    "@type": "Organization",
    "@id": ORG_ID,
    name: "Ude og Fiske",
    url: `${SITE}/`,
    logo: {
      "@type": "ImageObject",
      url: `${SITE}/images/logo.png`,
    },
  },
  {
    "@type": "Person",
    "@id": PERSON_ID,
    name: "Aldin Glavas",
    url: `${SITE}/om-mig/`,
    image: `${SITE}/images/aldin_profile.png`,
    jobTitle: "Grundlægger og redaktør",
    worksFor: { "@id": ORG_ID },
  },
  {
    "@type": "WebSite",
    "@id": SITE_ID,
    name: "Ude og Fiske",
    url: `${SITE}/`,
    description: "Guides, udstyr og pladser til din næste fisketur",
    publisher: { "@id": ORG_ID },
    potentialAction: {
      "@type": "SearchAction",
      target: `${SITE}/search?q={search_term_string}`,
      "query-input": "required name=search_term_string",
    },
  },
];

const webPageType =
  pageType === 'article' ? 'Article'
  : pageType === 'category' ? 'CollectionPage'
  : pageType === 'about' ? 'AboutPage'
  : 'WebPage';

const webPage: any = {
  "@type": webPageType,
  "@id": PAGE_ID,
  url: canonical,
  name: title,
  description,
  isPartOf: { "@id": SITE_ID },
  inLanguage: "da-DK",
};

if (breadcrumbs && breadcrumbs.length > 0) {
  webPage.breadcrumb = { "@id": BREADCRUMB_ID };
}

if (pageType === 'article' && articleData) {
  webPage.headline = articleData.headline;
  webPage.image = absUrl(articleData.image);
  webPage.datePublished = articleData.datePublished;
  webPage.dateModified = articleData.dateModified ?? articleData.datePublished;
  webPage.author = { "@id": PERSON_ID };
  webPage.publisher = { "@id": ORG_ID };
  webPage.mainEntityOfPage = { "@id": PAGE_ID };

  if (about && about.length > 0) {
    webPage.about = about.map(buildEntity);
  }
  if (mentions && mentions.length > 0) {
    webPage.mentions = mentions.map(buildEntity);
  }
  if (faq && faq.length > 0) {
    webPage.speakable = {
      "@type": "SpeakableSpecification",
      cssSelector: [".faq-item summary h3", ".faq-answer"],
    };
  }
}

graph.push(webPage);

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    "@type": "BreadcrumbList",
    "@id": BREADCRUMB_ID,
    itemListElement: breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: b.name,
      ...(b.url ? { item: absUrl(b.url) } : {}),
    })),
  });
}

if (faq && faq.length > 0) {
  graph.push({
    "@type": "FAQPage",
    "@id": `${canonical}#faq`,
    mainEntity: faq.map((f) => ({
      "@type": "Question",
      name: f.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: f.answer,
      },
    })),
  });
}

if (itemList && itemList.length > 0) {
  graph.push({
    "@type": "ItemList",
    "@id": `${canonical}#itemlist`,
    itemListElement: itemList.map((it, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: absUrl(it.url),
      name: it.name,
      ...(it.image ? { image: absUrl(it.image) } : {}),
    })),
  });
}

const jsonLd = { "@context": "https://schema.org", "@graph": graph };
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/images/logo.png" />

    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <meta property="og:type" content={pageType === 'article' ? 'article' : 'website'} />

    <!-- Google Analytics (GA4). Loads only after the visitor accepts the "Statistik"
         cookie category — the script stays inert (type="text/plain") until CookieConsent.astro
         activates it. Consent Mode v2 defaults (denied) are set there too. -->
    <script is:inline type="text/plain" data-consent="statistics" async src="https://www.googletagmanager.com/gtag/js?id=G-KH3MCDWBGT"></script>
    <script is:inline type="text/plain" data-consent="statistics">
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-KH3MCDWBGT');
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700&display=swap" rel="stylesheet" />

    <style>
      :root {
        --p:       #0d4a5e;
        --p-dark:  #082e3b;
        --p-light: #e6f1f5;
        --a:       #c47d0a;
        --a-dark:  #a26209;
        --tx:      #111827;
        --muted:   #6b7280;
        --bg:      #ffffff;
        --surf:    #f8fafc;
        --bdr:     #e5e7eb;
        --font:    "Inter", system-ui, sans-serif;
        --mw:      1200px;
        --r:       10px;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }

      body {
        font-family: var(--font);
        font-size: 1rem;
        line-height: 1.7;
        color: var(--tx);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      img { max-width: 100%; height: auto; display: block; }
      a { color: inherit; text-decoration: none; }

      /* ── Header ── */
      .skip-link {
        position: absolute;
        left: 0.75rem;
        top: -3rem;
        z-index: 300;
        padding: 0.6rem 1rem;
        background: #0d4a5e;
        color: #ffffff;
        font-size: 0.875rem;
        font-weight: 600;
        border-radius: 0 0 8px 8px;
        text-decoration: none;
        transition: top 0.18s ease;
      }
      .skip-link:focus {
        top: 0;
        outline: 2px solid #c47d0a;
        outline-offset: 2px;
      }

      .sh {
        position: sticky;
        top: 0;
        z-index: 200;
        background: rgba(255, 255, 255, 0.96);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--bdr);
      }

      .sh-bar {
        height: 3px;
        background: var(--p);
      }

      .sh-inner {
        max-width: var(--mw);
        margin: 0 auto;
        padding: 0 1.5rem;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
      }

      .sh-logo {
        font-size: 1.0625rem;
        font-weight: 700;
        color: var(--p);
        letter-spacing: -0.03em;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 0.625rem;
        text-decoration: none;
      }

      .sh-logo-img {
        width: 80px;
        height: 80px;
        object-fit: contain;
        flex-shrink: 0;
        display: block;
      }

      .sh-logo-text {
        line-height: 1;
      }

      .sh-logo:hover { color: var(--p-dark); }

      @media (max-width: 480px) {
        .sh-logo-text { display: none; }
      }

      .sh-nav {
        display: flex;
        align-items: center;
        gap: 0;
      }

      .sh-link {
        font-size: 0.8125rem;
        font-weight: 400;
        color: var(--muted);
        padding: 0.35rem 0.6rem;
        border-radius: 6px;
        transition: color 0.15s, background 0.15s;
        white-space: nowrap;
      }

      .sh-link:hover {
        color: var(--tx);
        background: var(--surf);
      }

      .sh-cta {
        font-size: 0.8125rem;
        font-weight: 500;
        background: var(--p);
        color: #fff;
        padding: 0.375rem 0.875rem;
        border-radius: 6px;
        margin-left: 0.5rem;
        transition: background 0.15s, transform 0.15s;
        white-space: nowrap;
      }

      .sh-cta:hover {
        background: var(--p-dark);
        transform: translateY(-1px);
      }

      .sh-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.375rem;
        color: var(--tx);
        border-radius: 6px;
        transition: background 0.15s;
      }

      .sh-toggle:hover { background: var(--surf); }

      @media (max-width: 800px) {
        .sh-nav {
          display: none;
          position: absolute;
          top: 63px;
          left: 0;
          right: 0;
          background: #fff;
          border-bottom: 1px solid var(--bdr);
          flex-direction: column;
          align-items: stretch;
          padding: 0.5rem 1rem 1rem;
          box-shadow: 0 8px 24px rgba(0,0,0,0.06);
        }

        .sh-nav.open { display: flex; }

        .sh-link {
          padding: 0.75rem 0.5rem;
          border-radius: 0;
          border-bottom: 1px solid var(--bdr);
          font-size: 0.9375rem;
        }

        .sh-link:last-child { border-bottom: none; }

        .sh-cta {
          margin: 0.75rem 0 0;
          text-align: center;
          padding: 0.75rem;
        }

        .sh-toggle { display: block; }
      }

      /* ── Footer ── */
      .sf {
        background: #071520;
        color: rgba(255, 255, 255, 0.65);
        padding: 4rem 1.5rem 2.5rem;
        margin-top: 0;
      }

      .sf-grid {
        max-width: var(--mw);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 2.5fr 1fr 1fr;
        gap: 3rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        margin-bottom: 2rem;
      }

      .sf-brand { font-size: 1.25rem; font-weight: 700; color: #fff; letter-spacing: -0.02em; margin-bottom: 0.625rem; }
      .sf-tagline { font-size: 0.875rem; line-height: 1.7; color: rgba(255,255,255,0.45); margin-bottom: 1.5rem; max-width: 320px; }
      .sf-copy { font-size: 0.75rem; color: rgba(255,255,255,0.3); }

      .sf-col-title {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255, 255, 255, 0.35);
        margin-bottom: 1rem;
      }

      .sf-links { display: flex; flex-direction: column; gap: 0.625rem; }

      .sf-link {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.55);
        transition: color 0.15s;
      }

      .sf-link:hover { color: #fff; }

      .sf-cookie-btn {
        font-family: inherit;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.25);
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 0.15s;
      }
      .sf-cookie-btn:hover { color: #fff; }

      .sf-bottom {
        max-width: var(--mw);
        margin: 0 auto;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.25);
      }

      @media (max-width: 700px) {
        .sf-grid { grid-template-columns: 1fr 1fr; }
        .sf-grid > div:first-child { grid-column: 1 / -1; }
      }

      @media (max-width: 420px) {
        .sf-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>

  <body>
    <a href="#indhold" class="skip-link">Spring til indhold</a>
    <header class="sh">
      <div class="sh-bar"></div>
      <div class="sh-inner">
        <a href="/" class="sh-logo" aria-label="Ude og Fiske — forside">
          <img src="/images/logo.png" alt="Ude og Fiske" class="sh-logo-img" width="80" height="80" />
          <span class="sh-logo-text">Ude og Fiske</span>
        </a>

        <button
          class="sh-toggle"
          aria-label="Åbn menu"
          onclick="this.parentElement.querySelector('.sh-nav').classList.toggle('open')"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M3 5.5h14M3 10h14M3 14.5h14" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>

        <nav class="sh-nav" aria-label="Primær navigation">
          <a href="/fiskeguide/" class="sh-link">Fiskeguides</a>
          <a href="/fiskeudstyr/" class="sh-link">Fiskeudstyr</a>
          <a href="/guide-til-fisk/" class="sh-link">Guides til fisk</a>
          <a href="/fisketure/" class="sh-link">Fisketure</a>
          <a href="/fiskepladser/" class="sh-link">Fiskepladser</a>
          <a href="/om-mig/" class="sh-cta">Kontakt</a>
        </nav>
      </div>
    </header>

    <main id="indhold">
      <slot />
    </main>

    <footer class="sf">
      <div class="sf-grid">
        <div>
          <div class="sf-brand">Ude og Fiske</div>
          <p class="sf-tagline">Inspiration og praktisk viden til din næste fisketur i Danmark — uanset om du er begynder eller erfaren lystfisker.</p>
          <p class="sf-copy">©2026 Ude og Fiske · CVR: 43131168</p>
        </div>
        <div>
          <div class="sf-col-title">Indhold</div>
          <div class="sf-links">
            <a href="/fiskeguide/" class="sf-link">Fiskeguides</a>
            <a href="/fiskeudstyr/" class="sf-link">Fiskeudstyr</a>
            <a href="/fisketure/" class="sf-link">Fisketure</a>
          </div>
        </div>
        <div>
          <div class="sf-col-title">Fisk & Pladser</div>
          <div class="sf-links">
            <a href="/guide-til-fisk/" class="sf-link">Guides til fisk</a>
            <a href="/fiskepladser/" class="sf-link">Fiskepladser</a>
          </div>
        </div>
      </div>
      <div class="sf-bottom">
        Alle anbefalinger er redaktionelt uafhængige. Nogle links er affiliate-links.
        · <a href="/cookiepolitik/" class="sf-link" style="display:inline">Cookiepolitik</a>
        · <button type="button" class="sf-cookie-btn" onclick="window.uofCookies&&window.uofCookies.open()">Cookieindstillinger</button>
      </div>
    </footer>

    <CookieConsent />
    <WelcomePopup />
  </body>
</html>
