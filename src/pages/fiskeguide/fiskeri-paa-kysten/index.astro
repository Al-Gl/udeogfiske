  }

  .fish-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    line-height: 1.2;
    text-shadow: 0 1px 2px rgba(0,0,0,0.35);
  }

  .fish-sub {
