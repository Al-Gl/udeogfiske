    href: "/fiskeguide/fluefiskeri/",
    image: "/images/fluefiskeri_card.jpg",
    alt: "Fluefisker på kysten",
    chip: "Fiskeform",
  },
  {
    title: "Polaroid briller til fiskeri",
    description: "Polariserede briller er afgørende for spotfiskeri efter regnbueørreder i klart vand — guide til valg.",
    href: "/fiskeudstyr/beklaedning/polaroid-briller/",
    image: "/images/Hero_leopardbund-min.jpg",
    alt: "Polaroid briller",
    chip: "Udstyr",
  },
  {
    title: "Regnbueørredfiskeri",
    description: "Den fulde guide til regnbueørreden — fisken du jagter i Put & Take søen.",
    href: "/guide-til-fisk/regnbueorredfiskeri/",
    image: "/images/regnbueoerred_card.png",
    alt: "Regnbueørred",
    chip: "Fiskearter",
  },
];

const faqs = [
  {
    question: "Skal jeg starte fluefiskeriet i Put & Take?",
    answer: "Ja — Put & Take er den <strong>nemmeste og mest velkomne</strong> indgang til fluefiskeri. Fiskene er der, du kan ofte se dem, kastene behøver ikke være lange, og du kan øve dig på alt fra tørflue til nymphe i samme sø. Det er der jeg startede, og det er der jeg sender alle nybegyndere hen.",
  },
  {
    question: "Hvilke fluer fanger flest regnbueørreder?",
    answer: "Fluer med <strong>store haler</strong> som du kan få til at \"danse\" i vandet via små vip med stangen er konsistent de mest effektive. Almindelige kystfluer virker også, men er ikke optimerede til regnbueørredens adfærd. Klassiske P&T-fluer som Cat's Whisker, Woolly Bugger og Mojo Minnow er gode udgangspunkter.",
  },
  {
    question: "Hvorfor er polaroid briller så vigtige i Put & Take?",
    answer: "Fordi <strong>spotfiskeri</strong> — at kaste på en fisk du kan se — er den sjoveste og mest effektive teknik. Uden polariserede briller ser du måske 10% af de fisk der er ude i vandet. Selv billige briller til 150-200 kr gør en kæmpe forskel. Læs <a href=\"/fiskeudstyr/beklaedning/polaroid-briller/\">polaroid-briller guiden</a> hvis du skal investere.",
  },
  {
    question: "Hvordan placerer jeg fluen korrekt foran en fisk?",
