>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fiskepladser/">Fiskepladser</a>
        <span>›</span>
        <span>Isefjorden</span>
