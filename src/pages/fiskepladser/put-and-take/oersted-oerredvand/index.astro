const faqs = [
  {
    question: "Hvorfor var fiskeriet svært en kold marts dag i Ørsted Ørredvand?",
    answer: "Vandet var stadig <strong>for koldt midt i marts</strong>, og fiskene gemte sig på bunden hvor jorden gav vandet lidt mere varme end overfladen. Det betød at fluefiskeriet — som arbejder i de øverste vandlag — var udsigtsløst. Først da jeg skiftede til spinnestang og kunne arbejde dybere, kom der bid.",
  },
  {
    question: "Hvilken spinner fangede regnbueørreden?",
    answer: "En <strong>Meps Aglia i størrelse 2, Rainbow Trout micropigments</strong>. Efter tre kast havde jeg bid — en regnbueørred på ca. <strong>2,5 kg</strong>. Mepps Aglia er et af de mest populære spinnere til ørredfiskeri i Put & Take, og str. 2 er min favorit fordi den er let og kan fiskes langsomt ind.",
  },
  {
    question: "Hvad er Præsten UL og hvornår bruger du den?",
    answer: "Præsten UL er en <strong>helt let gennemløber på 4,5 g</strong> — som skabt til Put & Take søer. Dens lave vægt gør at den kan fiskes utroligt langsomt, og dens gang i vandet er helt unik. Jeg har konsekvent haft held med den i Ørsted, men på denne kolde marts dag gav den kun et enkelt bid uden hook-up. Det er min plan B når Meps'en holder op med at fange.",
  },
  {
    question: "Hvad er en herningflue og hvorfor virkede den ikke?",
    answer: "En herningflue er en <strong>klassisk dansk Put & Take flue</strong> med tungt metalhoved og lang hale. Den synker hurtigt og er normalt perfekt til søens øverste vandlag. Problemet på denne tur var ikke fluen — det var <strong>vandtemperaturen</strong>. Fiskene stod helt på bunden, og selv 15 andre fluefiskere fik intet bid.",
  },
  {
    question: "Hvornår er Ørsted Ørredvand bedst at besøge?",
    answer: "Jeg anbefaler at vente til <strong>april</strong>, hvor vandet er begyndt at varme op. I april–maj er fiskene aktive i de øvre vandlag og fluestangen kan for alvor sættes på prøve. I marts er det stadig spinnefiskeri på bunden der giver hjem, og fangsten kan være sparsom selv for erfarne fiskere.",
  },
