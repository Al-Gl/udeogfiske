const faqs = [
  {
    question: "Hvorfor er Stevns kendt for havørredfiskeri?",
    answer: "Stevns har en <strong>meget varierende bund</strong> og områder hvor der er <strong>dybt vand tæt på land</strong>. Det er præcis de forhold som de helt store havørreder søger — især i de koldere perioder af året. Området er kendt over hele Danmark for at give store fisk.",
  },
