const faqs = [
  {
    question: "Hvorfor valgte du Bøgeskoven på en kold januardag?",
    answer: "Jeg havde tjekket <strong>FCOO.dk</strong> for vandtemperatur og salinitet, samt vejrudsigten. Alt pegede på muligheden for havørreder — bortset fra den svage fralandsvind, som kunne gøre fiskene forsigtige. Vandtemperaturen var estimeret til omkring 4 grader, hvilket er lige på grænsen til hvad jeg synes er for koldt for havørreden.",
  },
  {
    question: "Hvad er FCOO og hvordan bruger man det til havørredfiskeri?",
    answer: "FCOO.dk er Forsvarets Center for Operativ Oceanografi, og siden viser <strong>vandtemperatur, salinitet og strømforhold</strong> i danske farvande. Til havørredfiskeri er vandtemperaturen særligt vigtig — under 4 grader bliver havørreden ofte passiv. Saliniteten kan også fortælle dig hvilke pladser der vil holde fisk på en given dag.",
  },
  {
    question: "Hvilket grej fiskede du med?",
