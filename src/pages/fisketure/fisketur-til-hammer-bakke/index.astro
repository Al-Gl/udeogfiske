const faqs = [
  {
    question: "Hvordan fandt du frem til Hammer Bakke som fiskespot?",
    answer: "Jeg brugte <strong>Google Maps og Kraks luftfoto</strong> til at researche. På luftfotos kan man tydeligt se bundforhold: <strong>lyse områder er sand, mørke områder er tang eller græs</strong>. Den blanding er ideel for havørreder. Hammer Bakke — særligt området syd for færgelejet og rundt om pynten — viste netop den blanding på Krak.",
