  .article { max-width: 760px; margin: 0 auto; }
  .article p { font-size: 1rem; color: #374151; line-height: 1.8; margin-bottom: 1.25rem; }
  .article p strong { color: #111827; font-weight: 700; }
  .article a { color: #0d4a5e; font-weight: 600; text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
  .article a:hover { color: #c47d0a; }
  .article h2 {
    font-size: 1.625rem; font-weight: 700; color: #111827;
    letter-spacing: -0.02em; line-height: 1.25; margin: 2.5rem 0 1rem;
  }
  .article h2:first-child { margin-top: 0; }
  .faq-heading {
    font-size: 1.625rem; font-weight: 700; color: #111827;
    letter-spacing: -0.02em; line-height: 1.25;
    margin: 4rem auto 1rem; max-width: 760px;
  }
</style>
