---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';
import StatHighlight from '../../../components/StatHighlight.astro';
import Affiliate from '../../../components/Affiliate.astro';

const related = [
  {
    title: "Fiskeri i Roskilde Fjord",
    description: "Områdeguide til Roskilde Fjord — Salvadsparken er en af pladserne på listen, og denne tur foregik dér.",
    href: "/fiskepladser/roskilde-fjord/",
    image: "/images/roskilde_fjord_card.png",
    alt: "Roskilde Fjord ved solnedgang",
    chip: "Plads",
  },
  {
    title: "Gennemløbsblink",
    description: "Den blink-type jeg fangede min 64 cm havørred på — fysikken bag hvorfor de fanger flere fisk hjem.",
    href: "/fiskeudstyr/endegrej/gennemlobsblink/",
    image: "/images/endegrej.png",
    alt: "Gennemløbsblink",
    chip: "Udstyr",
  },
  {
    title: "Havørredfiskeri i Juli",
    description: "Hvad du kan forvente af havørredfiskeriet i juli — varmt vand, aftentur og hvornår fisken alligevel bider.",
    href: "/guide-til-fisk/havorredfiskeri/havorredfiskeri-juli/",
    image: "/images/havørred_card.jpeg",
    alt: "Havørredfiskeri om sommeren",
    chip: "Sæson",
  },
];

const faqs = [
  {
    question: "Hvorfor valgte du Salvadsparken på en sommerdag med høj blæst?",
    answer: "Jeg havde overvejet både fjord og kyst. Vinden var meldt til at falde til <strong>4-5 m/s</strong>, så jeg besluttede mig for at fluefiske i fjorden efter havørreder. Da jeg ankom blæste det stadig kraftigt, så jeg var glad for at jeg også havde min spinnestang med.",
  },
  {
    question: "Hvad gør høj vandstand for fiskeriet i Roskilde Fjord?",
    answer: "Vandstanden var <strong>80-100 cm højere end normalt</strong>, sandsynligvis pga. flere dages stærk vestenvind der havde presset vand op i denne side af fjorden. Høj vandstand kombineret med bølget vand kan være rigtig gode forhold for havørreder — fisken kommer tættere på land end normalt.",
  },
  {
    question: "Hvilket blink fangede den store havørred?",
    answer: "En <strong>Snurrebassen i olivengrøn</strong> — et gennemløbsblink. Da jeg fisker med gennemløbsblink bruger jeg fletline med et fluorocarbon-forfang, hvilket jeg var glad for da fighten var hård og fisken viste sig at være på den gode side af 50 cm.",
  },
  {
    question: "Kan man fange havørreder i fjorden midt om sommeren?",
    answer: "Ja, selv om fjorden ikke er det helt oplagte sted at jage havørreder midt om sommeren, så kan man stadig fange fisk der. Jeg har lagt mærke til at en <strong>lang periode med varmt vejr efterfulgt af lidt voldsommere vejr med regn og stærk vind</strong> plejer at give fisk — turen her er et godt eksempel.",
  },
  {
    question: "Hvad gør du, når en stor havørred ramler i blinket?",
    answer: "Holder ro og bremser hårdt. Den her fisk begyndte hurtigt at vise sig i overfladen med kraftige plask — der gik det op for mig hvor stor den var. Fluorocarbon-forfanget gav mig sikkerhed til at presse fight'en, og jeg fik den landet i nettet. På land målte den <strong>64 cm</strong> — min største havørred til dato.",
  },
];
---

<MainLayout
  title="Salvadsparken 16. juli 2022 — 64 cm havørred i hård blæst"
  description="Dokumenteret aftentur til Salvadsparken i Roskilde Fjord, 16. juli 2022. Hård vestenvind, høj vandstand — og min største havørred til dato på 64 cm."
  canonical="https://udeogfiske.dk/fisketure/salvadsparken-16-juli-2022/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Fisketure", url: "/fisketure/" },
    { name: "Salvadsparken — 16. juli 2022" },
  ]}
  articleData={{
    headline: "Hård blæst og høj vandstand i Salvadsparken",
    image: "/images/roskilde_fjord_card.png",
    datePublished: "2022-07-18",
    dateModified: "2026-05-13",
  }}
  faq={faqs}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fisketure/">Fisketure</a>
        <span>›</span>
        <span>Salvadsparken — 16. juli 2022</span>
      </nav>
      <h1 class="pg-title">Hård blæst og høj vandstand i Salvadsparken</h1>
      <p class="pg-sub">En sommeraften i Roskilde Fjord der blev til min største havørred til dato — 64 cm på en olivengrøn snurrebasse.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvad blev resultatet af turen?</h2>
        <p class="ac-a">Min <strong>største havørred til dato — 64 cm</strong> — landet på en olivengrøn Snurrebasse (gennemløbsblink), efter ca. 1 times fiskeri ved solnedgang. Hård vestenvind, 80-100 cm forhøjet vandstand og bølget vand var den uventede cocktail der gav fisken.</p>
      </div>

      <StatHighlight value="64 cm" caption="Min største havørred til dato — fanget her" icon="ruler" />

      <AuthorProfile
        quote="Jeg havde overvejet kysten længe, men i sidste øjeblik blev det fjorden. Det var dén beslutning der gav mig min største havørred til dato. Solnedgang, bølget vand, høj vandstand — alle de små ting fald på plads samtidig. Det er den slags ture man husker."
      />

      <article class="article">
        <p>Et par dage havde jeg siddet og kigget på <strong>FCOO</strong> og <strong>YR</strong> for at finde det bedste tidspunkt at tage ud og fiske på, og det faldt på lørdag. Da det er sommer havde jeg besluttet mig for at fiske om aftenen, så spørgsmålet var bare om det skulle være fjord eller kyst. Jeg hældte mest til at tage op til nordkysten, men ombestemte mig i sidste øjeblik. Et par timer inden jeg skulle afsted sagde vejrudsigten at vinden ville aftage til ca. 4-5 m/s, så jeg havde besluttet mig for at fluefiske i fjorden efter havørreder. Da jeg ankom til Salvadsparken kunne jeg konstatere at det stadig blæste ret kraftigt, så jeg var ret glad for at jeg også havde min spinnestang med!</p>

        <h2>Hvordan var forholdene da jeg ankom?</h2>
        <p>På vej ud til pladsen fra parkeringspladsen kunne jeg se at <strong>vandstanden var ret høj</strong>, hvilket nok skyldes at det i et par dage havde blæst ret voldsomt fra vest så vandet var blevet presset op i denne side af fjorden.</p>

        <p>Den blå markering er hvor jeg primært fiskede.</p>

        <DidYouKnow>
          Vestenvind over flere dage kan presse vand op i den østlige side af Roskilde Fjord — vandstandsforskelle på <strong>80-100 cm</strong> er ikke usædvanlige under sådanne forhold. Det betyder at strækninger som normalt er for lavvandede pludselig holder fisk, fordi havørreden kommer tættere på land end den ellers ville.
        </DidYouKnow>

        <h2>Hvordan startede fiskeriet?</h2>
        <p>Jeg begyndte fiskeriet omkring 20.45 hvilket gav mig ca. 1 times fiskeri inden solen gik ned. Vandet var godt bølget, hvilket jo ofte giver godt havørredfiskeri. Vandstanden var godt 80-100 cm højere end hvad den plejer, hvilket var ret overraskende. <strong>Snurrebassen i olivengrøn</strong> blev valgt og fiskeriet gik i gang.</p>

        <TipBox>
          Når du fisker med gennemløbsblink i hård vind: brug <strong>fletline med fluorocarbon-forfang</strong>. Fletlinen giver direkte kontakt og lange kast i blæst, fluorocarbonet skjuler forfanget for fisken og kan holde til en hård fight. Det er en kombination jeg konsekvent vælger til havørred — og det var præcis den linje der landede 64 cm-fisken her.
        </TipBox>

        <Affiliate
          productId="76484"
          note="Mit faste valg til havørred-forfang. Westin W6 ST5 er en blødere fluorocarbon der binder pænere knude og holder bedre under en hård fight. Det er præcis dén type fluorocarbon jeg havde knyttet til fletlinen, da 64 cm-fisken huggede her i Salvadsparken — og det er en jeg konsekvent vender tilbage til."
        />

        <h2>Hvordan endte aftenen?</h2>
        <p>Som altid er naturen ved Salvadsparken smuk, og jeg nød solnedgangen — da jeg fik mig noget af et chok. Lige pludselig kom der et <strong>ordentligt ryk i stangen</strong> og jeg kunne mærke at der var en ret stor fisk for enden af linen. Den begyndte også, ret hurtigt, at vise sig i overfladen, hvilket resulterede i kraftige plask i vandet. Der gik det for alvor op for mig hvor stor fisken egentlig var!</p>

        <p>Fighten var hård, og jeg var ret glad for at jeg havde opgraderet til en god tykkelse fletline og fluorocarbon, som jeg bruger som forfang når jeg fisker med gennemløbsblink. Jeg fik landet fisken i mit net og så at den var på den gode side af de 50 cm. På land fik jeg den aflivet og målt. <strong>Hele 64 cm var den på</strong>, hvilket betød at det var min største havørred til dato. Den kom på fiskegalgen, og jeg fortsatte mit fiskeri i 30 minutter endnu inden jeg besluttede mig for at afslutte dagens fiskeri.</p>

        <p>Så selv om fjorden ikke er det helt oplagte sted at jage havørreder midt om sommeren, så kan man altså stadig fange fisk der! Jeg har lagt mærke til at en lang periode med varmt vejr, efterfulgt af lidt voldsommere vejr med regn og stærk vind, plejer at give fisk.</p>
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p set:html={f.answer} />
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>


</MainLayout>

<style>
