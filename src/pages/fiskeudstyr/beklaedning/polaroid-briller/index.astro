  {
    key: 'overskyet', label: 'Overskyet & lavt lys', badge: 'Til gråvejr',
    lens: 'Gul / lysebrun', light: 'Overskyet / lavt lys', use: 'Tidlig morgen & gråvejr', contrast: 'Høj',
