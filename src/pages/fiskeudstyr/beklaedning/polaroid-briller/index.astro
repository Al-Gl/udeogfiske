    productId: '75529',
  },
  {
    key: 'sol', label: 'Skarpt sollys', badge: 'Til solen',
    lens: 'Grå / grøn', light: 'Skarpt sollys', use: 'Hav & åbent vand i sol', contrast: 'Neutral',
    note: 'Grå linser dæmper kraftigt lys uden at forvrænge farverne — bedst på de helt skarpe sommerdage på åbent vand. Holder også til at flyde, hvis du taber dem under wading.',
