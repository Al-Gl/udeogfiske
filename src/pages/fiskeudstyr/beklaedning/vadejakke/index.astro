---
import MainLayout from '../../../../layouts/MainLayout.astro';
import RelatedRow from '../../../../components/RelatedRow.astro';
import AuthorProfile from '../../../../components/AuthorProfile.astro';
import DidYouKnow from '../../../../components/DidYouKnow.astro';
import TipBox from '../../../../components/TipBox.astro';
import StatHighlight from '../../../../components/StatHighlight.astro';
import GuideLink from '../../../../components/GuideLink.astro';
import AffiliateTrio from '../../../../components/AffiliateTrio.astro';
import { getProduct, formatPrice } from '../../../../lib/feed';

// Vadejakke-vælger — one recommended jacket per budget/quality tier. Cards are
// pre-rendered server-side and toggled client-side so the product swaps with the choice.
const finder = [
  {
    key: 'begynder', label: 'Begynder & budget', badge: 'Billigst',
    material: 'Nylon', water: 'Vandtæt', pockets: 'Få, enkle', use: 'Lejlighedsvis brug',
    note: 'En billig vadejakke der holder regnen ude på de lejlighedsvise ture. Kvaliteten er i den lave ende — lommer og lynlås slides først — men den fanger fisk og koster næsten ingenting.',
    productId: '50616',
  },
  {
    key: 'vaerdi', label: 'Bedste værdi', badge: 'Mit udgangspunkt',
    material: 'Åndbar membran', water: 'Vandtæt + åndbar', pockets: 'Flere, lukkbare', use: 'Alsidig kyst & å',
    note: 'Det bedste forhold mellem pris og kvalitet. Åndbar, vandtæt og med ordentlige lukkbare lommer — den dækker langt de fleste kyst- og åfiskere uden at koste en formue. Mit anbefalede udgangspunkt.',
    productId: '501046',
  },
  {
    key: 'haard', label: 'Til hård brug', badge: 'Til kysten året rundt',
    material: 'Åndbar laminat', water: 'Høj, tapede sømme', pockets: 'Store, lukkbare', use: 'Hård kystbrug, helår',
    note: 'Bygget til den, der står på kysten året rundt. Robust laminat, tapede sømme og store lommer der holder til årevis af brug. Pairer perfekt med et sæt åndbare X5-waders.',
    productId: '82121',
  },
  {
    key: 'premium', label: 'Premium', badge: 'Kompromisløs',
    material: '3-lags membran', water: 'Maks., tapede sømme', pockets: 'Rigeligt + D-ring', use: 'Kompromisløs helårsbrug',
    note: 'Kompromisløs kvalitet i 3-lags membran med tapede sømme og D-ring til nettet. Dyr, men den slags grej der holder i mange år — værd at investere i, hvis du fisker meget.',
    productId: '503619',
  },
];

const finderRods = finder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Vadejakke-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const related = [
  {
    title: "Waders og støvler",
    description: "Det vigtigste stykke beklædning til kystfiskeriet — guide til PVC, neopren og åndbare waders.",
    href: "/fiskeudstyr/beklaedning/waders-og-stovler/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Waders til kystfiskeri",
    chip: "Beklædning",
  },
  {
    title: "Polaroid briller",
    description: "Polariserede solbriller skærer reflekserne fra vandoverfladen — kan være afgørende for at se fisken.",
    href: "/fiskeudstyr/beklaedning/polaroid-briller/",
    image: "/images/Hero_leopardbund-min.jpg",
    alt: "Polaroid briller mod refleksioner",
    chip: "Beklædning",
  },
  {
    title: "Fiskeri på kysten",
    description: "Komplet guide til kystfiskeri i Danmark — pladser, teknik, agn og hvornår sæsonen er bedst.",
    href: "/fiskeguide/fiskeri-paa-kysten/",
    image: "/images/kystfiskeri_hero.png",
    alt: "Kystfiskeri",
    chip: "Lokation",
  },
];

const faqs = [
  {
    question: "Hvornår skal jeg bruge en vadejakke?",
    answer: "Vadejakken er specifikt designet til lystfiskere som fisker med waders i vand. Bruger du allerede waders flittigt — typisk på kysten eller i fjorden efter havørred — så er en god vadejakke det naturlige følgekøb. Den holder dig tør og komfortabel mens du står i vandet, og giver samtidig opbevaringsplads til det fiskeudstyr du skal have tæt på.",
  },
  {
    question: "Hvad gør en vadejakke anderledes end en almindelig fiskejakke?",
    answer: "Vadejakken er <strong>kortere</strong> end en almindelig fiskejakke — den slutter højere oppe på kroppen så den ikke bliver våd når du står i vandet. Den er fremstillet i åndbare, vandtætte materialer som <strong>Gore-Tex eller nylon</strong> og har typisk flere lommer til grej og en hætte. Du kan dog sagtens bruge vadejakken til almindeligt fiskeri også — det gør jeg selv.",
  },
  {
    question: "Hvilke ting kigger jeg efter når jeg køber en vadejakke?",
    answer: "Mine fire krav: <strong>store lommer der kan lukkes helt</strong> så ting ikke falder ud, <strong>D-ring på ryggen til nettet</strong>, <strong>vandtæt og vindtæt</strong>, og <strong>behagelig at have på</strong> — du kommer typisk til at bruge den i flere timer ad gangen, så pasformen er afgørende.",
  },
  {
    question: "Hvad koster en god vadejakke?",
    answer: "Du kan få en brugbar begynder-vadejakke fra omkring <strong>600 kr</strong>, men kvaliteten på lommer og lynlås er i den lave ende. Det bedste forhold mellem pris og kvalitet ligger efter min erfaring omkring <strong>800–1.600 kr</strong>, hvor du får åndbart materiale, tapede sømme og ordentlige lommer. Premium-jakker i 3-lags membran koster <strong>2.000 kr og op</strong>, men holder også i mange år.",
  },
  {
    question: "Kan jeg bruge vadejakken til almindeligt fiskeri?",
    answer: "Ja, sagtens — det gør jeg selv. Jeg har én vadejakke af god kvalitet, som jeg bruger til stort set alt mit fiskeri, også når jeg ikke står i vandet. Den er blot lidt kortere end en almindelig fiskejakke, hvilket sjældent er noget problem fra land, mole eller båd.",
  },
  {
    question: "Skal jeg købe vadejakken i en størrelse større?",
    answer: "Ja — jeg køber altid vadejakker i lidt større størrelse end mit normale tøj. Især om vinteren har du flere lag termotøj på under, og jakken skal kunne sidde komfortabelt over uden at stramme. Hvis det er muligt, så prøv jakken før du køber, eller ring til butikken og rådfør dig om størrelsen hvis du bestiller online.",
  },
  {
    question: "Hvor slides en vadejakke først, og kan man reparere den?",
    answer: "<strong>Lommerne</strong> er det første sted jeg oplever slitage — der kan komme huller hvilket gør at grejet falder direkte ned i vandet. Det kan man heldigvis sy sammen igen uden større arbejde. <strong>Lynlåsen</strong> er det andet svage punkt, og her hænger pris og kvalitet sammen: de dyre vadejakker er bare lavet af bedre materialer og holder længere end de billige fra Harald Nyborg eller Bilka.",
  },
];
---

<MainLayout
  title="Vadejakke | Guide til valg af vadejakker til vadefiskeri"
  description="Vælg den helt rigtige vadejakke til dit vadefiskeri. Brug vadejakke-vælgeren og find den rette fra begynder-budget til premium Gore-Tex-klasse."
  canonical="https://udeogfiske.dk/fiskeudstyr/beklaedning/vadejakke/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Fiskeudstyr", url: "/fiskeudstyr/" },
    { name: "Beklædning", url: "/fiskeudstyr/beklaedning/" },
    { name: "Vadejakke" },
  ]}
  articleData={{
    headline: "Vadejakker",
    image: "/images/havørred_hero1.jpeg",
    datePublished: "2022-05-24",
    dateModified: "2026-06-02",
  }}
  faq={faqs}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fiskeudstyr/">Fiskeudstyr</a>
        <span>›</span>
        <a href="/fiskeudstyr/beklaedning/">Beklædning</a>
        <span>›</span>
        <span>Vadejakke</span>
      </nav>
      <h1 class="pg-title">Vadejakker</h1>
      <p class="pg-sub">Den vandtætte yderjakke til kystfiskeri og vadefiskeri — beskytter mod regn, vind og bølgesprøjt mens du står i vandet og holder grejet tæt på.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvornår har jeg brug for en vadejakke?</h2>
        <p class="ac-a">Hvis du <strong>allerede bruger waders</strong> på kysten eller i fjorden, så er vadejakken den naturlige følge-investering. Den er <strong>kortere</strong> end en almindelig fiskejakke (så den ikke bliver våd når du vader), <strong>vandtæt og åndbar</strong>, og har lommer + D-ring til nettet i ryggen. Pris og kvalitet hænger tæt sammen — særligt på lommer og lynlås.</p>
      </div>

      <AuthorProfile
        quote="Jeg har én vadejakke af rigtig god kvalitet, og jeg bruger den til stort set al mit fiskeri — også når jeg ikke står i vandet. Det er den slags grej hvor det betaler sig at bruge lidt mere første gang, fordi en god vadejakke holder i mange år. Mine vigtigste krav: gode lukkbare lommer, D-ring til nettet, vandtæt og vindtæt, og at den sidder behageligt over et par lag termotøj."
      />

      <article class="article">
        <p>Hvis du ejer et par waders og bruger dem flittigt ved du også hvor vigtigt det er at have en god vadejakke. En vadejakke er en type overtøj, der er specielt designet til lystfiskere, der fisker med waders i vand. En god vadejakke hjælper dig med at holde dig tør og komfortabel, mens du vader gennem vandet og fisker efter den fisk du nu er på jagt efter, Desuden giver vadejakken dig mulighed for at have det vigtigste fiskeudstyr tæt på dig når du skal bruge det.</p>

        <p>Når jeg skal ud og investere i en ny vadejakke har jeg nogle specifikke krav til den hvilket jeg skal have opfyldt. Kravene er mine egne, men jeg vil mene at mange fiskere vil kunne stille lignende krav.</p>

        <p>De ting jeg kigger efter i vadejakker er:</p>

        <ul>
          <li>Store lommer der kan lukkes helt så ting ikke falder ud</li>
          <li>D-ring på ryggen til nettet</li>
          <li>Vandtæt og vindtæt</li>
          <li>Behagelig at have på</li>
        </ul>

        <DidYouKnow>
          <strong>D-ringen på ryggen</strong> bruges til at hænge fangstnettet i — så har du det inden for rækkevidde uden at det generer mens du fisker. Det er en lille detalje, men en af de første jeg tjekker når jeg kigger på en ny vadejakke.
        </DidYouKnow>

        <StatHighlight
          value="4 krav"
          caption="Mine krav til en vadejakke: lukkbare lommer, D-ring til nettet, vandtæt & vindtæt — og behagelig over termolag"
          icon="ruler"
        />

        <h2>Hvilken vadejakke skal du vælge?</h2>
        <p>Vadejakker spænder fra billige begynder-modeller til kompromisløse premium-jakker, og forskellen mærkes mest på materiale, lommer og lynlås. Vælg dit niveau nedenfor, så får du min anbefaling til materiale, vandtæthed og lommer — og et konkret forslag:</p>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Vadejakke-vælger</span>
          <h3 class="rf-title">Find vadejakken til dit fiskeri</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg niveau">
          {finderRods.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Materiale</span><span class="rf-spec-value" id="rf-material">{finderRods[0].material}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Vandtæthed</span><span class="rf-spec-value" id="rf-water">{finderRods[0].water}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Lommer</span><span class="rf-spec-value" id="rf-pockets">{finderRods[0].pockets}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bedst til</span><span class="rf-spec-value" id="rf-use">{finderRods[0].use}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{finderRods[0].note}</p>

        <div class="rf-products">
          {finderRods.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ finderData: finder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          finderData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            material: document.getElementById('rf-material'),
            water: document.getElementById('rf-water'),
            pockets: document.getElementById('rf-pockets'),
            use: document.getElementById('rf-use'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.material.textContent = d.material;
              els.water.textContent = d.water;
              els.pockets.textContent = d.pockets;
              els.use.textContent = d.use;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <article class="article">
        <h2>Vadejakke eller almindelig fiskejakke?</h2>
        <p>Vadejakken kendes ved at den er ret kort, og grunden til dette er jo at man bruger jakken mens man vadefisker. Her vil en lang jakke blive våd hvis den er for lang, derfor er vadejakker lidt kortere end almindelige fiskejakker. Her er forskellen kort:</p>

        <div class="prey-table-wrap" role="region" aria-label="Vadejakke sammenlignet med almindelig fiskejakke">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Type</th>
                <th scope="col">Længde</th>
                <th scope="col">Bedst til</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" data-label="Type">Vadejakke</th>
                <td data-label="Længde">Kort — slutter over vandlinjen</td>
                <td data-label="Bedst til">Vadefiskeri i vand — kyst, fjord og å</td>
              </tr>
              <tr>
                <th scope="row" data-label="Type">Almindelig fiskejakke</th>
                <td data-label="Længde">Længere — dækker mere</td>
                <td data-label="Bedst til">Fiskeri fra land, mole og båd</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p>Du kan dog stadig bruge din vadejakke til almindelig fiskeri. Det gør jeg selv meget ofte. Jeg har en vadejakke som er rigtig god kvalitet og den bruger jeg til stort set al mit fiskeri, selv om jeg har en anden fiskejakke.</p>

        <p>Vadejakker er normalt fremstillet af åndbare, vandtætte materialer som Gore-Tex eller nylon. De har ofte flere lommer til opbevaring af grej og andre forsyninger samt en hætte til at beskytte dit hoved mod elementerne. Og den bør være fremstillet af slidstærke materialer, der kan holde til gentagen brug, for der er ingen der har lyst til at skifte vadejakke hele tiden. Med så mange forskellige stilarter og funktioner at vælge imellem er der ingen grund til ikke at investere i en god vadejakke.</p>

        <TipBox>
          Køb vadejakken i en størrelse større end dit normale tøj. Du har typisk flere lag termotøj på under om vinteren, og jakken skal kunne sidde komfortabelt over uden at stramme — det er forskellen på en behagelig dag og en kort dag på kysten.
        </TipBox>

        <h2>Hvor slides vadejakker først?</h2>

        <p>Som al andet tøj, bliver en vadejakke også udsat for slitage. Der hvor jeg oplever at vadejakker hurtigst bliver slidte og går i stykker er i lommerne, hvor der kan komme huller hvilket gør at det udstyr du har i lommerne falder ud af lommen. Det er jo et kæmpe problem hvis man står i vandet og ens fiskeudstyr begynder at falde ud og direkte ned i vandet.</p>

        <p>Jeg er lidt af en gør-det-selv person, så jeg har haft held med at sy lommerne sammen igen. Det kræver ikke alt for meget arbejde og er lige til.</p>

        <p>Et andet sted jeg oplever at der ofte kommer slitage er at lynlåsen kan gå i stykker. Det kræver lidt mere at fikse det selv, men her oplever jeg dog at pris og kvalitet hænger meget sammen. De dyre vadejakker er bare lavet af bedre kvalitet og holder meget længere end de billige du kan finde i Harald Nyborg eller Bilka.</p>

        <h2>Det øvrige kyst-grej</h2>
        <p>Vadejakken arbejder sjældent alene. Her er tre ting jeg altid har på eller med, når jeg vader på kysten — og som passer perfekt sammen med jakken:</p>

        <AffiliateTrio
          title="Det øvrige kyst-grej"
          intro="Det grej der hører sammen med vadejakken på kysten. Et net du hænger i jakkens D-ring, et par flydende polaroidbriller så du kan se fiskene — og en uldhue til de kolde morgener."
          products={[
            {
              productId: "505982",
              badge: "Til D-ringen",
              badgeTone: "teal",
              highlight: true,
              note: "Et fangstnet med gumminet, du hænger direkte i jakkens D-ring på ryggen. Easy Flip foldes ud med én hånd — og gummiet skåner fisken, hvis den skal genudsættes.",
            },
            {
              productId: "75528",
              badge: "Øjnene",
              badgeTone: "slate",
              note: "Flydende polaroidbriller skærer reflekserne fra vandet, så du kan se grunden, fiskene og dit fodfæste. At de flyder er guld værd, hvis de ryger i vandet mens du vader.",
            },
            {
              productId: "76177",
              badge: "Varmen",
              badgeTone: "orange",
              note: "En uldhue holder varmen selv når den bliver fugtig — uundværlig på de kolde forårs- og efterårsmorgener, hvor det bedste havørredfiskeri ofte er.",
            },
          ]}
        />

        <GuideLink
          href="/fiskeudstyr/beklaedning/waders-og-stovler/"
          title="Læs guiden til valg af waders"
          desc="Mangler du waders til vadejakken? Find den rette type — PVC, neopren eller åndbare."
        />
        <GuideLink
          href="/fiskeudstyr/beklaedning/polaroid-briller/"
          title="Læs guiden til polaroidbriller"
          desc="Hvilke linsefarver virker hvornår — og hvorfor polariserede briller ændrer dit fiskeri."
        />
        <GuideLink
          href="/fiskeguide/fiskeri-paa-kysten/"
          title="Læs guiden til kystfiskeri"
          desc="Pladser, teknik, agn og sæson — alt om at fiske havørred på den danske kyst."
        />
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p set:html={f.answer} />
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>

</MainLayout>

<style>
  .pg-hero {
    position: relative;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 55%, rgba(0, 0, 0, 0.15) 100%),
      url('/images/havørred_hero1.jpeg') center/cover no-repeat;
    padding: 5rem 0 4.5rem;
  }

  .pg-ctn { max-width: 1040px; margin: 0 auto; padding: 0 1.5rem; }

  .pg-bc {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem; flex-wrap: wrap;
  }
  .pg-bc a { color: rgba(255,255,255,0.65); transition: color 0.15s; }
  .pg-bc a:hover { color: #ffffff; }

  .pg-title {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #ffffff;
    letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 0.875rem;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }
  .pg-sub {
    font-size: 1.0625rem; font-weight: 300; color: rgba(255,255,255,0.85);
    line-height: 1.65; max-width: 580px; text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }

