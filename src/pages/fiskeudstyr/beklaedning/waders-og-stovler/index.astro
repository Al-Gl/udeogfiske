        />
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p set:html={f.answer} />
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>

</MainLayout>

