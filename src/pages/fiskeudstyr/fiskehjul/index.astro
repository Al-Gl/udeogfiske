---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';
import StatHighlight from '../../../components/StatHighlight.astro';
import GuideLink from '../../../components/GuideLink.astro';
import AffiliateTrio from '../../../components/AffiliateTrio.astro';
import { getProduct, formatPrice } from '../../../lib/feed';

// Hjul-vælger — one recommended reel per fishing form. Cards are pre-rendered
// server-side and toggled client-side so the product swaps with the choice.
const finder = [
  {
    key: 'kyst', label: 'Kyst & havørred', badge: 'Mit udgangspunkt',
    type: 'Fastspolehjul', size: 'Str. 2500–3000', brake: 'Blød frontbremse', use: 'Havørred på kyst',
    note: 'Et fastspolehjul i str. 3000 er den klassiske kyst-arbejdshest. Blød indspoling og en jævn frontbremse, der beskytter den tynde line, når en havørred sætter af. Det hjul jeg griber 80 % af tiden.',
    productId: '501665',
  },
  {
    key: 'pt', label: 'Put & Take & let', badge: 'Til de lette agn',
    type: 'Fastspolehjul (let)', size: 'Str. 2000–2500', brake: 'Fintindstillelig', use: 'Regnbue i P&T & UL',
    note: 'Til Put & Take og UL vil du have et mindre, let hjul, der balancerer med en følsom stang. En fintindstillelig bremse er vigtig, fordi den skal beskytte tynd line mod en frisk regnbueørred.',
    productId: '77126',
  },
  {
    key: 'gedde', label: 'Gedde, hav & store fisk', badge: 'Til de store',
    type: 'Fastspolehjul (kraftigt)', size: 'Str. 4000–6000', brake: 'Kraftig', use: 'Gedde, sandart & hav',
    note: 'Store rovfisk og bådfiskeri kræver et kraftigt hjul med høj line-kapacitet og en stærk bremse, der kan stoppe en gedde eller en torsk uden at give op. Robusthed slår finesse her.',
    productId: '503102',
  },
  {
    key: 'flue', label: 'Fluefiskeri', badge: 'Til fluestangen',
    type: 'Fluehjul', size: 'Klasse #5/6', brake: 'Skivebremse på line', use: 'Ørred på flue',
    note: 'Fluehjulet er primært en line-holder, så det skal først og fremmest matche stangens klasse. Et #5/6-hjul passer til den alsidige klasse 5–6 kyststang — og en god skivebremse er rar, når en stor fisk tager line.',
    productId: '67111',
  },
];

const finderRods = finder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Hjul-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const related = [
  {
    title: "Spinnestænger",
    description: "Stangen og hjulet er det makkerpar der bestemmer hele fiskeoplevelsen. Find den rette spinnestang til dit nye hjul.",
    href: "/fiskeudstyr/fiskestaenger/spinnestaenger/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Spinnefiskeri på kysten",
    chip: "Udstyr",
  },
  {
    title: "Fluefiskestænger",
    description: "Et fluefiskehjul skal matche stangens klasse — guide til valg af fluestang fra klasse 2 til klasse 9.",
    href: "/fiskeudstyr/fiskestaenger/fluefiskestang/",
    image: "/images/fluefiskeri_card.jpg",
    alt: "Fluefiskestang",
    chip: "Udstyr",
  },
  {
    title: "Endegrej",
    description: "Blink, wobblere og fluer — det lokkemiddel der får fisken til at bide når hjulet og stangen først er på plads.",
    href: "/fiskeudstyr/endegrej/",
    image: "/images/endegrej.png",
    alt: "Endegrej",
    chip: "Udstyr",
  },
];

const faqs = [
  {
    question: "Hvad er forskellen på et fastspolehjul og et fluefiskehjul?",
    answer: "Fastspolehjulet har mekaniske dele og en bremse der bruges til at kontrollere fisken under fight, og det er den mest populære og almindelige type fiskehjul. Fluefiskehjulet har derimod ingen mekaniske dele og fungerer primært som en line-holder — bremsen virker ved at justere modstanden på linen. Fluehjulet er ikke nær så afgørende for fiskeoplevelsen som spinnestangens hjul.",
  },
  {
    question: "Hvilke producenter af fastspolehjul er bedst?",
    answer: "De producenter jeg selv bruger, og som mange andre fiskere bruger, er <strong>Shimano, Daiwa og Abu Garcia</strong>. Det betyder ikke at du ikke kan finde gode hjul af andre producenter — det kan du naturligvis godt — men disse tre har bevist deres værd over mange år og findes i flere prisklasser fra begynder til premium.",
  },
  {
    question: "Hvilken størrelse fastspolehjul skal jeg vælge?",
    answer: "Størrelsen følger fiskeformen. Til <strong>Put & Take og UL</strong> bruger du str. <strong>2000–2500</strong>, til den alsidige <strong>kyststang efter havørred</strong> er str. <strong>2500–3000</strong> det naturlige valg, og til <strong>gedde, hav og bådfiskeri</strong> går du op i str. <strong>4000–6000</strong> for line-kapacitet og bremsekraft. Hjulet skal altid balancere med stangens kastevægt og længde.",
  },
  {
    question: "Skal stangen og hjulet matche i klasse og vægt?",
    answer: "Ja, særligt på fluestang/fluehjul-kombinationen er det vigtigt at klasserne passer sammen for at få det bedste resultat. På spinning-grej skal hjulet matche stangens kastevægt og længde — et tungt hjul på en let kyststang giver dårlig balance, og omvendt mangler et let hjul styrken til at trække en stor fisk ind på en kraftig havstang.",
  },
  {
    question: "Hvor vigtigt er hjulet sammenlignet med stangen?",
    answer: "På spinning-grej er hjulet næsten lige så vigtigt som stangen — bremsen og spole-funktionen afgør om du lander fisken eller mister den. På flue-grej er hjulet derimod sekundært til stangen, fordi fluefiskehjulets primære funktion er at indeholde linen — kasten og fight-kontrollen sker primært gennem stangen og hånden på linen.",
  },
  {
    question: "Hvor ofte skal jeg vedligeholde mit fiskehjul?",
    answer: "Skyl altid hjulet i <strong>ferskvand efter saltvandsfiskeri</strong>, og tør det af. En gang om året kan du give det en dråbe <strong>hjulolie</strong> på de bevægelige dele og lidt fedt på gearet — det er den enkleste måde at få et godt hjul til at holde i mange år. Skil det kun ad, hvis du ved hvad du laver; ellers er en let udvendig pleje rigeligt.",
  },
  {
    question: "Hvad skal et godt fastspolehjul kunne?",
    answer: "Det skal kunne <strong>spinde linen ind på en blød og jævn måde</strong>, så linen ikke bliver kludret ved selve indspolingen. Bremsen skal være justerbar og pålidelig, så du kan kontrollere fisken under fight uden at linen springer. Med et godt fastspolehjul monteret på en spinnestang er du klar til at fange alle typer fisk — uanset om det er fra båd eller land.",
  },
];
---

<MainLayout
  title="Fiskehjul | Guide til valg af det bedste fiskehjul til dig"
  description="Guide til valg af fiskehjul til spinnestænger og fluestænger. Brug hjul-vælgeren og find det rette fastspolehjul eller fluehjul til din fiskeform og stang."
  canonical="https://udeogfiske.dk/fiskeudstyr/fiskehjul/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Fiskeudstyr", url: "/fiskeudstyr/" },
    { name: "Fiskehjul" },
  ]}
  articleData={{
    headline: "Guide til køb af fiskehjul",
    image: "/images/fiskehjul.png",
    datePublished: "2020-07-06",
    dateModified: "2026-06-02",
  }}
  faq={faqs}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fiskeudstyr/">Fiskeudstyr</a>
        <span>›</span>
        <span>Fiskehjul</span>
      </nav>
      <h1 class="pg-title">Guide til køb af fiskehjul</h1>
      <p class="pg-sub">Det rette fiskehjul matcher stangens klasse, holder år efter år, og afgør om fight'en føles kontrolleret eller kaotisk. Guide til fastspolehjul og fluefiskehjul.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvilket fiskehjul skal jeg vælge?</h2>
        <p class="ac-a">Til spinnefiskeri er <strong>fastspolehjulet</strong> det rette valg — det er den mest populære type og dækker stort set alle fiskeformer. Til fluefiskeri har du brug for et <strong>fluefiskehjul</strong> der matcher stangens klasse. <strong>Shimano, Daiwa og Abu Garcia</strong> er de mest pålidelige producenter på fastspole-siden.</p>
      </div>

      <AuthorProfile
        quote="Mit hovedhjul de sidste fem år har været et Shimano Stradic — solid bremse, blød indspoling, og det har klaret alt fra havørred på Stevns til hornfisk fra Roskilde Mole. Jeg har også Daiwa og Abu Garcia hjul i grej-tasken til andre stænger. Pointen er ikke at finde det dyreste hjul, men et fra en producent der er kendt for at holde — så bruger du tiden på at fiske, ikke på at sende hjulet til reparation."
      />

      <article class="article">
        <p>Fiskestangen og fiskehjulet er de to vigtigste stykker udstyr når det gælder fiskeri. Fiskestangguiden har vist hvilke stænger man skal gå efter, og denne guide vil hjælpe dig med at finde det helt rigtige fiskehjul til din fiskestang. Da der findes forskellige fiskestænger, findes der naturligvis også forskellige fiskehjul. Et hjul til en fluefiskestang adskiller sig markant fra et hjul til en spinnestang. Derfor vil jeg også gennemgå de hjul som man oftest har brug for, hvilket er til spinnestænger. Hjulets funktion er at det bruges til at spinne dit endegrej ind når du har kastet det i vandet. Derfor er det vigtigt med et hjul som spinner ind på en blød og jævn måde så man undgår at linen bliver kludret til ved selve indspolingen. En anden vigtig funktion ved hjulet, er dets bremse.</p>

        <DidYouKnow>
          Et fluefiskehjul har <strong>ingen mekaniske dele</strong> — det er primært en line-holder. Bremsen fungerer ved at justere modstanden direkte på linen, ikke gennem en mekanisk bremse-skive som på et fastspolehjul. Det er en af grundene til at fluehjulet er sekundært til stangen i fluefiskeri.
        </DidYouKnow>

        <StatHighlight
          value="Str. 3000"
          caption="Den klassiske allround-hjulstørrelse til en 9-fods kyststang — matcher kastevægt 10–30 g og rummer rigeligt fletline"
          icon="ruler"
        />

        <h2>Hvilket fiskehjul passer til dit fiskeri?</h2>
        <p>Det rette hjul afhænger af, hvad du fisker efter. Et let Put & Take-hjul er noget andet end et kraftigt geddehjul eller et fluehjul, der bare skal matche stangens klasse. Vælg din fiskeform nedenfor, så får du min anbefaling til hjultype, størrelse og bremse — og et konkret forslag:</p>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Hjul-vælger</span>
          <h3 class="rf-title">Find fiskehjulet til dit fiskeri</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg fiskeform">
          {finderRods.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Hjultype</span><span class="rf-spec-value" id="rf-type">{finderRods[0].type}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Størrelse</span><span class="rf-spec-value" id="rf-size">{finderRods[0].size}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bremse</span><span class="rf-spec-value" id="rf-brake">{finderRods[0].brake}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bedst til</span><span class="rf-spec-value" id="rf-use">{finderRods[0].use}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{finderRods[0].note}</p>

        <div class="rf-products">
          {finderRods.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ finderData: finder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          finderData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            type: document.getElementById('rf-type'),
            size: document.getElementById('rf-size'),
            brake: document.getElementById('rf-brake'),
            use: document.getElementById('rf-use'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.type.textContent = d.type;
              els.size.textContent = d.size;
              els.brake.textContent = d.brake;
              els.use.textContent = d.use;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <article class="article">
        <h2>Fastspolehjul</h2>
        <p>Fastspolehjul er den mest populære og almindelige form for hjul man kan finde, da den opfylder en bred vifte af fiskeformer. Med et fastspolehjul monteret på en spinnestang er du klar til at fange alle typer fisk, hvad enten det er fra båd eller land.</p>

        <p>Da fastspolehjul er den mest populære form for fiskehjul findes der også et hav af producenter som producerer hjul i forskellige prisklasser. De producenter som jeg selv bruger, og som mange andre fiskere bruger er Shimano, Daiwa og Abu Garcia. Det betyder ikke at du ikke kan finde gode hjul af andre producenter, hvilket man naturligvis kan.</p>

        <TipBox>
          Læs <a href="/fiskeudstyr/fiskestaenger/spinnestaenger/">spinnestang-guiden</a> <em>før</em> du vælger hjul. Hjulet kan altid skiftes hvis stangen ikke passer, men en stang og et hjul i forskellige klasser fungerer aldrig optimalt sammen — og dårligt match er den hyppigste grund til at nybegyndere mister fisk under fight.
        </TipBox>

        <h2>Fastspolehjul eller fluehjul?</h2>
        <p>De to hjultyper løser hver sin opgave og fungerer på vidt forskellige måder. Her er forskellen sat op mod hinanden:</p>

        <div class="prey-table-wrap" role="region" aria-label="Fastspolehjul sammenlignet med fluehjul">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Hjultype</th>
                <th scope="col">Bremse</th>
                <th scope="col">Vigtighed</th>
                <th scope="col">Bedst til</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" data-label="Hjultype">Fastspolehjul</th>
                <td data-label="Bremse">Mekanisk frontbremse</td>
                <td data-label="Vigtighed">Næsten lige så vigtig som stangen</td>
                <td data-label="Bedst til">Spin: kyst, sø, hav & P&amp;T</td>
              </tr>
              <tr>
                <th scope="row" data-label="Hjultype">Fluehjul</th>
                <td data-label="Bremse">Modstand direkte på linen</td>
                <td data-label="Vigtighed">Sekundær til stangen</td>
                <td data-label="Bedst til">Fluefiskeri</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2>Fluefiskehjul</h2>
        <p>Fluefiskehjulet adskiller sig fra et almindeligt fastspolehjul på den måde, at der ikke er nogle mekaniske dele i et fluehjul og bremsen er ikke den samme bremse som på et fastspolehjul. Bremsen fungerer på den måde at du skruer op og ned for modstanden på linen afhængig af hvor stor fisken er og afhængig af om du vil kontrollere fisken med bremsen eller med linen. Fluefiskehjulets primære funktion er at indeholde al den line som du skal bruge i dit fiskeri. Hjulet er derfor ikke så vigtigt som stangen, men det betyder ikke at du kan vælge hvilket som helst hjul til din stang. Stangens og hjulets vægt og klasse skal passe sammen hvis du ønsker de bedste resultater når du fisker.</p>

        <p>Er du i tvivl over hvilken fluestang du skal vælge, kan du læse artiklen omkring valg af <a href="/fiskeudstyr/fiskestaenger/fluefiskestang/">fluestænger</a>.</p>

        <h2>Gør hjulet klar til fiskeriet</h2>
        <p>Et nyt hjul skal spoles op med line og passes lidt, før og efter det kommer i vandet. Her er de tre ting jeg altid har til at gøre et hjul klar — og holde det kørende i mange sæsoner:</p>

        <AffiliateTrio
          title="Gør hjulet klar"
          intro="Det grej der gør hjulet fiskeklar og holder det kørende. En stærk hovedline til spolen, et fluorocarbon-forfang fisken ikke ser, og en dråbe hjulolie så bremsen og gearet holder år efter år."
          products={[
            {
              productId: "82489",
              badge: "Hovedlinen",
              badgeTone: "teal",
              highlight: true,
              note: "En tynd, stærk fletline giver dig lange kast og direkte kontakt til agnet. 150 m er rigeligt til at spole et almindeligt fastspolehjul op — det første du sætter på et nyt hjul.",
            },
            {
              productId: "78797",
              badge: "Forfanget",
              badgeTone: "slate",
              note: "Et fluorocarbon-forfang bindes på fletlinen — det er næsten usynligt i vandet, så fisken ikke ser linen. Især vigtigt til klart vand og kræsne havørreder.",
            },
            {
              productId: "46562",
              badge: "Vedligeholdet",
              badgeTone: "orange",
              note: "En dråbe hjulolie på de bevægelige dele en gang om året holder indspolingen blød og bremsen pålidelig. Det er den billigste måde at få et godt hjul til at holde i mange år.",
            },
          ]}
        />

        <GuideLink
          href="/fiskeudstyr/fiskestaenger/spinnestaenger/"
          title="Læs spinnestang-guiden"
          desc="Hjulet skal matche stangen — find den rette spinnestang med stangvælgeren."
        />
        <GuideLink
          href="/fiskeudstyr/fiskestaenger/fluefiskestang/"
          title="Læs guiden til fluestænger"
          desc="Vælger du fluehjul, skal det matche stangens klasse — se fluestangvælgeren."
        />
        <GuideLink
          href="/fiskeudstyr/tilbehor/fiskesaet-for-begyndere/"
          title="Helt ny? Se begyndersættene"
          desc="Combo-sæt med stang og hjul der passer sammen fra start — den nemmeste vej ind."
        />
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p set:html={f.answer} />
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>

</MainLayout>

<style>
  .pg-hero {
    position: relative;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 55%, rgba(0, 0, 0, 0.15) 100%),
      url('/images/fiskehjul.png') center/cover no-repeat;
    padding: 5rem 0 4.5rem;
  }

  .pg-ctn { max-width: 1040px; margin: 0 auto; padding: 0 1.5rem; }

  .pg-bc {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem; flex-wrap: wrap;
  }
  .pg-bc a { color: rgba(255,255,255,0.65); transition: color 0.15s; }
  .pg-bc a:hover { color: #ffffff; }

  .pg-title {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #ffffff;
    letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 0.875rem;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }
  .pg-sub {
    font-size: 1.0625rem; font-weight: 300; color: rgba(255,255,255,0.85);
    line-height: 1.65; max-width: 580px; text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }

  .pg-body { padding: 3.5rem 0 5rem; }

  .answer-capsule {
    background: #ffffff; border: 1px solid #e5e7eb; border-left: 4px solid #0d4a5e;
