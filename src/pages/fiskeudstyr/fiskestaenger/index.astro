---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';

const subTypes = [
  {
    title: "Spinnestænger",
    description: "Den alsidige stang til kyst-, å- og søfiskeri. Spinnestangen er ofte førstevalget for nybegyndere.",
    href: "/fiskeudstyr/fiskestaenger/spinnestaenger/",
    image: "/images/fiskestanger.png",
    alt: "Spinnestang i brug ved kysten",
  },
  {
    title: "Fiskestænger til havet",
    description: "Kraftige havstænger til pirke, ned-rig og dybt vand fra båd eller mole.",
    href: "/fiskeudstyr/fiskestaenger/fiskestang-til-havet/",
    image: "/images/mole_fiskeri.jpg",
    alt: "Mole-fiskeri med havstang",
  },
  {
    title: "Fluefiskestænger",
    description: "Lette fluestænger til havørred og put-and-take ørreder — let kast, præcis præsentation.",
    href: "/fiskeudstyr/fiskestaenger/fluefiskestang/",
    image: "/images/fluefiskeri_card.jpg",
    alt: "Fluestang i brug ved kyst",
  },
];

const related = [
  {
    title: "Fiskehjul",
    description: "Spinnehjul og fluehjul — find det rette hjul til din stang og fiskeform.",
    href: "/fiskeudstyr/fiskehjul/",
    image: "/images/fiskehjul.png",
    alt: "Fiskehjul",
    chip: "Udstyr",
  },
  {
    title: "Endegrej",
    description: "Blink, wobblere og fluer — det lokkemiddel der får fisken til at bide.",
    href: "/fiskeudstyr/endegrej/",
    image: "/images/endegrej.png",
    alt: "Endegrej",
    chip: "Udstyr",
  },
  {
    title: "Spinnefiskeri efter havørred",
    description: "Klassisk kystspin med blink — den mest populære teknik i Danmark.",
    href: "/guide-til-fisk/havorredfiskeri/spinnefiskeri-havorred/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Spinnefiskeri",
    chip: "Teknik",
  },
];

const faqs = [
  {
    question: "Hvilken fiskestang skal jeg vælge som nybegynder?",
    answer: "Som nybegynder anbefaler jeg en spinnestang i 9 fod (270 cm) med kasevægt 10-30 g — den dækker næsten alle danske fiskeformer fra kyst til sø og er det naturlige førstevalg. Hos din lokale fiskeributik kan medarbejderne hjælpe med at matche stangen til den fiskeform du går mest op i.",
  },
  {
    question: "Hvilke typer fiskestænger findes der?",
    answer: "De tre primære typer fiskestænger er spinnestænger (alsidige til kyst, å og sø), havstænger (kraftige til dybt vand, pirke og bådfiskeri) og fluestænger (lette til kastefluefiskeri efter havørred og put-and-take ørreder). Hver type findes i flere længder og kasevægte tilpasset specifikke fiskeformer.",
  },
  {
    question: "Hvad koster en god fiskestang?",
    answer: "Du kan komme i gang for 3-500 kr i et begyndersæt fra Bilka eller Harald Nyborg. En solid spinnestang i mellemklassen ligger på 800-1500 kr og holder mange år. Topkvalitet starter omkring 2000 kr og opefter — ofte unødvendigt for begyndere, men en mærkbar opgradering for erfarne fiskere.",
  },
  {
    question: "Hvor skal jeg købe min fiskestang?",
    answer: "Den lokale fiskeributik er det bedste sted at købe sin første stang — medarbejderne kan rådgive om passende model til dit fiskeri og lade dig holde stængerne i hånden inden du beslutter dig. Online butikker har større udvalg og ofte bedre priser, men kræver at du selv ved hvad du leder efter.",
  },
  {
    question: "Hvad er forskellen på en spinnestang og en fluestang?",
    answer: "Spinnestangen kaster vægten af blinket eller wobbleren og bruges til at føre agnet aktivt med spinning af hjulet. Fluestangen kaster vægten af selve fluelinen — fluen er næsten vægtløs — og bruges til at præsentere kunstige fluer på vandoverfladen eller lige under. Det kræver helt forskellige kasteteknikker.",
  },
];
---

<MainLayout
  title="Fiskestænger | Guide til valg af fiskestænger til flere fiskeformer"
  description="Vælg den helt rigtige fiskestang til dit fiskeri! Se den store guide til valg af fiskestænger her!"
  canonical="https://udeogfiske.dk/fiskeudstyr/fiskestaenger/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Fiskeudstyr", url: "/fiskeudstyr/" },
    { name: "Fiskestænger" },
  ]}
  articleData={{
    headline: "Køb af fiskestænger",
    image: "/images/fiskestanger.png",
    datePublished: "2019-09-25",
    dateModified: "2026-05-08",
  }}
  faq={faqs}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fiskeudstyr/">Fiskeudstyr</a>
        <span>›</span>
        <span>Fiskestænger</span>
      </nav>
      <h1 class="pg-title">Køb af fiskestænger</h1>
      <p class="pg-sub">Guide til valg af fiskestang — fra alsidige spinnestænger til kraftige havstænger og lette fluestænger.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvilken fiskestang skal jeg vælge?</h2>
        <p class="ac-a">Valg af fiskestang afhænger af din fiskeform. <strong>Spinnestangen</strong> er det alsidige førstevalg til kyst, å og sø. <strong>Havstangen</strong> er kraftig og bygget til pirke i dybt vand. <strong>Fluestangen</strong> er let og kaster vægten af fluelinen, ikke agnet.</p>
      </div>

      <AuthorProfile
        quote="Min første stang var en billig 4-pak fra supermarkedet — og den fangede sin del af aborrer. Men jeg lærte hurtigt at en stang der matcher fiskeformen gør hele forskellen. Jeg har fisket med den samme 9-fods spinnestang i syv år nu, og den dækker alt fra havørred på kysten til gedde i søen. Pointen er ikke at finde den dyreste stang, men den rigtige stang til det fiskeri du faktisk laver."
      />

      <article class="article">
        <p>Fiskestangen er det vigtigste redskab en fisker kan have – uden den er der ingen fisketur. Derfor er valg af fiskestang noget der kræver lidt forståelse for de typer fiskestænger der findes. Man kan hurtigt komme til at købe en stang som slet ikke egner sig til de fisk man gerne vil fange. Kigger man på en typisk hjemmeside som sælger fiskeudstyr, eller hos sin lokale fiskeributik, vil man som nybegynder blive overrasket over det store udvalg af fiskestænger man kan købe. Derfor er det vigtigt, som nybegynder, at have noget hjælp til at vælge den rigtige fiskestang.</p>

        <p>Hos din lokale fiskeributik vil du kunne spørge medarbejderne og få den nødvendige rådgivning, men det kan altid være en god ide at have noget grundlæggende information på plads inden man tager til sin fiskeributik og handler.</p>

        <h2>Hvilke typer fiskestænger findes der?</h2>
        <p>På hjemmesiden vil du kunne finde anbefalinger til alle former for fiskestænger, hvad enten du er på udkig efter en spinnestang, kyststang eller fluestang.</p>

        <DidYouKnow>
          Lokale fiskeributikker tilbyder næsten altid <strong>at lade dig holde stangen i hånden</strong> inden du beslutter dig — vægt, balance og hvor stiv stangen er, kan være svært at vurdere fra et produktbillede. Det er ofte de små detaljer der afgør om en stang føles rigtig efter en hel dag på kysten.
        </DidYouKnow>
      </article>

      <section class="sub-guides">
        <span class="sub-eyebrow">Tre typer fiskestænger</span>
        <h2 class="sub-title">Hvilken stangtype passer til dit fiskeri?</h2>
        <p class="sub-lead">Her er de tre primære fiskestangstyper, jeg anbefaler. Klik på en kategori for de specifikke modelanbefalinger og priskategorier.</p>
        <div class="sub-grid">
          {subTypes.map((s) => (
            <a href={s.href} class="sub-card" aria-label={s.title}>
              <img src={s.image} alt={s.alt} loading="lazy" width="600" height="400" class="sub-img" />
              <div class="sub-body">
                <h3 class="sub-card-title">{s.title}</h3>
                <p class="sub-desc">{s.description}</p>
                <span class="sub-cta">Læs guiden →</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <article class="article article-tail">
        <TipBox>
          Køb din første stang lokalt — selv hvis den koster 100-200 kr mere end online. Personlig rådgivning fra en der selv fisker er guld værd som nybegynder, og du kan returnere stangen hvis den ikke føles rigtig efter et par fisketure.
        </TipBox>

        <p>Det er naturligvis vigtigt at finde en fiskestang som kan opfylde dine behov og samtidig holde sig inden for de forskellige budgetter fiskere har, derfor vælger jeg forskellige fiskestænger i forskellige priskategorier, så alle kan finde en fiskestang i deres prisklasse.</p>
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p>{f.answer}</p>
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>


</MainLayout>

<style>
  .pg-hero {
    position: relative;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 55%, rgba(0, 0, 0, 0.15) 100%),
      url('/images/fiskestanger.png') center/cover no-repeat;
    padding: 5rem 0 4.5rem;
  }

  .pg-ctn { max-width: 1040px; margin: 0 auto; padding: 0 1.5rem; }

  .pg-bc {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem; flex-wrap: wrap;
  }
  .pg-bc a { color: rgba(255,255,255,0.65); transition: color 0.15s; }
  .pg-bc a:hover { color: #ffffff; }

  .pg-title {
    font-size: clamp(2rem, 5vw, 3rem); font-weight: 700; color: #ffffff;
    letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 0.875rem;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }
  .pg-sub {
    font-size: 1.0625rem; font-weight: 300; color: rgba(255,255,255,0.85);
    line-height: 1.65; max-width: 580px; text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }

  .pg-body { padding: 3.5rem 0 5rem; }

  .answer-capsule {
    background: #ffffff; border: 1px solid #e5e7eb; border-left: 4px solid #0d4a5e;
    border-radius: 10px; padding: 1.25rem 1.5rem 1.375rem;
    margin: 0 auto 2.5rem; max-width: 760px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
  }
  .ac-label {
    display: inline-block; font-size: 0.6875rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.12em;
    color: #0d4a5e; margin-bottom: 0.5rem;
  }
  .ac-q { font-size: 1.0625rem; font-weight: 600; color: #111827; letter-spacing: -0.01em; margin-bottom: 0.625rem; }
  .ac-a { font-size: 0.9375rem; color: #4b5563; line-height: 1.7; }
  .ac-a strong { color: #111827; font-weight: 600; }

  .article { max-width: 760px; margin: 0 auto; }
  .article p { font-size: 1rem; color: #374151; line-height: 1.8; margin-bottom: 1.25rem; }
  .article p strong { color: #111827; font-weight: 700; }
  .article a { color: #0d4a5e; font-weight: 600; text-decoration: underline; text-underline-offset: 3px; text-decoration-thickness: 1px; }
  .article a:hover { color: #c47d0a; }
  .article h2 {
    font-size: 1.625rem; font-weight: 700; color: #111827;
    letter-spacing: -0.02em; line-height: 1.25; margin: 2.5rem 0 1rem;
  }
  .article h2:first-child { margin-top: 0; }
  .article-tail { margin-top: 3rem; }

  .sub-guides {
    margin: 3rem auto;
    max-width: 1040px;
    padding: 2.5rem 1.75rem;
    background: linear-gradient(135deg, #f8fafc 0%, #ecfeff 100%);
    border: 1px solid #e2e8f0;
    border-radius: 14px;
  }
  .sub-eyebrow {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #0d4a5e;
    margin-bottom: 0.75rem;
  }
  .sub-title {
    font-size: clamp(1.375rem, 2.6vw, 1.75rem);
    font-weight: 700;
    color: #111827;
    letter-spacing: -0.02em;
    margin: 0 0 0.625rem;
    line-height: 1.2;
  }
  .sub-lead {
    font-size: 0.9375rem;
    color: #4b5563;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 0 1.875rem;
  }
  .sub-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .sub-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .sub-card:hover {
    transform: translateY(-4px);
    border-color: #0d4a5e;
    box-shadow: 0 14px 32px -16px rgba(13, 74, 94, 0.35);
  }
  .sub-img {
    width: 100%;
    height: 160px;
    object-fit: cover;
  }
  .sub-body {
    padding: 1rem 1.125rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sub-card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #111827;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }
  .sub-desc {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.55;
  }
  .sub-cta {
    margin-top: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #0d4a5e;
  }

  .faq-heading {
    font-size: 1.625rem;
    font-weight: 700;
    color: #111827;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin: 4rem auto 1rem;
    max-width: 760px;
  }

  @media (max-width: 760px) {
    .sub-grid { grid-template-columns: 1fr; }
    .sub-guides { padding: 2rem 1.25rem; }
  }
</style>
