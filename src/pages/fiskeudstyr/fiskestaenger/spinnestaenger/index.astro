---
import MainLayout from '../../../../layouts/MainLayout.astro';
import RelatedRow from '../../../../components/RelatedRow.astro';
import AuthorProfile from '../../../../components/AuthorProfile.astro';
import DidYouKnow from '../../../../components/DidYouKnow.astro';
import TipBox from '../../../../components/TipBox.astro';
import StatHighlight from '../../../../components/StatHighlight.astro';
import GuideLink from '../../../../components/GuideLink.astro';
import Affiliate from '../../../../components/Affiliate.astro';
import AffiliateTrio from '../../../../components/AffiliateTrio.astro';
import { getProduct, formatPrice } from '../../../../lib/feed';

// Stangvælger — one recommended rod per fishing type. Cards are pre-rendered
// server-side and toggled client-side so the product swaps with the choice.
const finder = [
  {
    key: 'kyst', label: 'Havørred på kyst', badge: 'Min anbefaling til kysten',
    length: '9–10 fod', weight: '10–40 g', line: '0,18–0,22 mm fletline', reel: 'Str. 3000',
    note: 'Den klassiske kyststang: lang nok til de store kast efter havørred, men stadig let nok til en hel dags fiskeri. Den mest alsidige løsning, hvis du primært fisker kyst.',
    productId: '504497',
  },
  {
    key: 'aa', label: 'Fiskeri i å', badge: 'Min anbefaling til åen',
    length: '8–9 fod', weight: '5–25 g', line: '0,14–0,18 mm fletline', reel: 'Str. 2500',
    note: 'Lidt kortere stang, så du ikke fanger træer og buske langs åen. En blødere klinge gør det nemt at præsentere lette blink og spinnere på kort hold.',
    productId: '503113',
  },
  {
    key: 'pt', label: 'Put & Take', badge: 'Min anbefaling til Put & Take',
    length: '7–9 fod', weight: '2–15 g', line: '0,12–0,16 mm fletline', reel: 'Str. 2500',
    note: 'En følsom finesse-stang til de små blink, spinnere og flåd i Put & Take. Den bløde spids beskytter den tynde line, når en frisk regnbue sætter af.',
    productId: '504233',
  },
  {
    key: 'gedde', label: 'Gedde & sandart', badge: 'Min anbefaling til rovfisk',
    length: '7–9 fod', weight: '20–80 g', line: '0,20–0,30 mm fletline', reel: 'Str. 3000–4000',
    note: 'Kraftig klinge med rygrad til jerkbaits, store gummifisk og fighten med en stor gedde. Husk altid et stålforfang, så gedden ikke bider linen over.',
    productId: '504228',
  },
  {
    key: 'ul', label: 'Aborre & UL', badge: 'Min anbefaling til UL',
    length: '6–7,5 fod', weight: '1–10 g', line: '0,08–0,12 mm fletline', reel: 'Str. 1000–2500',
    note: 'Ultralet og legende — selv en lille aborre giver vild modstand. Perfekt til mikroblink, små jigs og en sjov dag ved søen eller i havnen.',
    productId: '505542',
  },
];

const finderRods = finder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Stangvælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const related = [
  {
    title: "Fiskestænger til havet",
    description: "Pirkestænger og kraftige havstænger til bådfiskeri og dybt vand.",
    href: "/fiskeudstyr/fiskestaenger/fiskestang-til-havet/",
    image: "/images/baad_hero.png",
    alt: "Bådfiskeri på havet",
    chip: "Stangtype",
  },
  {
    title: "Fluefiskestænger",
    description: "Lette fluestænger til havørred, ørred og laks — fra klasse 2 til klasse 9.",
    href: "/fiskeudstyr/fiskestaenger/fluefiskestang/",
    image: "/images/fluefiskeri_card.jpg",
    alt: "Fluestang",
    chip: "Stangtype",
  },
  {
    title: "Spinnefiskeri efter havørred",
    description: "Klassisk kystspin med blink — den mest populære teknik i Danmark.",
    href: "/guide-til-fisk/havorredfiskeri/spinnefiskeri-havorred/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Spinnefiskeri på kysten",
    chip: "Teknik",
  },
];

const faqs = [
  {
    question: "Hvad er en spinnestang?",
    answer: "Spinnestangen er den helt grundlæggende fiskestang som enhver fisker må eje. Den er udviklet til spinnefiskeri med spinnere, woblere og blink — hvor du kaster agnet ud og spinner det ind. Med en god spinnestang kan du fange alle fisk i de danske åer, søer og kyster, og den dækker også Put & Take, fladfiskeforfang og endda fluefiskeri på bombardaflåd.",
  },
  {
    question: "Hvad koster en god begynder spinnestang?",
    answer: "Som begynder anbefaler jeg en spinnestang op til 1.600 kr. I den prisklasse kan du finde rigtig gode stænger der klarer alle dine fiskeopgaver — det er slet ikke nødvendigt at investere mere som nybegynder. Først når du har fundet ud af hvilken fiskeform og fisk du gerne vil fokusere på, kan det give mening at investere flere penge i din næste stang.",
  },
  {
    question: "Hvilken længde spinnestang skal jeg vælge?",
    answer: "Til kystfiskeri efter havørred er <strong>9–10 fod</strong> standarden, fordi længden giver de lange kast. I åen går du ned i <strong>8–9 fod</strong>, så stangen ikke fanger træer og buske, og til aborre og UL-fiskeri er <strong>6–7,5 fod</strong> rart og legende let. Brug Stangvælgeren ovenfor til at se den anbefalede længde for netop dit fiskeri.",
  },
  {
    question: "Hvilken kastevægt skal jeg vælge til ørredfiskeri?",
    answer: "Til ørredfiskeri med blink anbefaler jeg en spinnestang med kastevægt op til 40 g. Det dækker langt de fleste blink og spinnere som bruges på kysten i Danmark og i de fleste åer og søer. Til tungere agn eller bombardafiskeri kan kastevægten gå op til 60-80 g.",
  },
  {
    question: "Bør jeg vælge en to-delt, tre-delt eller teleskop spinnestang?",
    answer: "Jeg anbefaler en to-delt eller tre-delt stang. Teleskopstænger er praktiske til transport, men de er aldrig lige så fleksible som ledsamlede stænger — og fleksibiliteten er afgørende for kasteoplevelsen og kontakten med fisken. To-delte og tre-delte stænger er nemme at have med på cykel eller i bilen, og samtidig får du den fulde kasteegenskab.",
  },
  {
    question: "Hvilken spinnestang passer til gedde og aborre?",
    answer: "Til <strong>gedde og sandart</strong> skal du op i kastevægt — 20–80 g og en kraftig klinge der kan håndtere jerkbaits, store gummifisk og fighten med en stor gedde. Til <strong>aborre og UL</strong> går du den anden vej: en kort, sart stang på 6–7,5 fod med kastevægt helt nede på 1–10 g, så selv en lille aborre giver sjov modstand.",
  },
  {
    question: "Hvilket fiskehjul passer til en spinnestang?",
    answer: "Et spinnehjul der matcher stangens vægt og kastevægt. Til en almindelig 9-fods spinnestang med kastevægt 10-30 g vil et spinnehjul i størrelse 2500-3000 være den naturlige vægtmæssige match. Se gerne <a href=\"/fiskeudstyr/fiskehjul/\">guiden til køb af fiskehjul</a> for de specifikke modelanbefalinger.",
  },
];
---

<MainLayout
  title="Spinnestang | Guide til valg af spinnestænger"
  description="Guide til køb af spinnestænger til spinfiskeri. Find den rigtige længde og kastevægt med vores stangvælger — plus mine bedste begynder- og premium-stænger."
  canonical="https://udeogfiske.dk/fiskeudstyr/fiskestaenger/spinnestaenger/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Fiskeudstyr", url: "/fiskeudstyr/" },
    { name: "Fiskestænger", url: "/fiskeudstyr/fiskestaenger/" },
    { name: "Spinnestænger" },
  ]}
  articleData={{
    headline: "Guide til køb af spinnestang",
    image: "/images/kyst_fiskeri.jpg",
    datePublished: "2020-01-18",
    dateModified: "2026-06-02",
  }}
  faq={faqs}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fiskeudstyr/">Fiskeudstyr</a>
        <span>›</span>
        <a href="/fiskeudstyr/fiskestaenger/">Fiskestænger</a>
        <span>›</span>
        <span>Spinnestænger</span>
      </nav>
      <h1 class="pg-title">Guide til køb af spinnestang</h1>
      <p class="pg-sub">Den alsidige stang til kyst, å og sø — fra prisvenlige begynder-modeller til premium kyststænger over 1500 kr.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvilken spinnestang skal jeg vælge?</h2>
        <p class="ac-a">Spinnestangen er <strong>den mest alsidige stangtype</strong> og dækker næsten alle danske fiskeformer. Som begynder anbefaler jeg en stang op til <strong>1.600 kr</strong> med kastevægt 10-40 g. Vælg en to- eller tre-delt model frem for teleskop — fleksibiliteten er bedre.</p>
      </div>

      <AuthorProfile
        quote="Spinnestangen er stangen jeg griber 80% af tiden. Min 9-fods Abu Sölv har dækket alt fra havørred på Stevns til gedde i Roskilde Fjord — samme stang, helt forskellige fisk. Den fungerer med blink på kysten, med flåd i Put & Take og med flueline på en bombarda. Hvis du kun har råd til én ordentlig stang, så lad det være en spinnestang i 9 fod og 10-30 g kastevægt. Den fanger alt."
      />

      <article class="article">
        <p>Spinnestangen er den helt grundlæggende fiskestang som enhver fisker må eje, da den opfylder de fleste fiskeopgaver du måtte have. Med en god spinnestang kan du fange alle fisk i de danske åer, søer og kyster. Det vigtigste er at have det helt rette agn for at fange den specifikke fisk du er ude efter. Spinnefiskeriet er typisk fiskeri med spinnere, woblere og blink – hvor du kaster agnet ud og spinner det ind. Som navnet indikerer, er spinnestangen udviklet med dette fisker i tankerne, men spinnestangen kan også bruges til mange andre former for fisker. Fiskeri med flåd i Put &amp; Take søer kan også klares med en almindelig spinnestang. Det samme med alle kystfiskeformer – hvad enten det er med fladfiskeforfang eller fra båd. Du kan endda fiske med flue bundet på et bombardaflåd på kysten, efter havørreder. Når jeg er på udkig efter en god spinnestang, kigger jeg efter en der er to-delt eller tre-delt, da det gør transporten meget nemmere. Der findes også teleskop stænger, men dem er jeg ikke tilhænger af da de ikke er så fleksible som to-delte eller tre-delte stænger.</p>

        <DidYouKnow>
          Spinnestangen kan bruges til langt flere fiskeformer end navnet antyder — <strong>Put &amp; Take med flåd, kystfiskeri med fladfiskeforfang, fluefiskeri med bombardaflåd</strong>. Det er den mest alsidige stangtype i Danmark, og hvis du kun ejer én stang, så er det den.
        </DidYouKnow>

        <StatHighlight
          value="9 fod · 10–40 g"
          caption="Den klassiske alt-i-én kystspinnestang til havørred — dækker også å, sø og Put & Take"
          icon="ruler"
        />

        <h2>Hvilken spinnestang passer til dit fiskeri?</h2>
        <p>Den rigtige spinnestang afhænger af, hvad du fisker efter. En lang kyststang til havørred er noget helt andet end en kort, sart UL-stang til aborre. Vælg dit primære fiskeri nedenfor, så får du min anbefaling til længde, kastevægt, line og hjulstørrelse — og et konkret stangforslag der passer til netop den type fiskeri:</p>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Stangvælger</span>
          <h3 class="rf-title">Find stangen til dit fiskeri</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg fiskeri">
          {finderRods.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Længde</span><span class="rf-spec-value" id="rf-length">{finderRods[0].length}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Kastevægt</span><span class="rf-spec-value" id="rf-weight">{finderRods[0].weight}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Line</span><span class="rf-spec-value" id="rf-line">{finderRods[0].line}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Hjul</span><span class="rf-spec-value" id="rf-reel">{finderRods[0].reel}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{finderRods[0].note}</p>

        <div class="rf-products">
          {finderRods.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ finderData: finder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          finderData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            length: document.getElementById('rf-length'),
            weight: document.getElementById('rf-weight'),
            line: document.getElementById('rf-line'),
            reel: document.getElementById('rf-reel'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.length.textContent = d.length;
              els.weight.textContent = d.weight;
              els.line.textContent = d.line;
              els.reel.textContent = d.reel;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <article class="article">
        <h2>Hvilken spinnestang skal nybegyndere vælge?</h2>
        <p>Ved valg af gode begynder stænger anbefaler jeg at man vælger en spinnestang op til 1.600 kr. Grunden til dette er fordi man kan finde gode stænger i den prisklasse som kan klare alle ens fiskeopgaver. Som begynder er det slet ikke nødvendigt at købe ens første fiskestang for mere end 1.600 kr. da man kan finde rigtig gode stænger op til dette beløb. Som begynder skal man jo først se hvilke stænger der passer til ens behov og hvilken fiskeform og fisk man gerne vil fiske efter. Når man har dette på plads kan man vælge at investere flere penge i sin fiskestang. Jeg har stadig nogle af mine stænger som har kostet under 1600 kr. som jeg også benytter regelmæssigt.</p>

        <p>Spinnestænger kan også bruges til at fange mange forskellige fisk, men disse stænger jeg anbefaler er primært mod ørredfiskeri med blink, så kastevægten vil ikke være højere end 40 g.</p>

        <Affiliate
          productId="77064"
          note="Min foretrukne begynderstang. Westin W2 Spin er en alsidig 2-delt stang, der dækker det hele — kyst, Put & Take og sø — uden at koste en formue. Det er præcis den type stang jeg mener man skal starte på: god kvalitet, lav pris, og den fanger fisk fra dag ét."
        />

        <TipBox>
          Vælg en to- eller tre-delt spinnestang frem for en teleskopstang. Teleskopstænger er nemme at transportere, men de er aldrig lige så fleksible som ledsamlede stænger — og fleksibilitet er hele forskellen mellem en god og en dårlig kastebevægelse.
        </TipBox>

        <h3>To-delt, tre-delt eller teleskop?</h3>
        <p>Forskellen mellem stangtyperne handler om, hvordan stangen samles. Her er de tre typer sat op mod hinanden, så du kan se hvorfor jeg anbefaler de ledsamlede stænger:</p>

        <div class="prey-table-wrap" role="region" aria-label="Sammenligning af spinnestangs-typer">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Type</th>
                <th scope="col">Transport</th>
                <th scope="col">Kasteegenskab</th>
                <th scope="col">Min anbefaling</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" data-label="Type">To-delt</th>
                <td data-label="Transport">Fint på cykel og i bil</td>
                <td data-label="Kasteegenskab">Bedst — ubrudt, fleksibel klinge</td>
                <td data-label="Min anbefaling">Mit standardvalg til kyst og å</td>
              </tr>
              <tr>
                <th scope="row" data-label="Type">Tre-/fire-delt</th>
                <td data-label="Transport">Bedst — passer i en rygsæk / kuffert</td>
                <td data-label="Kasteegenskab">Næsten lige så god som to-delt</td>
                <td data-label="Min anbefaling">Perfekt til rejser og fly</td>
              </tr>
              <tr>
                <th scope="row" data-label="Type">Teleskop</th>
                <td data-label="Transport">Mest kompakt</td>
                <td data-label="Kasteegenskab">Dårligst — stiv, ufleksibel aktion</td>
                <td data-label="Min anbefaling">Kun som nødløsning</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2>Hvilke spinnestænger anbefaler jeg over 1500 kr?</h2>
        <p>Når man bevæger sig over de 1500 for en spinnestang, så er der helt andre forventninger til udstyret, synes jeg selv i hvert fald. Kvaliteten skal bare være det bedre, end hvis man køber en stang til 600 kr.</p>

        <p>Herunder har jeg valgt 3 stænger over de 1500 kr. eller deromkring, som jeg mener man burde kigge på hvis man er på udkig efter en ny spinnestang. De er alle produceret af kendte stang producenter, og kvaliteten er helt i top.</p>

        <AffiliateTrio
          title="Mine 3 spinnestænger over 1500 kr"
          intro="Tre premium-stænger jeg selv ville stå med på kysten. En alsidig kyst-arbejdshest, en superfølsom havørred-finesse og en let stang til blink i å og Put & Take — så der er en til hver type fiskeri."
          products={[
            {
              productId: "78509",
              badge: "Til kysten",
              badgeTone: "teal",
              highlight: true,
              note: "Min favorit til havørred. Abu Sölv AG2 er udviklet sammen med europæiske kystfiskere — ultralet med fremragende kasteegenskaber. Og som 4-delt rejsestang kan den være med overalt.",
            },
            {
              productId: "70553",
              badge: "Finesse",
              badgeTone: "slate",
              note: "Sportex Captor RS-2 Seatrout er ekstremt let med en perfekt afbalanceret, semi-parabolsk aktion. Den føling med agnet betyder, at du mærker selv de mest forsigtige hug.",
            },
            {
              productId: "81504",
              badge: "Til å & P&T",
              badgeTone: "orange",
              note: "Westin W6 Spoon er en let finesse-stang til blink og spinnere — perfekt til ørred i Put & Take og å. Medium aktion giver god kontakt til de små agn.",
            },
          ]}
        />

        <p>Stangen lærer du egentligt først at kende når du går i gang med at bruge den, og det er vigtigt at hele ens fiskeoplevelse går op. Derfor skal man også vælge et godt fiskehjul som passer til den stang man har. Det samme gælder linen og agnet, brug helst agn som er inden for den kastevægt som er optimal for den stang du har købt.</p>

        <p>Når du skal have et nyt fiskehjul kan du med fordel se <a href="/fiskeudstyr/fiskehjul/">guiden til køb af fiskehjul</a>, så du er sikker på at du vælger det helt rigtige.</p>

        <GuideLink
          href="/fiskeudstyr/fiskehjul/"
          title="Læs guiden til køb af fiskehjul"
          desc="Find det hjul der balancerer med din nye spinnestang — størrelse, vægt og bremse."
        />
        <GuideLink
          href="/guide-til-fisk/havorredfiskeri/spinnefiskeri-havorred/"
          title="Læs guiden til spinnefiskeri efter havørred"
          desc="Sådan bruger du spinnestangen på kysten — teknik, blink og de bedste pladser."
        />
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p set:html={f.answer} />
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>

</MainLayout>

<style>
  .pg-hero {
    position: relative;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 55%, rgba(0, 0, 0, 0.15) 100%),
      url('/images/kyst_fiskeri.jpg') center/cover no-repeat;
    padding: 5rem 0 4.5rem;
  }

  .pg-ctn { max-width: 1040px; margin: 0 auto; padding: 0 1.5rem; }

  .pg-bc {
    display: flex; align-items: center; gap: 0.5rem;
