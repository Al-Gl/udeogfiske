const faqs = [
  {
    question: "Hvem grundlagde Savage Gear?",
    answer: "Savage Gear blev grundlagt af <strong>Mads Grosell i Danmark</strong>. Virksomheden startede med en mission om at skabe det mest realistiske og virkelighedstro fiskeudstyr på markedet — agn, der ikke bare lignede fisk, men også bevægede sig og lugtede som dem. Det har fra dag ét været mærkets signaturidé.",
  },
  {
    question: "Hvad er Savage Gear mest kendt for?",
    answer: "Savage Gear er især kendt for deres <strong>realistiske 3D- og 4D-agn</strong> — herunder ikoner som <em>4D Line Thru Trout</em> og <em>3D Baitfish Paddle Tail</em>. Agnene er udviklet ved hjælp af avanceret scanningsteknologi, der efterligner rigtige fisks bevægelse, udseende og duft. Udover agn laver Savage Gear også stænger, hjul, beklædning og tilbehør.",
  },
