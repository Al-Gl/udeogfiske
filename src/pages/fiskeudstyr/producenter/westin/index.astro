const faqs = [
  {
    question: "Hvornår blev Westin grundlagt?",
    answer: "Westin blev grundlagt i Sverige i <strong>1952</strong> af Ingvar Westin. Det første produkt var en håndlavet trækopi af en wobler kaldet <strong>Jätte</strong>, designet til geddefiskeri. Wobleren blev hurtigt populær blandt skandinaviske fiskere og lagde grundstenen for Westins succes — den er stadig en del af produktsortimentet i dag.",
