---
import MainLayout from '../../../../layouts/MainLayout.astro';
import RelatedRow from '../../../../components/RelatedRow.astro';
import AuthorProfile from '../../../../components/AuthorProfile.astro';
import DidYouKnow from '../../../../components/DidYouKnow.astro';
import TipBox from '../../../../components/TipBox.astro';
import StatHighlight from '../../../../components/StatHighlight.astro';
import GuideLink from '../../../../components/GuideLink.astro';
import AffiliateTrio from '../../../../components/AffiliateTrio.astro';
import { getProduct, formatPrice } from '../../../../lib/feed';

// Net-vælger — one recommended net per fishing situation. Cards are pre-rendered
// server-side and toggled client-side so the product swaps with the choice.
const finder = [
  {
    key: 'allround', label: 'All-round', badge: 'Mit udgangspunkt',
    type: 'Teleskopnet', handle: 'Justerbart teleskop', mesh: 'Gummimasker', use: 'Mole, sø, å & P&T',
    note: 'Et teleskopnet med gummimasker dækker langt de fleste fiskere. Du justerer armens længde efter situationen, folder det lille til transport — og gummiet skåner fisken og filtrer ikke kroge fast. Det rette første net.',
    productId: '83145',
  },
  {
    key: 'mole', label: 'Mole & højt vand', badge: 'Til langt ned til vandet',
    type: 'Langt teleskopnet', handle: 'Langt, 2-delt alu', mesh: 'Foldbart', use: 'Mole & høje brinker',
    note: 'På molen kan der være over en meter ned til vandet. Her er et langt teleskophåndtag afgørende, så du når ned til fisken uden at strække dig farligt langt ud over kanten.',
    productId: '64608',
  },
  {
    key: 'vade', label: 'Vadefiskeri', badge: 'Til kyst & wading',
    type: 'Kompakt vadenet', handle: 'Kort + magnetlås', mesh: 'Gummi, flydende', use: 'Kyst & fjord i waders',
    note: 'Når du vader i brystdybt vand, skal nettet være lille, hænge på ryggen og være klar med det samme. Magnetlåsen lader dig tage og hænge nettet med våde hænder, og gummiet flyder, så det ikke driver væk under afkrogning.',
    productId: '50300',
  },
  {
    key: 'gedde', label: 'Gedde & store fisk', badge: 'Til de store',
    type: 'Stort, dybt net', handle: 'Kraftigt', mesh: 'Skånsomt, dybt', use: 'Gedde, sandart & laks',
    note: 'Store rovfisk kræver et stort, dybt net med god kurv, så fisken ligger sikkert og ikke hopper ud. Et skånsomt gummi-/knudeløst net beskytter både fiskens slimlag og dine kroge mod at filtre sig fast.',
    productId: '82797',
  },
];

const finderRods = finder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Net-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const related = [
  {
    title: "Spinnestænger",
    description: "Det rette grej til den fisk du vil lande — kyststænger til havørred, lette stænger til ørred i åer og søer.",
    href: "/fiskeudstyr/fiskestaenger/spinnestaenger/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Spinnefiskeri på kysten",
    chip: "Udstyr",
  },
  {
    title: "Waders og støvler",
    description: "Når du wade-fisker, har du brug for et fangstnet du nemt kan have hængende fra ryggen — og waders der gør wading komfortabel.",
    href: "/fiskeudstyr/beklaedning/waders-og-stovler/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Waders ved kyst",
    chip: "Beklædning",
  },
  {
    title: "Fiskeri på mole",
    description: "På molen er afstanden ned til vandet ofte over en meter — her er et net med teleskoparm afgørende.",
    href: "/fiskeguide/fiskeri-paa-mole/",
    image: "/images/mole_fiskeri.jpg",
    alt: "Mole-fiskeri",
    chip: "Lokation",
  },
];

const faqs = [
  {
    question: "Hvorfor er et fangstnet vigtigt?",
    answer: "Nettet sikrer at den fisk du fanger, rent faktisk også bliver hevet med op. Uanset hvilket agn du bruger, mindsker nettet risikoen for at miste fisken når du forsøger at lande den — særligt på moler og fra kyst hvor afstanden ned til vandet kan være stor, eller fra båd hvor fisken sjældent kan tages med hånden.",
  },
  {
    question: "Hvad er et all-round fangstnet?",
    answer: "Et all-round fangstnet er typisk udstyret med et teleskoparm-håndtag, så du kan justere længden af armen efter behov. Det gør det muligt at hive fisk op fra moler hvor der kan være over 1 meter ned til vandet, eller fra søer og åer hvor græs eller grøde står i vejen. Du kan gøre armen helt lille for transport eller når du wade-fisker. Det er det mest fleksible valg som første net.",
  },
  {
    question: "Skal jeg vælge et gummi-net eller et traditionelt knudenet?",
    answer: "Jeg foretrækker <strong>gummimasker</strong> (eller gummibelagt net). De skåner fiskens slimlag bedre, kroge filtrer sig sjældnere fast, og nettet tørrer hurtigt og lugter ikke. Det er især vigtigt, hvis du genudsætter fisk. Et traditionelt <strong>knudenet</strong> er billigere, men hårdere ved fisken og en sand magnet for trekroge — vælg det kun, hvis du altid hjemtager fangsten.",
  },
  {
    question: "Hvor meget skal jeg bruge på et fangstnet?",
    answer: "Til lejlighedsvis fiskeri kan et all-round net til <strong>150 kr i Bilka</strong> være helt nok — særligt hvis dit fiskeri ikke er mere end et par P&amp;T-ture om året. Til mere seriøst fiskeri eller specifikke behov (mole-net med langt håndtag, dybt net til gedde, kompakt vade-net) er det værd at investere i flere net til forskellige formål.",
  },
  {
    question: "Hvilket fangstnet passer til kystfiskeri og wading?",
    answer: "Til wading har du brug for et mindre, kompakt net du kan hænge fra ryggen mens du fisker. Disse net har typisk ikke teleskoparm men i stedet et fast net som kan foldes. Mange wade-net har en magnet så du nemt kan tage nettet og hænge det tilbage, og nogle er flydende — så du kan give slip på dem mens du afkroger fisken uden at de driver væk.",
  },
  {
    question: "Hvor har jeg nettet, når jeg vader?",
    answer: "Du hænger det på ryggen. De fleste vade-net bruger en <strong>magnetlås</strong> eller en quick-release, der sidder på en D-ring bag i nakken eller på vadejakken — så kan du gribe nettet med én hånd og smække det tilbage uden at kigge, mens du står med en fisk på krogen. En <strong>net-magnet</strong> er derfor et af de første tilbehør, jeg anbefaler til wading.",
  },
  {
    question: "Skal jeg have flere fangstnet?",
    answer: "Det afhænger af dit fiskeri og budget. Til de fleste fiskere er ét godt all-round net rigeligt. Hvis du fisker både fra mole, kyst og fra båd, og hvis budgettet er til det, så giver det mening at have specifikke net til forskellige formål. Personligt har jeg to all-round net i forskellige størrelser samt et net til når jeg wade-fisker.",
  },
];
---

<MainLayout
  title="Fangstnet | Guide til valg af fangstnet i forskellige prisklasser"
  description="Find det rette fangstnet til dit fiskeri. Brug net-vælgeren og find det rette net til mole, kyst, sø og gedde — plus magnet, peang og vægt til landingen."
  canonical="https://udeogfiske.dk/fiskeudstyr/tilbehor/fangstnet/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Fiskeudstyr", url: "/fiskeudstyr/" },
    { name: "Tilbehør", url: "/fiskeudstyr/tilbehor/" },
    { name: "Fangstnet" },
  ]}
  articleData={{
    headline: "Fangstnet",
    image: "/images/kyst_fiskeri.jpg",
    datePublished: "2020-02-18",
    dateModified: "2026-06-02",
  }}
  faq={faqs}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/fiskeudstyr/">Fiskeudstyr</a>
        <span>›</span>
        <a href="/fiskeudstyr/tilbehor/">Tilbehør</a>
        <span>›</span>
        <span>Fangstnet</span>
      </nav>
      <h1 class="pg-title">Fangstnet</h1>
      <p class="pg-sub">Det net der lander fisken — fra alsidige all-round net med teleskoparm til kompakte vadenet med magnet eller flydeevne.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvilket fangstnet skal jeg vælge?</h2>
        <p class="ac-a">Til de fleste fiskere er et <strong>all-round net med teleskoparm</strong> det rigtige førstevalg — fleksibelt, transportabelt, dækker mole, kyst, sø og å. Til <strong>wading</strong> har du brug for et mindre, kompakt net du kan hænge fra ryggen, gerne med magnet eller flydeevne.</p>
      </div>

      <AuthorProfile
        quote="Jeg har selv to all-round fangstnet i forskellige størrelser og et separat net til når jeg wade-fisker. Det lyder måske som overdrevet, men når du står i brystdybt vand og en god havørred er på krogen, så vil du ikke kæmpe med et stort net der står i vejen. Og når du fisker fra mole hvor der er halvanden meter ned til vandet, vil du heller ikke fumlene med et lille kompakt vadenet. Forskellige opgaver, forskellige værktøjer."
      />

      <article class="article">
        <p>Et fangstnet er et vigtigt redskab som enhver fisker må eje for at sikre at de fisk man fanger, rent faktisk også bliver hevet med op, og hjemtaget hvis det er hvad man vil. Fangstnet kommer i forskellige størrelser og former og kan opfylde forskellige behov hos forskellige fiskere.</p>

        <p>Nettet er med til at sikre at den fisk du fanger, uanset hvilket agn du bruger, bliver sikret så du ikke mister fisken ved at forsøge at tage den med hånden eller lande den på land. Da der findes forskellige fiskeformer, findes der også forskellige net som skal hjælpe fiskere som udøver de forskellige fiskeformer. Dog kan man altid vælge at købe et godt all-round net som kan bruges til de fleste fiskeformer.</p>

        <DidYouKnow>
          Mange vade-fangstnet er <strong>flydende</strong> — du kan give slip på nettet mens du afkroger fisken uden at det driver væk i vandet. Andre har en <strong>magnet</strong> så du nemt kan tage nettet og hænge det tilbage på ryggen mens du står i brystdybt vand med våde hænder.
        </DidYouKnow>

        <StatHighlight
          value="Gumminet"
          caption="Gummimasker skåner fiskens slimlag, filtrer sjældent kroge fast og tørrer hurtigt — mit foretrukne valg, særligt hvis fisken skal genudsættes"
          icon="ruler"
        />

        <h2>Hvilket fangstnet passer til dit fiskeri?</h2>
        <p>Det rette net afhænger helt af, hvor og hvordan du fisker. Et langt teleskopnet til molen er noget andet end et kompakt vadenet til kysten eller et stort dybt net til gedde. Vælg din situation nedenfor, så får du min anbefaling til type, håndtag og net — og et konkret forslag:</p>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Net-vælger</span>
          <h3 class="rf-title">Find fangstnettet til dit fiskeri</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg fiskeri">
          {finderRods.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Type</span><span class="rf-spec-value" id="rf-type">{finderRods[0].type}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Håndtag</span><span class="rf-spec-value" id="rf-handle">{finderRods[0].handle}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Net</span><span class="rf-spec-value" id="rf-mesh">{finderRods[0].mesh}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bedst til</span><span class="rf-spec-value" id="rf-use">{finderRods[0].use}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{finderRods[0].note}</p>

        <div class="rf-products">
          {finderRods.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ finderData: finder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          finderData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            type: document.getElementById('rf-type'),
            handle: document.getElementById('rf-handle'),
            mesh: document.getElementById('rf-mesh'),
            use: document.getElementById('rf-use'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.type.textContent = d.type;
              els.handle.textContent = d.handle;
              els.mesh.textContent = d.mesh;
              els.use.textContent = d.use;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <article class="article">
        <h2>All-round fangstnet</h2>
        <p>Et godt net som kan bruges til alle fiskeformer er et net med et teleskop håndtag, altså et net hvor man kan justere for længden af armen som holder nettet. Dette gør det muligt at hive fisk op fra moler, hvor der kan være over 1 meter ned til vandet, eller søer og åer hvor der kan være græs eller grøde som står i vejen, og hvor du har behov for en længere arm.</p>

        <p>Du kan også gøre armen helt lille for nemmere transport, eller hvis du ønsker at fastgøre nettet til din ryg når du f.eks. vadefisker. Disse net er de nemmeste at transportere og kan fås relativt billigt.</p>

        <p>All-round fangstnet er typisk nok til de fleste fiskere da det opfylder næsten alle krav til det moderne fiskeri. De kommer i mange forskellige modeller og størrelser, hvilket gør at du kan bruge de typer net til alle fisk du fanger. For at få det bedste ud af dit all-round net, er det vigtigt at du overvejer disse punkter.</p>

        <TipBox>
          Hvis du fisker primært i Put &amp; Take eller fra mole, så start med et all-round net med teleskoparm. Det er det mest fleksible valg som første net og koster ofte under 200 kr i Bilka eller Harald Nyborg — rigeligt til lejlighedsvis fiskeri uden at gå på kompromis med pålideligheden.
        </TipBox>

        <p>Budgettet er med til at bestemme om du skal have flere net, eller et godt all-round net. Nogle gange kan du også nøjes med et all-round net til 150 kr i Bilka hvis dit fiskeri ikke er mere end et par ture til den lokale Put &amp; Take et par gange om året. Fiskeformen er vigtig og hænger sammen med fiskelokationen. Planlægger du at fiske meget fra moler og steder hvor der generelt er langt fra hvor du står til vandet, så er det vigtigt at vælge et net med et meget langt håndtag. Fisker du kun i Put &amp; Take søer eller efter gedder, er det måske vigtigere med et dybt ned, da fiskene kan blive ret store. Fiskere der fisker ved kysten eller fjorden, og wade fisker, har brug for et kort håndtag og et net som er kompakt og nemt at transportere.</p>

        <p>Du kan også have brug for et mere specifikt fangstnet end et all-round net. Er budgettet til det kan du med fordel have forskellige net til forskellige formål. Personligt har jeg to all-round net i forskellige størrelser samt et net til når jeg wade fisker.</p>

        <h2>Gummi-net eller traditionelt knudenet?</h2>
        <p>Et af de vigtigste valg — uanset nettype — er selve maskerne. Her er forskellen på de to, du oftest møder:</p>

        <div class="prey-table-wrap" role="region" aria-label="Gummi-net sammenlignet med traditionelt knudenet">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Nettype</th>
                <th scope="col">Skånsomhed mod fisken</th>
                <th scope="col">Kroge filtrer sig</th>
                <th scope="col">Bedst til</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" data-label="Nettype">Gummi / gummibelagt</th>
                <td data-label="Skånsomhed mod fisken">Skånsom — bevarer slimlaget</td>
                <td data-label="Kroge filtrer sig">Sjældent</td>
                <td data-label="Bedst til">Genudsætning &amp; allround</td>
              </tr>
              <tr>
                <th scope="row" data-label="Nettype">Traditionelt knudenet</th>
                <td data-label="Skånsomhed mod fisken">Hårdere ved slimlaget</td>
                <td data-label="Kroge filtrer sig">Ofte — særligt trekroge</td>
                <td data-label="Bedst til">Billigt, ved hjemtagning</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h2>Fangstnet til kystfiskeri</h2>
        <p>Når man vadefisker, har man andre behov i et fangstnet end hvis man stod på kysten. Da man ofte står i vand helt til brystet er det vigtigt med et mindre net som man nemt kan have hængende fra ryggen og hvor det ikke er vigtigt at det står i vejen mens du fisker.</p>

        <p>Disse net har typisk ikke en teleskop arm samt et net som kan foldes. Dette skyldes at man ofte ikke har tid eller ekstra hænder til at justere på nettet. Her er det vigtigt at nettet er klar til at blive brugt med det samme. Nogle af nettene har en magnet så du nemt kan tage nettet og hænge det tilbage mens du er i vandet, og nogle er også flydende for at du kan give slip på det mens du afkroger fisken.</p>

        <h2>Det grej der hører med nettet</h2>
        <p>Et net kommer sjældent alene. Her er de tre ting jeg altid har sammen med nettet — så fisken bliver landet, afkroget og vejet hurtigt og skånsomt:</p>

        <AffiliateTrio
          title="Land, afkrog og vej fisken"
          intro="Det grej der hører sammen med fangstnettet. En magnet så nettet hænger klar på ryggen, en peang til hurtig afkrogning i nettet, og en lille vægt så du kan veje fisken, inden den sættes tilbage."
          products={[
            {
              productId: "73472",
              badge: "Ophænget",
              badgeTone: "teal",
              highlight: true,
              note: "En net-magnet med 4 kg holdekraft hænger nettet klar på ryggen og lader dig gribe og smække det tilbage med én våd hånd — uundværlig, når du vader med en fisk på krogen.",
            },
            {
              productId: "77757",
              badge: "Afkrogeren",
              badgeTone: "slate",
              note: "En peang/forceps når ind til krogen, mens fisken ligger trygt i nettet — hurtig afkrogning uden at presse eller klemme fisken unødigt.",
            },
            {
              productId: "33204",
              badge: "Vejningen",
              badgeTone: "orange",
              note: "En lille, simpel fjedervægt så du hurtigt kan veje fangsten i nettet, inden den sættes tilbage eller hjemtages. Klassikeren der bare virker — og fylder ingenting i tasken.",
            },
          ]}
        />

        <GuideLink
          href="/fiskeguide/catch-and-release/"
          title="Læs guiden til Catch & Release"
          desc="Et gumminet er det første skridt mod skånsom genudsætning — se hele teknikken."
        />
        <GuideLink
          href="/fiskeguide/fiskeri-paa-mole/"
          title="Læs guiden til molefiskeri"
          desc="På molen er det lange teleskophåndtag afgørende — find pladsen og teknikken."
        />
        <GuideLink
          href="/fiskeudstyr/beklaedning/waders-og-stovler/"
          title="Læs guiden til waders"
          desc="Vade-net hænger på ryggen, mens du står i vandet — find de rette waders til kysten."
        />
      </article>

      <h2 id="faq" class="faq-heading">Ofte stillede spørgsmål</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary><h3>{f.question}</h3></summary>
            <div class="faq-answer">
              <p set:html={f.answer} />
            </div>
          </details>
        ))}
      </div>

      <RelatedRow items={related} />

    </div>
  </section>

</MainLayout>

<style>
  .pg-hero {
    position: relative;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.4) 55%, rgba(0, 0, 0, 0.15) 100%),
      url('/images/kyst_fiskeri.jpg') center/cover no-repeat;
    padding: 5rem 0 4.5rem;
  }

  .pg-ctn { max-width: 1040px; margin: 0 auto; padding: 0 1.5rem; }

  .pg-bc {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8125rem; color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem; flex-wrap: wrap;
  }
