---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DifficultyMeter from '../../../components/DifficultyMeter.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';
import StatHighlight from '../../../components/StatHighlight.astro';
import SeasonCalendar from '../../../components/SeasonCalendar.astro';
import { getProduct, formatPrice } from '../../../lib/feed';

// Aborre-vælger — anbefalet agn pr. metode. Cards are pre-rendered server-side
// and toggled client-side so the product swaps with the choice.
const agnFinder = [
  {
    key: 'jig', label: 'Jig / gummidyr', badge: 'Min favorit',
    bait: 'Lille gummifisk, grønlig', weight: 'Jighoved 5–15 g', technique: 'Jig langs bunden, tag-pause', best: 'Allround — hele sæsonen',
    note: 'Små jigs i grønlige farver er min foretrukne aborre-agn. En lille gummifisk på et 5–15 g jighoved har en realistisk bevægelse — fisk den i tag-pauser langs bunden, hvor aborren står og venter.',
    productId: '79150',
  },
  {
    key: 'spinner', label: 'Spinner & blink', badge: 'Triggrer rovinstinktet',
    bait: 'Spinner / lille blink', weight: 'Str. 1–2', technique: 'Jævn indspinning', best: 'Aktive, jagende fisk',
    note: 'Små spinnere og blink udsender glimt og vibrationer, der trigger aborrens rovinstinkt. Perfekt når fiskene jager aktivt — fisk dem jævnt ind, og dæk meget vand for at finde stimerne.',
    productId: '34536',
  },
  {
    key: 'orm', label: 'Orm', badge: 'Når de er forsigtige',
    bait: 'Orm / blød imitation', weight: 'Flåd el. let blylod', technique: 'Lad det stå eller drive', best: 'Forsigtige fisk & begyndere',
    note: 'Når aborrerne er kræsne, redder ormen turen. Fisk en orm (eller en dufttilsat imitation) under et flåd, hvor der er siv, eller på et let blylod hvor der er lidt dybere. Klassikeren — også den nemmeste for begyndere.',
    productId: '30377',
  },
  {
    key: 'flue', label: 'Flue', badge: 'Sjovest af alle',
    bait: 'Woolly bugger / streamer', weight: 'Klasse 4–6 flue', technique: 'Strip ind i små ryk', best: 'Lavt vand, varme måneder',
    note: 'Aborre på flue er super sjovt og overraskende effektivt. En woolly bugger eller lille streamer strippet ind i små ryk efterligner en flygtende byttefisk — en fremragende måde at komme i gang med fluefiskeri på.',
    productId: '505055',
  },
];

const agnItems = agnFinder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Aborre-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const aborreSeasons: Array<'peak' | 'good' | 'poor'> = [
  'good', 'good', 'good', 'good', 'good', 'good',
  'good', 'good', 'peak', 'peak', 'peak', 'good',
];

const related = [
  {
    title: "UL fiskeri",
    description: "Ultralight grej er ideelt til aborre — fighten bliver sjovere på let udstyr.",
    href: "/fiskeguide/ul-fiskeri/",
    image: "/images/ul_fiskeri_hero.png",
    alt: "UL fiskeri",
    chip: "Teknik",
  },
  {
    title: "Fluefiskeri",
    description: "Fluefiskeri efter aborre er super sjovt og meget effektivt — en god indgang for fluefiskere.",
    href: "/fiskeguide/fluefiskeri/",
    image: "/images/fluefiskeri_card.jpg",
    alt: "Fluefiskeri",
    chip: "Teknik",
  },
  {
    title: "Fiskeri på mole",
    description: "Aborre kan fanges fra molen med jigs, hvor du kan jigge med agnet langs bunden.",
    href: "/fiskeguide/fiskeri-paa-mole/",
    image: "/images/mole_fiskeri.jpg",
    alt: "Mole",
    chip: "Lokation",
  },
];

const faqs = [
  {
    question: "Hvor finder man aborre i Danmark?",
    answer: "Aborren trives i stort set alle vande i Danmark — søer, langsomt flydende floder og åer, kystnære brakvandsområder og kunstige kanaler. Den foretrækker strukturer som søgræs, undersøiske klipper, sunkne træer og skyggefulde områder, hvor den kan gemme sig og jage bytte.",
  },
  {
    question: "Hvilket grej skal jeg bruge til aborrefiskeri?",
    answer: "Aborrefiskeri kræver ikke vildt udstyr. En spinnestang i 7-9 fod, et multihjul, line og noget agn er nok. Et begyndersæt fra Bilka eller Harald Nyborg til 4-500 kr fungerer fint. UL eller lettere grej gør fighten sjovere — aborren kæmper godt på let udstyr.",
  },
  {
    question: "Hvilket agn er bedst til aborre?",
    answer: "De tre bedste agn til aborrefiskeri er jigs/gummidyr (særligt i grønlige farver, 5-15 gram), små spinnere og blink, samt orm. Aborren er sjældent kræsen — har du disse tre i grejæsken, er chancerne for fangst meget store. Når aborrerne er forsigtige, er ormen det rette valg.",
  },
  {
    question: "Hvornår kan man fange aborre?",
    answer: "Aborre kan teknisk set fanges året rundt, men sæsonen for alvor starter når vandet når 7°C — typisk fra april og frem til september-oktober. Morgen og aften er de bedste tidspunkter på dagen, særligt omkring solopgang og solnedgang, hvor aborren er mest bidelysten.",
  },
  {
    question: "Hvad spiser aborren?",
    answer: "Aborren er en alsidig rovfisk. Hovedføden er mindre fisk (agn), insekter (særligt i sommerperioden, hvor den jager myg og vandkalve nær overfladen), krebsdyr som rejer og små krabber, samt orm og bundlevende organismer når jagten på agnfisk slår fejl.",
  },
  {
    question: "Hvilke tips øger fangsten af aborre?",
    answer: "Tag forskelligt agn med — hvis jigs ikke virker, så prøv orm. Brug UL eller lettere grej for sjovere fight. Fisker du fra mole, brug jigs hvor du kan jigge med agnet langs bunden. Er du fluefisker, så kast dig ud i aborre på flue — super sjovt og meget effektivt.",
  },
];

const about = [
  {
    name: "Aborre (Perca fluviatilis)",
    sameAs: "https://da.wikipedia.org/wiki/Aborre",
  },
];
---

<MainLayout
  title="Fiskeri efter Aborre — Tips, Teknikker og Bedste Fiskesteder | Ude og Fiske"
  description="Bliv mester i fiskeri efter aborre med denne dybdegående guide. Påbegynd dit fiskeeventyr med denne fiskeguide til fiskeri efter aborre. Er du nybegynder eller øvet, kan denne guide bruges til at blive endnu bedre!"
  canonical="https://udeogfiske.dk/guide-til-fisk/aborrefiskeri/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Guide til fisk", url: "/guide-til-fisk/" },
    { name: "Aborre" },
  ]}
  articleData={{
    headline: "Guide til Aborre Fiskeri",
    image: "/images/aa_fiskeri.jpg",
    datePublished: "2023-11-11",
    dateModified: "2026-05-06",
  }}
  faq={faqs}
  about={about}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/guide-til-fisk/">Guide til fisk</a>
        <span>›</span>
        <span>Aborre</span>
      </nav>
      <h1 class="pg-title">Guide til Aborre Fiskeri</h1>
      <p class="pg-sub">Den perfekte begynder-fisk — let grej, klassiske agn og aktiv fra april til oktober i alle danske vande.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvor og hvornår fanger man aborre?</h2>
        <p class="ac-a">Aborren findes i <strong>stort set alle vande i Danmark</strong> — søer, åer, kanaler og endda brakvand. Sæsonen starter for alvor når vandet når <strong>7°C</strong> (typisk april) og fortsætter til september-oktober. Morgen og aften er de bedste tidspunkter, særligt omkring solopgang og solnedgang.</p>
      </div>

      <AuthorProfile
        quote="Aborrefiskeri er for mig den perfekte indgang til lystfiskeri — lavt budget, simpelt grej og fisk der bider. Det var min første rigtige sportsfisk som barn med flåd og orm fra brohjørnet, og jeg vender stadig tilbage til det med UL-grej og små jigs i grønlige farver. Aborren er sjældent kræsen, kæmper godt for sin størrelse og findes praktisk talt alle steder hvor der er ferskvand i Danmark. Hvis du aldrig har stået med en fiskestang før, så start her."
      />

      <DifficultyMeter value={15} />

      <SeasonCalendar
        species="Aborre"
        seasons={aborreSeasons}
        title="Bedste fisketider for aborre"
        subtitle="Kan fanges hele året — men efteråret er højsæson, når aborren jager i stimer."
        note="Aborren er aktiv året rundt, også om vinteren. Efteråret (september–november) er bedst, hvor den samler sig i store stimer og jager intenst, inden vandet bliver rigtig koldt."
      />

      <article class="article">
        <p>Aborrefiskeri er en spændende og nem måde at påbegynde sit fiskeeventyr. Fiskeriet er nemt at komme i gang med, og det hjælper en del at aborren kan findes i stort set alle vande i Danmark, selv i brakvand trives den!</p>

        <p>Af udstyr er det ikke meget man skal bruge for at fange aborre, og man kan med fordel bruge noget lettere grej da fighten bliver det hårdere. Herunder vil jeg give en guide til, hvilken slags fisk aborren er, hvilket udstyr man skal bruge for at fange den samt fisketeknikker til at fange aborre.</p>

        <h2>Hvad er en aborre?</h2>
        <p>Aborren er en af de mest almindelige og elskede fisk i ferskvand i Danmark. Denne art, der tilhører percidae-familien, er ikke kun et populært mål for sportsfiskere, men også en vigtig del af økosystemet i vores søer og vandløb.</p>

        <p>Aborren er alsidig og trives i en række forskellige vandmiljøer. Her er nogle af de steder, hvor du typisk kan finde aborren:</p>
        <ul>
          <li><strong>Søer:</strong> Aborren trives i søer af forskellige størrelser. Den elsker strukturer som søgræs, undersøiske klipper og sunkne træer, hvor den kan gemme sig og jage bytte.</li>
          <li><strong>Floder og åer:</strong> Aborren findes ofte i langsomt flydende floder og mindre vandløb, hvor den drager fordel af strukturer som klipper og skyggefulde områder.</li>
          <li><strong>Kystnære områder:</strong> Aborren kan også findes i brakvand og kystnære områder nær havet. Den tilpasser sig forskellige salinitetsniveauer.</li>
          <li><strong>Kanaler:</strong> Kunstige kanaler og vandveje er yderligere levesteder, hvor aborren trives og ofte findes i stimer.</li>
        </ul>

        <DidYouKnow>
          Aborren tilpasser sig <strong>forskellige salinitetsniveauer</strong> og kan derfor fanges i både ferskvand og brakvand — nær kysten ud for åmundinger og fjordskel. Det gør den til en af de mest fleksible danske ferskvandsfisk og forklarer hvorfor du finder den næsten overalt hvor der er vand.
        </DidYouKnow>

        <p>Nogle af aborrens madvaner inkluderer:</p>
        <ul>
          <li><strong>Mindre fisk:</strong> Aborren er kendt for at jage og forbruge mindre fisk som agn. Det er en intelligent jæger og bruger ofte skjul og hurtige svømmebevægelser for at overmande byttefisken.</li>
          <li><strong>Insekter:</strong> I løbet af sommermånederne er insekter en vigtig del af aborrens kost. Den svømmer ofte tæt på vandoverfladen for at snappe insekter som myg og vandkalve.</li>
          <li><strong>Krebsdyr:</strong> Aborren spiser også krebsdyr som rejer og små krabber. Disse udgør en velsmagende snack for den.</li>
          <li><strong>Orm og andet bundlevende liv:</strong> Når aborren ikke kan fange byttefisk i åbent vand, vil den ofte søge efter orme og andre bundlevende organismer.</li>
        </ul>

        <StatHighlight
          icon="ruler"
          value="7°C"
          caption="Vand-temperaturen hvor aborren for alvor begynder at blive aktiv — typisk i april. Sæsonen fortsætter frem til september-oktober."
        />
      </article>

      <figure class="full-bleed">
        <img src="/images/aa_fiskeri.jpg" alt="Å-fiskeri — klassisk udgangspunkt for aborrefiskeri i Danmark" loading="lazy" />
        <figcaption>Aborren findes i stort set alle danske vande — fra åer og søer til kanaler og brakvandsområder. Strukturer som sunkne træer og skyggefulde områder er aborrens favorit-skjulesteder.</figcaption>
      </figure>

      <article class="article">
        <h2>Hvordan fanger man en aborre?</h2>
        <p>Man skal ikke bruge noget vildt udstyr for at fange en aborre. En stang i 7-9 fod længeden er perfekt, et multihjul, noget line og noget agn. Mere skal der faktisk ikke til. Det kan sagtens lade sig gøre at bruge et begyndersæt fra Bilka eller Harald Nyborg til 4-500 kr.</p>

        <p>Vil du have en mere dybdegående guide til valg af stang, har jeg lavet en <a href="/fiskeudstyr/">guide til valg af spinnestænger</a> du kan se.</p>

        <DidYouKnow>
          Et komplet aborre-grej kan koste under <strong>500 kr</strong> i en discount-butik som Bilka eller Harald Nyborg — stang, hjul, line og agn samlet. Det er en af de billigste indgange til lystfiskeri overhovedet, og en af de få fiskerier hvor du faktisk kan fange noget på dag ét med det allerletteste setup.
        </DidYouKnow>

        <h2>Hvilket agn er bedst til aborre?</h2>
        <p>For at fange en aborre, er det vigtigt, men ikke altafgørende, at vælge de rette fiskeagn. Aborren er en fisk som ikke er særlig kræsen (det meste af tiden), derfor er agnvalg ikke så vigtigt som f.eks. når du fisker efter havørred om efteråret eller når du fisker efter sandart.</p>

        <p>Der er nogle grundagn man kan bruge, som næsten er garanteret at fange aborre, hvis aborrerne er til stede!</p>

        <p>De bedste agn til aborrefiskeri er:</p>
        <ul>
          <li><strong>Jigs/gummidyr</strong></li>
          <li><strong>Små spinnere og blink</strong></li>
          <li><strong>Orm</strong></li>
        </ul>

        <p>Har du disse agn i din boks, kan du være sikker på at dine chancer for at fange en aborre, er meget store.</p>

        <div class="prey-table-wrap" role="region" aria-label="De tre grundagn til aborre">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Agn</th>
                <th scope="col">Bedst når</th>
                <th scope="col">Tip</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" data-label="Agn">Jig / gummidyr</th>
                <td data-label="Bedst når">Allround, hele sæsonen</td>
                <td data-label="Tip">Grønlige farver, 5–15 g jighoved</td>
              </tr>
              <tr>
                <th scope="row" data-label="Agn">Spinner / blink</th>
                <td data-label="Bedst når">Når fiskene jager aktivt</td>
                <td data-label="Tip">Glimt &amp; vibration triggrer hugget</td>
              </tr>
              <tr>
                <th scope="row" data-label="Agn">Orm</th>
                <td data-label="Bedst når">Når fiskene er forsigtige</td>
                <td data-label="Tip">Under flåd i siv, ellers let blylod</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3>Jigs</h3>
        <p>Personligt har jeg bedst erfaring med at fikse med små jigs i grønlige farver, og det er også min foretrukne agn når jeg fisker efter aborre. Typisk bruger jeg bly hoveder til jigs i størrelsen 5-15 gram, afhængigt af hvor jeg står og hvad dybden er.</p>

        <p>Disse agn har en realistisk bevægelse i vandet og kan fiskes på forskellige måder, såsom kastning, spinding eller vertikal fiskeri. Du kan finde dem i forskellige farver og størrelser.</p>

        <h3>Blink &amp; Spinnere</h3>
        <p>En anden populær type agn til aborre er små spinners eller blinkere. Disse glimrende agn udsender glimt og vibrationer i vandet, hvilket tiltrækker aborre og trigger deres rovinstinkt. Vælg farver og størrelser, der passer til de lokale forhold og aborrens præferencer.</p>

        <h3>Orm</h3>
        <p>Naturlige agn som orm er også effektive til at fange aborre, især hvis de ikke bider på dine jigs eller blink. Når aborrerne er mere forsigtige er ormen det rette agn til at få dem igang! En orm på en enkelt krog er nok til at komme i gang, valget står på om du skal fiske med blylod eller flåd. Blylod bruger jeg hvis der er lidt dybere hvor jeg fisker, hvor flådet er godt hvis man fisker hvor der er mere siv og hvor man kan lade det flyde med vandet.</p>

        <p>Fiskeri med flåd og orm var min yndlings metode til at fange aborre, da jeg var mindre, og det vil altid være et af mine foretrukne agn, når det gælder aborre fiskeri.</p>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Aborre-vælger</span>
          <h3 class="rf-title">Vælg agn — se den rette tilgang</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg agn til aborre">
          {agnItems.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Agn</span><span class="rf-spec-value" id="rf-bait">{agnItems[0].bait}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Vægt / str.</span><span class="rf-spec-value" id="rf-weight">{agnItems[0].weight}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Teknik</span><span class="rf-spec-value" id="rf-technique">{agnItems[0].technique}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bedst når</span><span class="rf-spec-value" id="rf-best">{agnItems[0].best}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{agnItems[0].note}</p>

        <div class="rf-products">
          {agnItems.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ agnData: agnFinder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          agnData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            bait: document.getElementById('rf-bait'),
            weight: document.getElementById('rf-weight'),
            technique: document.getElementById('rf-technique'),
            best: document.getElementById('rf-best'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.bait.textContent = d.bait;
              els.weight.textContent = d.weight;
              els.technique.textContent = d.technique;
              els.best.textContent = d.best;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <figure class="full-bleed">
        <img src="/images/put_and_take_fiskeri.jpg" alt="Put & Take sø — også et godt sted at fange aborre i de tidlige forårsmåneder" loading="lazy" />
        <figcaption>Aborren tager både små jigs i grønlige farver, små spinnere og blink — og den klassiske orm under et flåd. Skift agn hvis det ene ikke virker.</figcaption>
      </figure>

      <article class="article">
        <h2>Hvornår kan man fange aborre?</h2>
        <p>I princippet kan du fange aborre året rundt, men der er nogle måneder, som er bedre end andre. Når vandet når de 7 grader, så er det som om at fiskene bliver lidt mere aktive, og søger føde mere. Derfor starter aborre fiskeriet for alvor i april og forsætter til september-oktober. Som sagt, er det dog stadig muligt at fange dem hele året.</p>

        <p>Når det kommer til et specifikt tidspunkt på dagen, er min erfaring at morgen of aften fiskeri er bedst. Dog har jeg også haft masser af gode ture midt på dagen.</p>

        <p>Det virker dog som om at aborre, lige som mange andre fisk, er mest bidelystne ved solopgang og solnedgang. Det er typisk de bedste tidspunkter at fiske, når det kommer til en stor del af fisk.</p>

        <TipBox>
          <p>Tag <strong>flere typer agn med</strong> på turen — hvis det ene ikke virker, så skift. Orm plejer altid at give pote når jigs og blink fejler. Det er en af de simpleste måder at redde en stille aborre-tur på.</p>
        </TipBox>

        <StatHighlight
          icon="calendar"
          value="April-okt."
          caption="Aborrens peak-sæson i Danmark — fra vandet hitter 7°C i foråret til det køler ned igen i sensommeren. Dog kan aborre også fanges udenfor disse måneder."
        />

        <h2>Hvilke tips øger fangsten af aborre?</h2>
        <ul>
          <li>Tag forskelligt agn med – hvis det ene ikke virker, kan du med fordel skifte til noget andet. Orm plejer altid at give pote!</li>
          <li>Brug UL eller lettere grej, det gør fighten sjovere.</li>
          <li>Fisker du fra moler, så fisk med jigs hvor du kan jigge med agnet. Det plejer at fungere rigtigt godt.</li>
          <li>Er du fluefisker, kan du kaste dig ud i aborrefiskeri på flue. Det er super sjovt, og meget effektivt!</li>
        </ul>

        <h2>FAQ</h2>

        <div class="faq-list">
          <details class="faq-item">
            <summary><h3>Hvor finder man aborre i Danmark?</h3></summary>
            <div class="faq-answer">
              <p>Aborren trives i stort set alle vande i Danmark — søer, langsomt flydende floder og åer, kystnære brakvandsområder og kunstige kanaler. Den foretrækker strukturer som søgræs, undersøiske klipper, sunkne træer og skyggefulde områder, hvor den kan gemme sig og jage bytte.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvilket grej skal jeg bruge til aborrefiskeri?</h3></summary>
            <div class="faq-answer">
              <p>Aborrefiskeri kræver ikke vildt udstyr. En spinnestang i 7-9 fod, et multihjul, line og noget agn er nok. Et begyndersæt fra Bilka eller Harald Nyborg til 4-500 kr fungerer fint. UL eller lettere grej gør fighten sjovere — aborren kæmper godt på let udstyr.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvilket agn er bedst til aborre?</h3></summary>
            <div class="faq-answer">
              <p>De tre bedste agn til aborrefiskeri er jigs/gummidyr (særligt i grønlige farver, 5-15 gram), små spinnere og blink, samt orm. Aborren er sjældent kræsen — har du disse tre i grejæsken, er chancerne for fangst meget store. Når aborrerne er forsigtige, er ormen det rette valg.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvornår kan man fange aborre?</h3></summary>
            <div class="faq-answer">
              <p>Aborre kan teknisk set fanges året rundt, men sæsonen for alvor starter når vandet når 7°C — typisk fra april og frem til september-oktober. Morgen og aften er de bedste tidspunkter på dagen, særligt omkring solopgang og solnedgang, hvor aborren er mest bidelysten.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvad spiser aborren?</h3></summary>
            <div class="faq-answer">
              <p>Aborren er en alsidig rovfisk. Hovedføden er mindre fisk (agn), insekter (særligt i sommerperioden, hvor den jager myg og vandkalve nær overfladen), krebsdyr som rejer og små krabber, samt orm og bundlevende organismer når jagten på agnfisk slår fejl.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvilke tips øger fangsten af aborre?</h3></summary>
            <div class="faq-answer">
              <p>Tag forskelligt agn med — hvis jigs ikke virker, så prøv orm. Brug UL eller lettere grej for sjovere fight. Fisker du fra mole, brug jigs hvor du kan jigge med agnet langs bunden. Er du fluefisker, så kast dig ud i aborre på flue — super sjovt og meget effektivt.</p>
            </div>
          </details>
        </div>
