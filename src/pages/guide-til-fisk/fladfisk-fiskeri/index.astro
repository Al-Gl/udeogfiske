---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DifficultyMeter from '../../../components/DifficultyMeter.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';
import StatHighlight from '../../../components/StatHighlight.astro';
import SeasonCalendar from '../../../components/SeasonCalendar.astro';
import AffiliateTrio from '../../../components/AffiliateTrio.astro';
import { getProduct, formatPrice } from '../../../lib/feed';

// Fladfisk-vælger — anbefalet tilgang pr. art. Cards are pre-rendered server-side
// and toggled client-side so the product swaps with the choice.
const artFinder = [
  {
    key: 'skrubbe', label: 'Skrubbe', badge: 'Mest talrig',
    bait: 'Sandorm / børsteorm', bottom: 'Sand & mudder', depth: '0,5–3 m', behaviour: 'Graver sig ned; høj/lavvande',
    note: 'Skrubben er den mest almindelige fladfisk og graver sig ned i sandet. Den er mest aktiv ved høj- og lavvande, hvor strømmen synliggør ormene — et forfang med blade og perler tirrer den ekstra.',
    productId: '79260',
  },
  {
    key: 'rodspaette', label: 'Rødspætte', badge: 'Bedste spisefisk',
    bait: 'Frisk sandorm', bottom: 'Sandet / blandet', depth: 'Lavt → 10 m+', behaviour: 'Kræsen & forsigtig',
    note: 'Rødspætten er kræsen omkring ormens tilstand — en træt orm giver ingen bid. Brug friske orm eller en overbevisende imitation som Berkley Gulp. Den bider forsigtigt, men fighter godt, når den først sidder.',
    productId: '503157',
  },
  {
    key: 'pighvar', label: 'Pighvar', badge: 'Aktiv jæger',
    bait: 'Småfisk / gummifisk', bottom: 'Sand & brakvand', depth: 'Varierende', behaviour: 'Jager aktivt i dagslys',
    note: 'Pighvarren jager aktivt og æder gerne småfisk som tobis og kutling — derfor fanger en gummifisk ofte de store bedre end orm. Det er den største fladfisk i danske farvande og en formidabel fighter.',
    productId: '72781',
  },
  {
    key: 'ising', label: 'Ising', badge: 'Den lille',
    bait: 'Sandorm / småkrebs', bottom: 'Sandet / mudret', depth: '2–15 m', behaviour: 'Lille, aktiv jæger',
    note: 'Isingen er den mindste fladfisk (typisk 20–35 cm) og en aktiv jæger. Den tager samme orm som de andre — fisk med et fint forfang og mindre kroge, så du kroger de små munde.',
    productId: '79262',
  },
];

const artFinderItems = artFinder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Fladfisk-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const fladfiskSeasons: Array<'peak' | 'good' | 'poor'> = [
  'poor', 'poor', 'good', 'good', 'good', 'good',
  'good', 'peak', 'peak', 'peak', 'good', 'poor',
];

const related = [
  {
    title: "Fiskeri på mole",
    description: "Moler med sandbund omkring er det klassiske sted at fange fladfisk fra land.",
    href: "/fiskeguide/fiskeri-paa-mole/",
    image: "/images/mole_fiskeri.jpg",
    alt: "Mole der strækker sig ud i havet",
    chip: "Hav",
  },
  {
    title: "Fiskeri på kysten",
    description: "Sandstrande langs den danske kyst er perfekte til fladfiskeri hele sommeren.",
    href: "/fiskeguide/fiskeri-paa-kysten/",
    image: "/images/kyst_fiskeri.jpg",
    alt: "Dansk kystlinje",
    chip: "Hav",
  },
  {
    title: "Fiskeri fra båd",
    description: "Fra båd kan du fange de større fladfisk der står i dybere vand.",
    href: "/fiskeguide/fiskeri-fra-baad/",
    image: "/images/baad_hero.png",
    alt: "Fiskeri fra båd",
    chip: "Hav",
  },
];

const faqs = [
  {
    question: "Hvad er det bedste agn til fladfisk?",
    answer: "Sandorm og børsteorm er det mest effektive agn til fladfisk i Danmark. Du kan også bruge silde-stykker, rejer eller imitations-orm som Berkley Gulp. Levende orm slår alt — særligt rødspætten er kræsen og bider sjældent på en træt orm.",
  },
  {
    question: "Hvilket udstyr skal jeg bruge til fladfiskeri?",
    answer: "En 9-12 fods stang med kastevægt på minimum 50-60 g, en stærk hjul-kombi, fletline (mere holdbar end monofil) og 3-4 fladfiskeforfang. Robust grej er vigtigt — du kan let fange to fisk på samme forfang, og det kræver en stang der kan løfte begge op.",
  },
  {
    question: "Hvor fanger man flest fladfisk i Danmark?",
    answer: "Havne, moler og sandstrande er klassiske fladfiskepladser. Så længe der er sandbund, kan du fange fladfisk. Du behøver ikke fiske over dybt vand — 1 m dybde kan ofte være bedre end 5 m, særligt for skrubber der trives på lavt vand.",
  },
  {
    question: "Hvad er forskellen på skrubbe og rødspætte?",
    answer: "Skrubben har ru hud og bliver sjældent over 40 cm. Rødspætten er glat og kan blive op til 100 cm (sjældent over 50 cm i Danmark) med tydelige røde pletter på oversiden. De to arter kan yngle og giver hybrider, så det kan være svært at skelne — særligt hvis skrubben har antydninger af røde pletter.",
  },
  {
    question: "Hvor stor bliver en pighvar?",
    answer: "Pighvar er den største fladfisk i danske farvande. Hunner kan blive op til 1 meter lange og veje 25 kg, mens hannerne sjældent bliver over 50 cm. Typisk fanger man pighvar omkring 70 cm i havene omkring Danmark.",
  },
  {
    question: "Hvornår er den bedste tid at fiske fladfisk?",
    answer: "Skrubber er mest aktive ved højvande og lavvande, hvor strømmen synliggør orm i sandet. Rødspætter kan fanges hele døgnet, men morgen og aften er bedst. Pighvar jager typisk i dagtimerne. Fladfiskesæsonen er hovedsageligt forår til efterår — om vinteren trækker fladfiskene til dybere vand.",
  },
  {
    question: "Skal jeg have fisketegn for at fiske fladfisk?",
    answer: "Ja, hvis du er mellem 18 og 65 år. Køb online på fisketegn.dk: dagkort 40 kr., ugekort 130 kr., årskort 185 kr. Under 18 og over 65 år fisker gratis. Husk altid at kende fredningsperioder for de arter du fisker efter.",
  },
];

const about = [
  {
    name: "Fladfisk (Pleuronectiformes)",
    sameAs: "https://da.wikipedia.org/wiki/Fladfisk",
  },
];
---

<MainLayout
  title="Fang en fladfisk | Fladfisk Fiskeri Guide | Ude og Fiske"
  description="Fang flere fladfisk med denne guide til fladfisk fiskeri. Lær hvordan man fanger fladfisk og hvilket udstyr du skal bruge."
  canonical="https://udeogfiske.dk/guide-til-fisk/fladfisk-fiskeri/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Guide til fisk", url: "/guide-til-fisk/" },
    { name: "Fladfisk" },
  ]}
  articleData={{
    headline: "Fladfisk Fiskeri",
    image: "/images/fladfisk_card.jpeg",
    datePublished: "2021-01-06",
    dateModified: "2026-05-03",
  }}
  faq={faqs}
  about={about}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/guide-til-fisk/">Guide til fisk</a>
        <span>›</span>
        <span>Fladfisk</span>
      </nav>
      <h1 class="pg-title">Fladfisk Fiskeri</h1>
      <p class="pg-sub">Fang flere fladfisk — udstyr, fladfiskeforfang, agn og de fire fladfiskearter du kan fange ved danske kyster.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Lidt om fladfisken</h2>
        <p class="ac-a">Der findes forskellige slags fladfisk i vandende omkring Danmark, men fælles for dem alle er, at de er saltvandsfisk. Fladfisk kan nemt kendes ved at være meget flade, og deres krop vender så den flade side er parallel med bunden, i modsætning til mange andre fisk.</p>
      </div>

      <AuthorProfile
        quote="Fladfiskeri er et af mine yndlingsfiskerier, fordi det er så tilgængeligt. Du behøver ikke avanceret grej eller specialviden — en mole, lidt sandbund omkring og et fladfiskeforfang med friske orm er ofte alt der skal til. For mig er det den perfekte form for fiskeri når jeg vil ud i ro, lytte til bølgerne og komme hjem med en god middag i tasken."
      />

      <DidYouKnow>
        Skrubber og rødspætter kan faktisk <strong>yngle med hinanden</strong> og giver fertile hybrider. Hvis du fanger en fisk hvor du er i tvivl — ru hud som en skrubbe, men antydninger af røde pletter — så er det sandsynligvis netop sådan en krydsning.
      </DidYouKnow>

      <DifficultyMeter value={30} />

      <SeasonCalendar
        species="Fladfisk"
        seasons={fladfiskSeasons}
        title="Bedste fisketider for fladfisk"
        subtitle="Højsæson i sensommer og efterår, hvor fladfisken æder sig fed nær kysten."
        note="Skrubber og rødspætter fanges bedst fra sensommer til efterår (august–oktober). Omkring gydningen i dele af foråret er fladfisken fredet — tjek de aktuelle regler for dit farvand."
      />

      <article class="article">
        <h2>Hvad er fladfisk og hvilke fire arter kan jeg fange i Danmark?</h2>
        <p>Fladfisk er desuden perfekte til at gemme sig, da de kan ligge stille på bunden, og nærmest forsvinde ind med omgivelserne, hvilket fiskens farve samt form også hjælper med.</p>

        <p>De mest populære fladfisk i Danmark både til spise og fange er, <strong>skrubber, rødspætter, pighvar og isinger</strong>, hvilket også primært er de fisk man fisker efter.</p>

        <p>Alle fladfisk er perfekte spisefisk hvilket også er grunden til at de er så populære fisk at fange. Desuden er fiskeri efter fladfisk en noget nemmere affære, end f.eks. <a href="/guide-til-fisk/havorredfiskeri/">havørredfiskeri</a>.</p>

        <p>Den nemme tilgang til fiskeriet gør at man kan fange fladfisk i stort set hele Danmark, men især havne og moler er populære destinationer for fiskeri efter fladfisk. Så længe der er sandbund, kan du med sikkerhed fange fladfisk.</p>

        <p>Du kan se min tur til Gilleleje hvor jeg fangede skrubber med meget enkelt grej.</p>

        <StatHighlight
          icon="fish"
          value="4 arter"
          caption="Skrubbe, rødspætte, pighvar og ising — de fire fladfiskearter du kan fange i danske farvande."
        />
      </article>

      <figure class="full-bleed">
        <img src="/images/mole_hero.png" alt="Dansk mole der strækker sig ud i havet — klassisk fladfiskeplads" loading="lazy" />
        <figcaption>Moler med sandbund omkring er den klassiske fladfiskeplads i Danmark — særligt ved højvande og lavvande.</figcaption>
      </figure>

      <article class="article">
        <h2>Hvilket udstyr skal jeg bruge til fladfiskeri?</h2>
        <p>Fiskeri efter fladfisk kræver ikke noget avanceret udstyr, udover en robust fiskestang, en god line samt fladfiskeforfang. Ud over det kræver det naturligvis agn, som man selv kan skaffe eller købe.</p>

        <p>Vælger du at fiske efter fladfisk fra båd kan det betale sig at gå et par størrelser op i fiskeudstyr da man typisk fanger større fisk end fra land.</p>

        <h3>Fiskestang</h3>
        <p>Valg af fiskestang kræver lidt omtanke da den skal være i den lidt mere robust ende. Ofte fiskes der fra moler, hvilket kræver at stangen er stærk nok til at kunne hive fisken, eller fiskene op. Man kan naturligvis fange to fladfisk ad gangen hvis man bruger et fladfiskeforfang, hvilket en den største grund til at have en stang som er mere robust.</p>

        <p>Stangen skal desuden have en god længde for at man kan kaste langt. En stang i 9 fod er tilstrækkeligt, men hvis man ønsker, kan man gå helt op til 12 fod.</p>

        <p>Stangens kastevægt skal være som minimum 50-60 g.</p>

        <p>Som nævnt tidligere, kan det ske at man fanger to fladfisk på samme tid, på et fladfiskeforfang, det kan give problemer hvis ens line er for tynd. Selv benytter jeg en fletline, som er mere holdbar end en almindelig monofil line.</p>

        <p>Herunder er der et udvalg af stænger du kan bruge til fiskeri efter fladfisk fra moler.</p>

        <h2>Hvad er et fladfiskeforfang?</h2>
        <p>Fladfiskeforfanget er den helt klassiske metode at fange fladfisk på, og den er super effektiv!</p>

        <p>I bund og grund er fladfiskeforfanget bare et blylod med to kroge. Derfor er det muligt selv at lave et fladfiskeforfang ved at følge disse enkelte krav. Men med tiden har fladfiskeforfanget udviklet sig en del, efter længere tids fiskeri.</p>

        <p>I dag findes der mange forskellige slags fladfiskeforfang, alt fra de klassiske til de mere eksperimenterende, med plastikperler i forskellige farver, samt spinneblade og meget mere.</p>

        <p>Herunder kan du se mine anbefalinger til fladfiskeforfang og dem jeg har bedst erfaring med.</p>

        <p>Jeg vil til enhver tid anbefale at man har mindsk 3-4 fladfiskeforfang med sig når man skal fiske, da man nemt kan miste dem.</p>

        <figure class="art-figure">
          <img src="/images/fladfisk_forfang.png" alt="Fladfiskeforfang med to kroge, perler og spinnerblade på sandstrand" width="1280" height="720" loading="lazy" />
          <figcaption>Det klassiske fladfiskeforfang — to kroge, et blylod og lidt perler/spinnere som lokkemiddel.</figcaption>
        </figure>

        <AffiliateTrio
          title="Mit fladfiskegrej"
          intro="Det grej jeg tager med på en fladfisketur fra mole eller strand: en robust stang der kan løfte to fisk på én gang, et klassisk fladfiskeforfang — og en pumpe, så du selv kan grave friske sandorm på stranden."
          products={[
            {
              productId: "46104",
              badge: "Forfanget",
              badgeTone: "teal",
              highlight: true,
              note: "Det klassiske fladfiskeforfang med to kroge, perler og blylod. Hjertet i fladfiskeriet — hav altid 3–4 med, da du nemt mister dem på den stenede bund.",
            },
            {
              productId: "71693",
              badge: "Stangen",
              badgeTone: "slate",
              note: "En let 11-fods stang med 50–120 g kastevægt — lang nok til de gode kast fra molen og stærk nok til at løfte to fladfisk op på samme forfang.",
            },
            {
              productId: "505506",
              badge: "Agnen selv",
              badgeTone: "orange",
              note: "En to-vejs ormepumpe, så du selv kan suge friske sandorm op af strandens sand. Friske orm slår frosne hver gang — særligt for den kræsne rødspætte.",
            },
          ]}
        />
      </article>

      <article class="article">
        <h2>Hvilket agn fungerer bedst til fladfisk?</h2>
        <p>Man kan fange fladfisk på forskellige agn, og spørger man 3 forskellige fiskere, får man 3 forskellige svar på hvad der er bedst.</p>

        <p>Personligt sværger jeg til <strong>børsteorm og sandorm</strong> når jeg skal fange fladfisk. Det har for mig, vist sig at være den bedste og mest pålidelige agn man kan bruge til at fange fladfisk. Man kan selv grave efter sandorm og børsteorm hvis man vil, og kender de rigtige steder. Typisk graver man efter sandorm og børsteorm ved sandstrande, og her er det anbefalet at man bruger en speciel spade efter, som gør processen nemmere.</p>

        <p>Man kan typisk købe sandorm og børsteorm tæt på de kendte fiskepladser, især hvis man fisker tæt på de større byer. Desuden tilbyder de fleste fiskeudstyr forretninger friske sandorm og børsteorm. Priserne kan variere, så hvis man skal købe en del orm kan det betale sig at ringe rundt til de forskellige og sammenligne priserne.</p>

        <p>Fordelen ved denne agn er desuden at den kan bruges flere gange. Fanger man en fladfisk, man kan oftest forsigtigt tage krogen og agnen ud af fiskens mund og genanvende den.</p>

        <p>Sandorm og børsteorm tiltrækker desuden andre fisk, og man kan således fange torsk, sej og makrel. Er man heldig kan en havørred også bide på en børsteorm.</p>

        <TipBox>
          <p>Sandorm og børsteorm er <strong>bløde</strong> — et hårdt kast river dem af krogen før agnen overhovedet rammer vandet. Brug et blødt, glidende kast frem for et kraftigt ryk. På den måde får du orm der holder hele turen, og du sparer både penge og tid på krogning.</p>
        </TipBox>

        <p>Andre agn som kan bruges, er silde stykker og rejer. Silde stykker kan man selv tilberede, ved at købe sild i supermarkeder eller hos fiskehandlere, og skære dem i mindre stykker. Rejer kan bare sættes på krogen, men man skal være lidt varsom da de nemt kan ryge af krogen.</p>

        <h3>Gulp orme — alternativ når du ikke kan skaffe levende orm</h3>
        <p>Alle ved at levende børsteorm er super effektivt, men hvad gør man hvis man ikke kan skaffe levende børsteorm? Man tager det næstbedste selvfølgeligt. Disse imitations børsteorm fra Berkley er specieltdesignet så de ligner rigtige børsteorm, og så er de tilsat duftstoffer som lokker fist til. Ormene er robuste og kan genbruges flere gange. De skal tilbage i beholderen for at bibeholde deres robusthed og duft.</p>
      </article>

      <figure class="full-bleed">
        <img src="/images/mole_fiskeri.jpg" alt="Lystfisker med stang og fladfiskeforfang på en dansk mole" loading="lazy" />
        <figcaption>Mole-fiskeri efter fladfisk — robust grej, et godt forfang, og tålmodighed når fiskene nipper til agnen.</figcaption>
      </figure>

      <article class="article">
        <h2>Hvilke fire fladfiskearter findes i Danmark?</h2>
        <p>De fire fladfiskearter du møder oftest langs den danske kyst er skrubbe, rødspætte, pighvar og ising. Hver art har sine egne kendetegn, foretrukne habitat og adfærd — kender du forskellen, vælger du både den rigtige plads og det rigtige agn.</p>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Fladfisk-vælger</span>
          <h3 class="rf-title">Vælg art — se den rette tilgang</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg fladfiskeart">
          {artFinderItems.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Bedste agn</span><span class="rf-spec-value" id="rf-bait">{artFinderItems[0].bait}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bund</span><span class="rf-spec-value" id="rf-bottom">{artFinderItems[0].bottom}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Dybde</span><span class="rf-spec-value" id="rf-depth">{artFinderItems[0].depth}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Adfærd</span><span class="rf-spec-value" id="rf-behaviour">{artFinderItems[0].behaviour}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{artFinderItems[0].note}</p>

        <div class="rf-products">
          {artFinderItems.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ artData: artFinder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          artData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            bait: document.getElementById('rf-bait'),
            bottom: document.getElementById('rf-bottom'),
            depth: document.getElementById('rf-depth'),
            behaviour: document.getElementById('rf-behaviour'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.bait.textContent = d.bait;
              els.bottom.textContent = d.bottom;
              els.depth.textContent = d.depth;
              els.behaviour.textContent = d.behaviour;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <article class="article">
        <h3>Skrubbe</h3>
        <p>Skrubber er en af de mest talrige fisk i havene omkring Danmark. Den kendes på den mere ru overflade samt at den størrelsesmæssigt ikke bliver så stor som rødspætten. Man kan blive snydt af at nogle skrubber har røde pletter, men de er ikke så tydelige som rødspætten. Skrubber og rødspætter kan desuden yngle, hvilket resulterer i en blanding af de to fisk.</p>

        <p>Skrubber fortrækker helt sandbund eller mudret bund, hvor den ofte graver sig ned i sandet, og kan blive der i længere perioder.</p>

        <p>Skrubber bliver sjældent større end 40 cm i Danmark og hunnerne plejer at være lidt større end hannerne. Skrubbens primære fødeemner er sandorme eller børsteorme, derfor er den også mest aktiv ved højvande eller lavvande, hvor strømmen kan synliggøre ormene.</p>

        <h3>Rødspætte</h3>
        <p>Rødspætten er nok den mest eftertragtet fladfisk i Danmark grundet dens smag, som mange mener, er de andre fladfisk overlegen. Rødspættens navn kommer fra de røde pletter fisken har på den side der vender væk fra bunden. Den side er desuden brun med lidt grønligt skær. Fisken kan blive op til 100 cm men i Danmark fanges der sjældent rødspætter over de 50 cm.</p>

        <p>Rødspættens foretrukne fødeemner er sandorm og børsteorm, samt tyndskallede muslinger. Derfor er det mest effektive agn også børsterorm eller sandorm. Orme imitationer som Gulp Orme er også effektive, dog ikke så effektive som den ægte varer.</p>

        <p>Min erfaring med rødspætte fiskeri er at de er mere kræsne omkring ormens tilstand, så hvis du ikke har en frisk orm på krogen, bider de ikke ofte. Desuden er de forsigtige i deres bid, men når de har bidt på krogen, er de typisk en bedre fighter end andre fladfisk.</p>

        <p>Rødspætten kan fanges i havene omkring hele Danmark, og endda inde i nogle af fjordene. De mindre rødspætter findes på lavere vand, hvor de større ofte er i vand som er over 10 m dybt. De fortrækker sandet eller blandet bund, så fisk i disse områder hvis du gerne vil fange rødspætter.</p>

        <p>Jeg har fanget rødspætter alle tider på døgnet, dog er morgen og aften nok de tidspunkter hvor chancerne for at fange rødspætter er højest.</p>

        <div class="prey-table-wrap" role="region" aria-label="Skrubbe sammenlignet med rødspætte">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Art</th>
                <th scope="col">Hud &amp; udseende</th>
                <th scope="col">Maks. størrelse</th>
                <th scope="col">Bedste agn</th>
              </tr>
            </thead>
            <tbody>
