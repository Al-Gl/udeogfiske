---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DifficultyMeter from '../../../components/DifficultyMeter.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';
import StatHighlight from '../../../components/StatHighlight.astro';
import SeasonCalendar from '../../../components/SeasonCalendar.astro';
import AffiliateTrio from '../../../components/AffiliateTrio.astro';
import { getProduct, formatPrice } from '../../../lib/feed';

// Gedde-vælger — anbefalet kunstigt agn pr. type. Cards are pre-rendered server-side
// and toggled client-side so the product swaps with the choice.
const agnFinder = [
  {
    key: 'wobler', label: 'Wobler / jerk', badge: 'Imiterer skadet fisk',
    bait: 'Wobler / jerkbait', size: '10–15 cm', technique: 'Variér tempo — stop & start', best: 'Aktive, jagende fisk',
    note: 'En wobler eller jerkbait efterligner en skadet byttefisk og udløser geddens angrebsinstinkt. Hemmeligheden er variation: lav pludselige stop og rusk, og lad den vakle — hugget kommer ofte i pausen.',
    productId: '82808',
  },
  {
    key: 'gummi', label: 'Gummidyr', badge: 'Bedst i koldt vand',
    bait: 'Stor gummifisk', size: '15–20 cm', technique: 'Langsom jig nær bunden', best: 'Koldt vand, sløve fisk',
    note: 'Store gummifisk er særligt effektive i koldt vand, hvor gedden er mindre aktiv og kræver en langsom præsentation. Krogen vender opad, så du undgår bundbid — fisk den langsomt langs bunden, hvor de store gedder ligger på lur.',
    productId: '76958',
  },
  {
    key: 'spinner', label: 'Spinner & blink', badge: 'Dækker meget vand',
    bait: 'Stor spinner / blink', size: 'Str. 4–5', technique: 'Jævn indspinning', best: 'Til at finde fiskene; uklart vand',
    note: 'En stor spinner skaber en flimrende, vibrerende bevægelse, der trækker gedder til fra lang afstand — perfekt til at dække meget vand og finde de aktive fisk. I uklart vand virker iøjnefaldende farver som rød og orange bedst.',
    productId: '68683',
  },
  {
    key: 'flue', label: 'Flue', badge: 'Avanceret & spændende',
    bait: 'Stor geddeflue / streamer', size: '15–25 cm', technique: 'Strip ind i kraftige ryk', best: 'Lavt vand, øvede fluefiskere',
    note: 'Fluefiskeri efter gedde er en avanceret men medrivende disciplin med store streamere på kraftigt fluegrej. Strip den store flue ind i markante ryk, så den ser ud som en flygtende fisk — og hold altid et wire- eller titaniumforfang foran.',
    productId: '52734',
  },
];

const agnItems = agnFinder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Gedde-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const geddeSeasons: Array<'peak' | 'good' | 'poor'> = [
  'peak', 'good', 'good', 'poor', 'good', 'good',
  'poor', 'poor', 'good', 'peak', 'peak', 'peak',
];

const related = [
  {
    title: "Aborrefiskeri",
    description: "Mindre rovfisk i samme søer som gedden — perfekt for letvægts-fiskerier mellem geddesæsoner.",
    href: "/guide-til-fisk/aborrefiskeri/",
    image: "/images/aa_fiskeri.jpg",
    alt: "Aborre",
    chip: "Ferskvand",
  },
  {
    title: "Fluefiskeri",
    description: "Fluefiskeri efter gedde er en avanceret men spændende metode med store streamere.",
    href: "/fiskeguide/fluefiskeri/",
    image: "/images/fluefiskeri_card.jpg",
    alt: "Fluefiskeri",
    chip: "Teknik",
  },
  {
    title: "Fiskeri i å",
    description: "Mange åer i Jylland huser betydelige geddebestande — særligt i langsomt strømmende afsnit.",
    href: "/fiskeguide/fiskeri-i-aa/",
    image: "/images/aa_fiskeri.jpg",
    alt: "Å-fiskeri",
    chip: "Lokation",
  },
];

// FAQ verbatim from the live udeogfiske.dk geddefiskeri page (live source has a real FAQ block)
const faqs = [
  {
    question: "Hvornår er det bedste tidspunkt at fiske efter gedder?",
    answer: "Gedder kan fanges året rundt, men de mest produktive perioder er forår og efterår. I foråret er gedderne aktive efter gydning, og i efteråret spiser de intensivt for at forberede sig til vinteren.",
  },
  {
    question: "Hvad er de bedste steder at fiske efter gedder i Danmark?",
    answer: "Gedder kan findes i mange forskellige vandtyper over hele Danmark. Nogle af de mest populære steder inkluderer Furesø, Esrum Sø, og de mange åer og kanaler i Jylland.",
  },
  {
    question: "Hvad er de vigtigste regler og regulativer for geddefiskeri i Danmark?",
    answer: "Reglerne kan variere afhængigt af regionen, men generelt skal du have et gyldigt fisketegn for at fiske efter gedder i Danmark. Der kan også være særlige regler for brug af levende agn, minimumsstørrelser for gedder, og særlige fredningstider.",
  },
  {
    question: "Hvordan håndterer jeg en gedde sikkert, når jeg har fanget den?",
    answer: "Gedder har skarpe tænder, så det er vigtigt at håndtere dem med forsigtighed. Brug en god fiskehandske og en tang til at fjerne krogen. Hvis du planlægger at genudsætte gedden, skal du sørge for at holde den i vandet så meget som muligt for at minimere stress.",
  },
  {
    question: "Hvad er de mest almindelige fejl, man skal undgå, når man fisker efter gedder?",
    answer: "Nogle almindelige fejl inkluderer at bruge for lille agn, fiske i forkerte områder, og ikke være tålmodig nok. Geddefiskeri kræver ofte tålmodighed og vedholdenhed, da gedder kan være svære at lokke til at bide.",
  },
];

const about = [
  {
    name: "Gedde (Esox lucius)",
    sameAs: "https://da.wikipedia.org/wiki/Gedde",
  },
];
---

<MainLayout
  title="Geddefiskeri | Tips og teknikker til at fange din næste store gedde i Danmark | Ude og Fiske"
  description="Guide til geddefiskeri i Danmark — find de bedste agn, teknikker og fiskepladser. Gedden kan blive op til 1,5 meter og veje 25 kg. Lær at fange Danmarks største ferskvandsrovfisk."
  canonical="https://udeogfiske.dk/guide-til-fisk/geddefiskeri/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Guide til fisk", url: "/guide-til-fisk/" },
    { name: "Gedde" },
  ]}
  articleData={{
    headline: "Guide til geddefiskeri",
    image: "/images/aafiskeri_hero.png",
    datePublished: "2023-07-02",
    dateModified: "2026-05-06",
  }}
  faq={faqs}
  about={about}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/guide-til-fisk/">Guide til fisk</a>
        <span>›</span>
        <span>Gedde</span>
      </nav>
      <h1 class="pg-title">Guide til geddefiskeri</h1>
      <p class="pg-sub">Danmarks største ferskvandsrovfisk — op til 1,5 meter og 25 kg. Wireforfang, kraftig spinnestang og tålmodighed.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvor og hvornår fanger man gedde?</h2>
        <p class="ac-a">Gedden lever i ferskvandssøer, åer og floder i hele Danmark og trives i områder med <strong>stillestående eller langsomt strømmende vand</strong> med rigelig vegetation. De bedste sæsoner er <strong>forår</strong> (efter gydning) og <strong>efterår</strong> (intens føderammen op til vinter). Husk wireforfang — geddens skarpe tænder skærer en almindelig line over.</p>
      </div>

      <AuthorProfile
        quote="Geddefiskeri er for mig den danske ferskvands-svar på tropisk sportsfiskeri — den eksplosive jagt, det tunge ryk i stangen og synet af en stor gedde der dukker op i overfladen er svært at slå. Det kræver lidt mere grej end aborrefiskeri: kraftig spinnestang, pålidelig hjul og altid wireforfang. Vær tålmodig — gedden kan være svær at lokke, men når hugget kommer er der ingen tvivl. Og pas på fingrene når du krogudredder."
      />

      <DifficultyMeter value={50} />

      <SeasonCalendar
        species="Gedde"
        seasons={geddeSeasons}
        title="Bedste fisketider for gedde"
        subtitle="Bedst i det kolde vand — sen efterår, vinter og det tidlige forår."
        note="Gedden hugger bedst i koldt vand (efterår til forår). Varmt sommervand gør fiskeriet sværere, og mange vande har fredning i gydeperioden om foråret — tjek altid de lokale regler."
      />

      <article class="article">
        <p>Gedden er en af de største rovfisk i danske farvande, og den er en populær fangst blandt sportsfiskere. Den kan blive op til en meter lang og veje over 10 kg, og dens lange, slanke krop og skarpe tænder gør den til en imponerende fisk at se på. Gedden lever primært i ferskvandssøer, åer og floder, og den er udbredt i hele Danmark. Den trives bedst i områder med masser af vandplanter og skjulesteder, hvor den kan jage sine byttedyr. Gedden er en rovfisk, og dens føde består primært af mindre fisk som aborrer, skaller og små gedder, da den er en kannibal.</p>

        <DidYouKnow>
          Gedden er en <strong>kannibal</strong> — dens føde inkluderer "små gedder" sammen med aborrer og skaller. Det forklarer hvorfor store agn ofte virker bedre end forventet: gedden er vant til at angribe bytte i samme størrelseskategori som sig selv, og store gummidyr eller woblere imiterer netop det.
        </DidYouKnow>

        <p>Geddefiskeri er en populær sport i Danmark, og der findes mange steder, hvor man kan fange gedder. Gedder kan fanges med både flue, spinner og agn, og det er vigtigt at vælge den rigtige agn, der passer til geddens fødeemner.</p>

        <p>Populære agn til geddefiskeri er fx blink, woblere og gummidyr, der ligner små fisk eller frøer Hvis du vil fange gedder, er det vigtigt at vælge de rigtige områder, hvor gedderne trives.</p>

        <p>Gedden (Esox lucius) er en rovfisk, der er kendt for sin aggressive adfærd og store størrelse. Den kan vokse op til 1,5 meter og veje op til 25 kg. Gedden trives i både ferskvand og brakvand, og kan findes i søer, floder og åer over hele Danmark. Den foretrækker stillestående eller langsomt strømmende vand med rigelig vegetation, hvor den kan ligge på lur efter bytte.</p>

        <p>Gedderne holder ofte til i områder med masser af skjulesteder, fx nær vandplanter, sten og træer, og det kan være en god idé at bruge et stangophæng, der gør det nemmere at kaste agnen ud i de rigtige områder.</p>

        <StatHighlight
          icon="ruler"
          value="Op til 1,5 m"
          caption="Maksimalstørrelse for gedde i danske farvande — op til 25 kg. De typiske fangster ligger dog under en meter, men store gedder over 10 kg er ikke usædvanlige i Furesø og Esrum Sø."
        />
      </article>

      <figure class="full-bleed">
        <img src="/images/aafiskeri_hero.png" alt="Vegetation-rige danske vande — geddens foretrukne jagtområder" loading="lazy" />
        <figcaption>Gedden trives bedst i stillestående eller langsomt strømmende vand med rigelig vegetation, hvor den kan ligge på lur efter bytte. Vandplanter, sten og sunkne træer er klassiske skjulesteder.</figcaption>
      </figure>

      <article class="article">
        <h2>Fiskeri efter gedde med kunstigt agn</h2>
        <p>Kunstigt agn er en populær metode til geddefiskeri, da det er relativt nemt at gå til. Det er en alsidig teknik, der kan tilpasses til forskellige forhold og situationer og kræver ikke for meget forberedelse som at grave efter orm, og fiske efter agnfisk.</p>

        <p>Spinnere, woblere, og softbaits er alle effektive valg for geddefiskeri. Spinnere skaber en flimrende og vibrerende bevægelse i vandet, der kan tiltrække gedder fra lang afstand.</p>

        <p>Woblere efterligner bevægelsen af en skadet fisk, hvilket kan udløse geddens angreb instinkt. Softbaits, som gummiagn, kan være særligt effektive i koldt vand, hvor gedderne er mindre aktive, og en langsom præsentation er nødvendig.</p>

        <p>Fordelene ved softbaits er at krogen oftest vender på top siden, hvilket mindsker chancer for bundbid. Farvevalget kan variere afhængigt af vandets klarhed og lysforholdene. I klart vand og på solrige dage kan naturlige farver, der efterligner geddens typiske bytte, være mest effektive. I uklart vand eller ved lavt lys kan mere iøjnefaldende farver som rød, orange eller gul være mere synlige for gedden.</p>

        <p>Husk at gedden er en rovfisk, så agnet skal præsenteres på en måde, der vækker dens interesse og angreb instinkt. Dette kan indebære at variere indhentning hastigheden, lave pludselige stop og starter, eller lade agnet synke til bunden før genoptagelse af indhentningen.</p>

        <p>Endelig er det vigtigt at bruge det rigtige udstyr til geddefiskeri med kunstigt agn. En kraftig spinnestang, en pålidelig hjul, og en stærk line er afgørende for at kunne håndtere geddens kraftfulde hug og kamp. En wireforfang er også nødvendig for at forhindre, at gedden bider linen over med sine skarpe tænder.</p>

        <DidYouKnow>
          <strong>Wireforfang er ikke valgfrit</strong> ved geddefiskeri — geddens tænder er skarpe nok til at skære en almindelig fluorocarbon- eller monolinj over på sekunder. Et 30-50 cm wireforfang mellem agnen og hovedlinen er den eneste måde at sikre, at den store fisk ikke svømmer væk med dit blink i munden.
        </DidYouKnow>

        <AffiliateTrio
          title="Det gedde-grej du ikke kan undvære"
          intro="Uanset hvilket agn du vælger, er der tre ting du altid skal have med på en geddetur: et wireforfang så tænderne ikke skærer linen, en lang afkrogertang så fingrene holder afstand til tænderne, og et stort net til at lande fisken skånsomt."
          products={[
            {
              productId: "34650",
              badge: "Stålforfanget",
              badgeTone: "teal",
              highlight: true,
              note: "Et wireforfang er ikke til diskussion — det er det eneste, der forhindrer geddens tænder i at skære linen over. Bind det mellem agnen og hovedlinen på hver eneste tur.",
            },
            {
              productId: "82644",
              badge: "Afkrogeren",
              badgeTone: "slate",
              note: "En lang afkrogertang holder dine fingre på sikker afstand af de skarpe tænder, mens du løsner krogen. Uundværlig — og langt sikrere end at fumle med fingrene i gabet.",
            },
            {
              productId: "82797",
              badge: "Nettet",
              badgeTone: "orange",
              note: "Et stort, dybt net med skånsomt garn lander gedden sikkert og holder den rolig, mens du afkroger den. Vigtigt for både fisken og dig, hvis den skal genudsættes.",
            },
          ]}
        />
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Gedde-vælger</span>
          <h3 class="rf-title">Vælg agn — se den rette tilgang</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg kunstigt agn til gedde">
          {agnItems.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Agn</span><span class="rf-spec-value" id="rf-bait">{agnItems[0].bait}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Størrelse</span><span class="rf-spec-value" id="rf-size">{agnItems[0].size}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Teknik</span><span class="rf-spec-value" id="rf-technique">{agnItems[0].technique}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Bedst når</span><span class="rf-spec-value" id="rf-best">{agnItems[0].best}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{agnItems[0].note}</p>

        <div class="rf-products">
          {agnItems.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ agnData: agnFinder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          agnData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            bait: document.getElementById('rf-bait'),
            size: document.getElementById('rf-size'),
            technique: document.getElementById('rf-technique'),
            best: document.getElementById('rf-best'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.bait.textContent = d.bait;
              els.size.textContent = d.size;
              els.technique.textContent = d.technique;
              els.best.textContent = d.best;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <figure class="full-bleed">
        <img src="/images/aa_fiskeri.jpg" alt="Å-fiskeri — Jyllands åer og kanaler huser betydelige geddebestande" loading="lazy" />
        <figcaption>Furesø, Esrum Sø og de mange åer og kanaler i Jylland er nogle af de mest populære geddevande i Danmark — alle med rigelige skjulesteder og varieret bund.</figcaption>
      </figure>

      <article class="article">
        <h2>Tips til geddefiskeri</h2>
        <ul>
          <li>Gedden er en glubsk fisk med mange tænder, pas på den ikke bider din line over!</li>
          <li>Vær tålmodig – der kan være perioder hvor der slet ingen fisk er, men de skal nok komme.</li>
          <li>Vær hurtigt til at give modhug da gedden kan spytte agnet ud hvis den fatter mistanke.</li>
          <li>Aften og morgen plejer at være gode tidspunkter at fange gedde på.</li>
        </ul>

        <TipBox>
          <p>Vær <strong>hurtig til modhug</strong> når gedden bider — den fatter hurtigt mistanke og kan spytte agnet ud igen hvis du tøver. Hold stangen klar og giv et fast ryk så snart du mærker hugget. Det er forskellen på en fanget gedde og en frustrerende afhopper.</p>
        </TipBox>

        <StatHighlight
          icon="calendar"
          value="Forår + efterår"
          caption="Geddens to peak-perioder — efter gydning i foråret hvor de er aktive, og i efteråret hvor de spiser intensivt op til vinteren. Sommer og vinter er sværere men ikke umulige."
        />

        <h2>FAQ</h2>

        <div class="faq-list">
          <details class="faq-item">
            <summary><h3>Hvornår er det bedste tidspunkt at fiske efter gedder?</h3></summary>
            <div class="faq-answer">
              <p>Gedder kan fanges året rundt, men de mest produktive perioder er forår og efterår. I foråret er gedderne aktive efter gydning, og i efteråret spiser de intensivt for at forberede sig til vinteren.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvad er de bedste steder at fiske efter gedder i Danmark?</h3></summary>
            <div class="faq-answer">
              <p>Gedder kan findes i mange forskellige vandtyper over hele Danmark. Nogle af de mest populære steder inkluderer Furesø, Esrum Sø, og de mange åer og kanaler i Jylland.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvad er de vigtigste regler og regulativer for geddefiskeri i Danmark?</h3></summary>
            <div class="faq-answer">
              <p>Reglerne kan variere afhængigt af regionen, men generelt skal du have et gyldigt fisketegn for at fiske efter gedder i Danmark. Der kan også være særlige regler for brug af levende agn, minimumsstørrelser for gedder, og særlige fredningstider.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvordan håndterer jeg en gedde sikkert, når jeg har fanget den?</h3></summary>
            <div class="faq-answer">
              <p>Gedder har skarpe tænder, så det er vigtigt at håndtere dem med forsigtighed. Brug en god fiskehandske og en tang til at fjerne krogen. Hvis du planlægger at genudsætte gedden, skal du sørge for at holde den i vandet så meget som muligt for at minimere stress.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvad er de mest almindelige fejl, man skal undgå, når man fisker efter gedder?</h3></summary>
            <div class="faq-answer">
