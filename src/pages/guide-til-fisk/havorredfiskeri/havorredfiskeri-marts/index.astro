import StatHighlight from '../../../../components/StatHighlight.astro';

const faqs = [
  {
    question: "Er marts en god måned for havørredfiskeri?",
    answer: "Marts er en af de absolut bedste måneder for havørredfiskeri på den danske kyst. Vandtemperaturen begynder at stige, fiskene bliver mere aktive, og overspringerne er stadig velnærede og blanke. Det er forårets første måned, og fiskene er i bide-humør efter vinterens sparsomme føde.",
  },
  {
    question: "Hvor finder jeg havørreder i marts?",
    answer: "Fjorde og kyststrækninger med varieret bund og god strøm. Limfjorden, Mariager Fjord og Isefjorden har stabil temperatur og godt fødegrundlag. Langs kysten virker områder med blæretang, stenrev og varierende dybder, og åmundinger trækker fiskene fordi salt- og ferskvand mødes der med rigeligt foder.",
  },
  {
    question: "Hvilke agn virker bedst i marts?",
    answer: "Slanke blink (Snurrebassen, Møresilda, Sandeel) i naturlige farver er klassiske marts-blink. Gennemløbsblink som Westin D360° rækker længere ud. Til fluefiskeri: rejefluer og småfiskimitationer fisket med intermediate bombardaflåd. Variation er nøglen — nogle dage foretrækker fiskene blink, andre dage fluer.",
  },
  {
    question: "Hvilken indspinning virker i marts?",
    answer: "Variation. Kast langt, lad agnen synke, spind langsomt ind med varierede pauser så agnen efterligner en svag eller skadet fisk. Skift mellem hurtige og langsomme indspinninger på samme plads — fiskene er stadig påvirket af det kolde vand, men begynder at jage mere aggressivt på de varmere dage.",
  },
  {
    question: "Hvilket vejr giver bedst marts-fiskeri?",
    answer: "Solrige forårsdage med svag vind øger vandtemperaturen og fiskens aktivitetsniveau. Let til moderat pålandsvind skaber bevægelse i vandet og lokker fiskene tættere på land. Overskyet vejr giver ofte bedre fiskeri end klar himmel — fiskene er mindre sky og jager højere i vandsøjlen.",
  },
];

const about = [
  {
    name: "Havørred (Salmo trutta trutta)",
    sameAs: "https://da.wikipedia.org/wiki/Hav%C3%B8rred",
  },
];
