const faqs = [
  {
    question: "Hvornår er den bedste tid til natfiskeri efter havørred?",
    answer: "Sommermånederne fra sen forår til tidligt efterår er bedst. Vandet bliver varmt om dagen, så havørrederne søger ud på dybere vand, men når natten kommer og temperaturen falder, trækker de tæt på kysten for at jage småfisk og krebsdyr.",
  },
  {
    question: "Hvad er fordelen ved at fiske om natten?",
    answer: "Om sommeren ligger dagvandet ofte for varmt til at havørreder kommer ind på det lave vand. Natten er den eneste tid hvor de jager kystnært — derfor er natfiskeri den primære metode for sommer-havørreder, og det er ofte i sommernætterne man har chance for at fange de helt store fisk.",
  },
  {
    question: "Hvilket udstyr skal jeg have med til natfiskeri?",
    answer: "Det vigtigste ekstra-udstyr er en pandelampe så du har begge hænder fri til at skifte agn og afkroge fisk. Ud over det bruger du dit normale havørred-grej: spinnestang, fletline med fluorocarbon-forfang, og et udvalg af blink/gennemløbere. Mørke agn højt i vandsøjlen virker bedst.",
  },
  {
    question: "Hvordan finder jeg fisken i mørke?",
    answer: "Hørelsen er din vigtigste sans om natten. Havørrederne plasker ofte i overfladen når de jager, og du kan høre hvilken retning de er i, så du kan kaste agnen ud til dem. Stå stille, lyt et par minutter mellem kast, og lad ørerne gøre arbejdet.",
  },
  {
    question: "Er natfiskeri farligt eller svært for begyndere?",
    answer: "Natfiskeri kræver ekstra forberedelse — pandelampe, kendskab til pladsen i dagslys, og ekstra opmærksomhed på fodfæste i vand. Det er ikke for absolut nybegyndere, men har du fisket dagspladsen flere gange og kender bunden, kan du roligt prøve nat på samme plads. Tag en makker med første gang.",
  },
];

const about = [
  {
    name: "Havørred (Salmo trutta trutta)",
    sameAs: "https://da.wikipedia.org/wiki/Hav%C3%B8rred",
  },
