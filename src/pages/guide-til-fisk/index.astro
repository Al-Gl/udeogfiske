---
import MainLayout from '../../layouts/MainLayout.astro';

const saltwater = [
  {
    title: "Torsk",
    href: "/guide-til-fisk/torskefiskeri/",
    image: "/images/torsk_card.png",
    alt: "Dansk fisker med nyfanget torsk på båd",
  },
  {
    title: "Havørred",
    href: "/guide-til-fisk/havorredfiskeri/",
    image: "/images/havørred_card.jpeg",
    alt: "Havørred med blink i græs",
  },
  {
    title: "Fladfisk",
    href: "/guide-til-fisk/fladfisk-fiskeri/",
    image: "/images/fladfisk_card.jpeg",
    alt: "Fladfisk på sten ved kyst",
  },
  {
    title: "Makrel",
    href: "/guide-til-fisk/makrelfiskeri/",
    image: "/images/makrel_card.png",
    alt: "Nyfanget makrel på bådens dæk",
  },
  {
    title: "Sild",
    href: "/guide-til-fisk/sildefiskeri/",
    image: "/images/sild_card.png",
    alt: "Sild i spand på dansk havn",
  },
  {
    title: "Hornfisk",
    href: "/guide-til-fisk/hornfisk/",
    image: "/images/hornfisk_card.png",
    alt: "Hornfisk på klippe",
  },
];

const freshwater = [
  {
    title: "Regnbueørred",
    href: "/guide-til-fisk/regnbueorredfiskeri/",
    image: "/images/regnbueørred_card.jpg",
    alt: "Regnbueørred med blink",
  },
  {
    title: "Aborre",
    href: "/guide-til-fisk/aborrefiskeri/",
    image: "/images/aa_fiskeri.jpg",
    alt: "Å-fiskeri efter aborre",
  },
  {
    title: "Gedde",
    href: "/guide-til-fisk/geddefiskeri/",
    image: "/images/aafiskeri_hero.png",
    alt: "Vegetation-rige danske vande hvor gedden trives",
  },
];
---

<MainLayout
  title="Guide til fisk – Saltvand og ferskvand | Ude og Fiske"
  description="Artsspecifikke guides til de mest populære fisk i Danmark. Havørred, torsk, fladfisk, makrel, sild, hornfisk, regnbueørred, aborre og gedde."
  canonical="https://udeogfiske.dk/guide-til-fisk/"
  pageType="category"
  breadcrumbs={[{ name: "Forside", url: "/" }, { name: "Guide til fisk" }]}
  itemList={[
    ...saltwater.map(c => ({ name: c.title, url: c.href, image: c.image })),
    ...freshwater.map(c => ({ name: c.title, url: c.href, image: c.image })),
  ]}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <span>Guide til fisk</span>
      </nav>
      <h1 class="pg-title">Guide til fisk</h1>
      <p class="pg-sub">Artsspecifikke guides til de mest populære fisk i danske farvande — saltvand og ferskvand.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Hvilke fisk dækker guiden?</h2>
        <p class="ac-a">Guiden dækker de mest populære fisk i danske farvande. I saltvand finder du guides til <strong>torsk</strong>, <strong>havørred</strong>, <strong>fladfisk</strong>, <strong>makrel</strong>, <strong>sild</strong> og <strong>hornfisk</strong>. I ferskvand har vi guides til <strong>regnbueørred</strong> fra Put &amp; Take søer, samt <strong>aborre</strong> og <strong>gedde</strong> fra søer, åer og kanaler. Hver guide giver konkrete anbefalinger til udstyr, teknik og de bedste sæsoner.</p>
      </div>

      <div class="pg-intro">
        <p>I Danmark er vi så heldige at have et rigt fiskeri både i salt- og ferskvand. Når man gerne vil fiske, kan det være overvældende at vide hvor man skal starte, da der findes så mange forskellige fisk, bare her i lille Danmark.</p>
        <p>Nedenfor finder du artsspecifikke guides til de mest populære fisk. Hver guide giver dig konkrete anbefalinger til det rette udstyr, effektive teknikker, de bedste sæsoner — og hvor du finder fisken.</p>
      </div>

      <h2 class="sec-heading">Saltvandsfisk</h2>
      <div class="card-grid">
        {saltwater.map((c) => (
          <a href={c.href} class="card" aria-label={c.title}>
            <img src={c.image} alt={c.alt} loading="lazy" width="600" height="400" class="card-img" />
            <div class="card-overlay">
              <h3 class="card-title">{c.title}</h3>
              <span class="card-arrow">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M5 9h8M9.5 5.5l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>


      <h2 class="sec-heading sec-heading-sm">Ferskvandsfisk</h2>
      <div class="card-grid">
        {freshwater.map((c) => (
          <a href={c.href} class="card" aria-label={c.title}>
            <img src={c.image} alt={c.alt} loading="lazy" width="600" height="400" class="card-img" />
            <div class="card-overlay">
              <h3 class="card-title">{c.title}</h3>
              <span class="card-arrow">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <path d="M5 9h8M9.5 5.5l4 3.5-4 3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</MainLayout>

<style>
  .pg-hero {
    position: relative;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.25) 55%, rgba(0, 0, 0, 0) 100%),
      url('/images/guide_til_fisk_hero.png') center/cover no-repeat;
    padding: 5rem 0 4.5rem;
  }

  .pg-ctn {
    max-width: 1040px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .pg-bc {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.65);
    margin-bottom: 1.25rem;
  }

  .pg-bc a { color: rgba(255,255,255,0.65); transition: color 0.15s; }
  .pg-bc a:hover { color: #ffffff; }

  .pg-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.875rem;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }

  .pg-sub {
    font-size: 1.0625rem;
    font-weight: 300;
    color: rgba(255,255,255,0.85);
    line-height: 1.65;
    max-width: 520px;
    text-shadow: 0 2px 6px rgba(0, 0, 0, 0.35);
  }

  .pg-body { padding: 3.5rem 0 5rem; }

  .answer-capsule {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-left: 4px solid #0d4a5e;
    border-radius: 10px;
    padding: 1.25rem 1.5rem 1.375rem;
    margin-bottom: 2.5rem;
    max-width: 860px;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.03);
  }

  .ac-label {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0d4a5e;
    margin-bottom: 0.5rem;
  }

  .ac-q {
    font-size: 1.0625rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.01em;
    margin-bottom: 0.625rem;
  }

  .ac-a {
    font-size: 0.9375rem;
    color: #4b5563;
    line-height: 1.7;
  }

  .ac-a strong {
    color: #111827;
    font-weight: 600;
  }

  .pg-intro {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    max-width: 860px;
    padding-bottom: 2.5rem;
    margin-bottom: 2.5rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .pg-intro p {
    font-size: 0.9375rem;
    color: #4b5563;
    line-height: 1.8;
  }

  .sec-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #6b7280;
    margin-bottom: 1.25rem;
  }

  .sec-heading-sm { margin-top: 3.5rem; }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 2;
    border-radius: 14px;
    overflow: hidden;
    background: #0d4a5e;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 32px -14px rgba(13, 74, 94, 0.45);
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .card:hover .card-img { transform: scale(1.06); }

  .card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.25) 45%, rgba(0,0,0,0) 70%);
    pointer-events: none;
  }

  .card-overlay {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.125rem 1.25rem 1.25rem;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.015em;
    line-height: 1.25;
    text-shadow: 0 1px 2px rgba(0,0,0,0.3);
  }

  .card-arrow {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    color: #ffffff;
    backdrop-filter: blur(6px);
    transition: background 0.2s, transform 0.2s;
  }

  .card:hover .card-arrow {
    background: #ffffff;
    color: #0d4a5e;
    transform: translateX(3px);
  }

  @media (max-width: 900px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
