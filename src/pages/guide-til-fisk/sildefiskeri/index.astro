---
import MainLayout from '../../../layouts/MainLayout.astro';
import RelatedRow from '../../../components/RelatedRow.astro';
import AuthorProfile from '../../../components/AuthorProfile.astro';
import DifficultyMeter from '../../../components/DifficultyMeter.astro';
import DidYouKnow from '../../../components/DidYouKnow.astro';
import TipBox from '../../../components/TipBox.astro';
import StatHighlight from '../../../components/StatHighlight.astro';
import SeasonCalendar from '../../../components/SeasonCalendar.astro';
import PriceRunnerProductWidget from '../../../components/PriceRunnerProductWidget.astro';
import { getProduct, formatPrice } from '../../../lib/feed';

// Silde-vælger — anbefalet opsætning pr. situation. Cards are pre-rendered server-side
// and toggled client-side so the product swaps with the choice.
const sildeFinder = [
  {
    key: 'forar', label: 'Forårssild (mole)', badge: 'Klassikeren',
    rig: 'Sildeforfang 3–6 fluer', weight: '+ lod/pirk 20–40 g', where: 'Mole & havn', technique: 'Vip/ryk — vent på flere',
    note: 'Forårssilden står tæt på land fra april til maj, så et almindeligt sildeforfang under et let lod er alt du behøver fra molen. Vip stangen, så fluerne danser — og vent, når du mærker den første, så får du flere på samme træk.',
    productId: '79185',
  },
  {
    key: 'host', label: 'Høstsild (fra båd)', badge: 'Til dybet',
    rig: 'Forfang + tung pirk', weight: '40–80 g', where: 'Båd, dybere vand', technique: 'Lad synke, pirk i dybden',
    note: 'Høstsilden står dybere og varmere og fanges oftest fra båd. Sæt en tungere pirk for enden af forfanget, så det hurtigt når ned — og pirk det op-og-ned i den dybde, hvor stimen står.',
    productId: '55150',
  },
  {
    key: 'torsk', label: 'Torsk som bonus', badge: 'To fisk i ét',
    rig: 'Sild-imiterende pirk', weight: '28–60 g', where: 'Mole & båd', technique: 'Pirk i bunden',
    note: 'Pirken for enden af forfanget er ikke kun kastevægt — en sild-imiterende pirk fisket helt i bunden fanger ofte torsk som bonus, da torsken holder til i samme områder som silden.',
    productId: '503770',
  },
  {
    key: 'uv', label: 'Grumset vand / gråvejr', badge: 'Når sigten er dårlig',
    rig: 'UV-sabiki m. twister', weight: '+ lod 20–40 g', where: 'Uroligt/mørkt vand', technique: 'Vip langsomt',
    note: 'Er vandet grumset eller lyset dårligt, hjælper et UV-aktivt forfang silden med at finde fluerne. De selvlysende twister-haler giver ekstra bevægelse og synlighed, når et almindeligt forfang kommer til kort.',
    productId: '59984',
  },
];

const sildeItems = sildeFinder.map((f) => {
  const product = getProduct(f.productId);
  if (!product) throw new Error(`Silde-vælger: product ${f.productId} not found in feed`);
  return { ...f, product };
});

const sildSeasons: Array<'peak' | 'good' | 'poor'> = [
  'poor', 'good', 'good', 'peak', 'peak', 'good',
  'poor', 'poor', 'good', 'good', 'good', 'poor',
];

const related = [
  {
    title: "Fiskeri på mole",
    description: "Moler og havne er det klassiske udgangspunkt for sildefiskeri i forårsmånederne.",
    href: "/fiskeguide/fiskeri-paa-mole/",
    image: "/images/mole_fiskeri.jpg",
    alt: "Mole der strækker sig ud i havet",
    chip: "Hav",
  },
  {
    title: "Fiskeri fra båd",
    description: "Høstsilden står dybere og varmere — fra båd kan du følge stimerne om efteråret.",
    href: "/fiskeguide/fiskeri-fra-baad/",
    image: "/images/baad_hero.png",
    alt: "Fiskeri fra båd",
    chip: "Hav",
  },
  {
    title: "Torsk",
    description: "Torsk holder ofte til i samme områder som silden — pirken kan fange begge dele.",
    href: "/guide-til-fisk/torskefiskeri/",
    image: "/images/torsk_card.png",
    alt: "Nyfanget torsk",
    chip: "Saltvand",
  },
];

const faqs = [
  {
    question: "Hvor i Danmark kan man fange sild?",
    answer: "Silden kan fanges stort set i hele landet, hvor der er saltvand. Det vigtigste er, at der er lidt dybde, hvor du fisker — derfor er moler og havne særdeles populære til sildefiskeri. Forårssilden står tæt på land, mens høstsilden står dybere og fanges oftest fra båd.",
  },
  {
    question: "Hvornår er den bedste tid til sildefiskeri?",
    answer: "Silden kommer til Danmark i to perioder. Forårssilden ankommer i slutningen af marts og kan fanges til midten af maj — april og start maj er de bedste måneder. Høstsilden ankommer i september og bliver i danske farvande helt frem til jul. Høstsilden er typisk større og federe.",
  },
  {
    question: "Hvilket agn fungerer bedst til sild?",
    answer: "Et sildeforfang overgår alt andet. Det består af 3-6 sildefluer fæstet på en line, som slutter med et blylod eller et tungt blink. Fluerne bevæger sig i vandet når du vipper med stangen, og lokker sildene til. Du kan fange 3-4 sild på samme tid med samme forfang.",
  },
  {
    question: "Hvilket grej skal jeg bruge til sildefiskeri?",
    answer: "Valg af stang og hjul er ikke vigtigt — har du allerede en spinnestang og et fastspolehjul, så kan de bruges. Vælg en line der kan klare minimum 4-5 kg, da man ofte fanger mere end 2-3 sild på én gang. Vægten kommer fra et blylod eller en pirk for enden af forfanget.",
  },
  {
    question: "Hvad er forskellen på forårssild og høstsild?",
    answer: "Forårssilden ankommer i april–maj og fanges nemt fra moler og havne tæt på land — det er silden langt størstedelen af danske lystfiskere fisker efter. Høstsilden ankommer i september og foretrækker dybere og varmere vand, så den fanges oftest fra båd. Høstsilden er større og federe efter en hel sommers fødeoptagelse.",
  },
  {
    question: "Skal jeg have fisketegn for at fiske sild?",
    answer: "Ja, hvis du er mellem 18 og 65 år. Statens lystfisketegn købes online på fisketegn.fiskeristyrelsen.dk: dagkort, ugekort eller årskort. Under 18 og over 65 år fisker gratis. Husk at have det med eller tilgængeligt på telefonen når du er ude at fiske.",
  },
];

const about = [
  {
    name: "Sild (Clupea harengus)",
    sameAs: "https://da.wikipedia.org/wiki/Sild",
  },
];
---

<MainLayout
  title="Sildefiskeri | Guide til at fange flere sild i 2025 | Ude og Fiske"
  description="Fang flere sild med denne guide til sildefiskeri. Læs den store guide til sildefiskeri og bliv bedre til at fange flere sild."
  canonical="https://udeogfiske.dk/guide-til-fisk/sildefiskeri/"
  pageType="article"
  breadcrumbs={[
    { name: "Forside", url: "/" },
    { name: "Guide til fisk", url: "/guide-til-fisk/" },
    { name: "Sild" },
  ]}
  articleData={{
    headline: "Guide til sildefiskeri",
    image: "/images/sild_card.png",
    datePublished: "2021-02-25",
    dateModified: "2026-05-04",
  }}
  faq={faqs}
  about={about}
>

  <section class="pg-hero">
    <div class="pg-ctn">
      <nav class="pg-bc">
        <a href="/">Forside</a>
        <span>›</span>
        <a href="/guide-til-fisk/">Guide til fisk</a>
        <span>›</span>
        <span>Sild</span>
      </nav>
      <h1 class="pg-title">Guide til sildefiskeri</h1>
      <p class="pg-sub">Bonanza-fiskeri når forholdene er rigtige — sildeforfang, pirke og når silden trækker ind.</p>
    </div>
  </section>

  <section class="pg-body">
    <div class="pg-ctn">
      <div class="answer-capsule">
        <span class="ac-label">Kort fortalt</span>
        <h2 class="ac-q">Sildefiskeri</h2>
        <p class="ac-a">Sildefiskeriet kan være et rent Bonanza fiskeri, når man rammer de helt rigtige forhold. Man kan hurtigt fange 30+ fisk inden for kort tid især, hvis du bruger et sildeforfang, hvor man kan fange 3-4 fisk på samme tid. Sildefiskeri har været en del af dansk historie i lang tid, og derfor er fisken også en populær spisefisk i Danmark.</p>
      </div>

      <AuthorProfile
        quote="Sildefiskeri er en af de mest givende discipliner jeg kender, især når foråret begynder og sildestimerne presser sig ind mod mole og havn. Du behøver ikke avanceret grej — en almindelig spinnestang og et sildeforfang med 3-6 fluer er nok. For mig er det selve den ramme der gør det til Bonanza: tre-fire sølvblanke fisk på samme kast, stemningen på molen, og en frisk middag eller røget sild i tasken på vejen hjem."
      />

      <DidYouKnow>
        Sildens kamuflage er smart designet — <strong>sølvblank krop set fra siden, mørkere ryg set fra oven</strong>. Det giver fisken den bedste skjul fra alle vinkler, hvilket forklarer hvorfor stimerne kan vokse til milliarder af individer uden at blive let bytte for rovfisk.
      </DidYouKnow>

      <DifficultyMeter value={30} />

      <SeasonCalendar
        species="Sild"
        seasons={sildSeasons}
        title="Bedste fisketider for sild"
        subtitle="Forårsstimerne i april–maj er højsæson — med et ekstra træk om efteråret."
        note="Sildens forårstræk (april–maj) giver det mest intense fiskeri fra moler og havne, fx i Øresund. Et mindre efterårstræk kan også give fine fangster, når silden trækker forbi igen."
      />

      <article class="article">
        <p>Sildefiskeriet kan være et rent Bonanza fiskeri, når man rammer de helt rigtige forhold. Man kan hurtigt fange 30+ fisk inden for kort tid især, hvis du bruger et sildeforfang, hvor man kan fange 3-4 fisk på samme tid. Sildefiskeri har været en del af dansk historie i lang tid, og derfor er fisken også en populær spisefisk i Danmark.</p>

        <p>I Danmark er vi så heldige, at silden kan fanges stort set i hele landet, hvor der er saltvand, dog skal der helst være lidt dybde, hvor man fisker, hvilket gør moler og havne særdeles populære til dette formål.</p>

        <h2>Hvad er en sild og hvor lever den?</h2>
        <p>Silden er et af de fiske, som der eksistere flest af i verdenen, og den kan fanges i store dele af verdenen. Silden som vi kender den i Danmark, er en del af en sildefamilie, som kan fanges i den nordlige atlant og ind i Østersøen. Området hvor man kan fange sild strækker sig fra det nordøstlige Amerika, nord til Grønland samt Island, og ind mod Europa.</p>

        <p>På udseendet kendes fisken på dens sølvblanke krop og den lidt mørkere ryg, som giver den bedste camouflage fra alle vinkler.</p>

        <p>Størrelsen varierer meget, dog bliver de sjældent over 35 cm, når de fanges i Danmark. Sildene kommer i store stimer, og i Atlanterhavet har man fundet stimer, som har indeholdt mere end 4 mia. fisk.</p>

        <p>Sildens fødeemner er primært krill og vandlopper, men de spiser også fiskeyngel og fiskeæg. Sildens fødeemner spiser alle planteplankton, derfor søger silden også hen hvor byttet er – områder som er rige i planteplankton. I Danmark er de områder omkring Vadehavet, hvilket er et af sildens foretrukne områder.</p>

        <StatHighlight
          icon="fish"
          value="4 mia."
          caption="Den største sildestime fundet i Atlanten — silden er en af de mest talrige fisk i verden."
        />

        <h3>Fiskestang</h3>
        <p>Valg af stang og hjul er slet ikke vigtigt til sildefiskeri, da sildene bevæger sig tæt op land så ofte, som de er længere ude. Så har du allerede en stang, vil den med garanti kunne bruges til sildefiskeri. Det samme gælder hjulet. Her kan et typisk fastspolehjul sagtens bruges til sildefiskeri. Ved valg af line ville jeg nok vælge en lidt tykkere line, som kan klare 4-5 kg (som minimum), da man ofte fanger mere end 2-3 sild på en gang, bare for at være på den sikre side.</p>
      </article>

      <figure class="full-bleed">
        <img src="/images/mole_hero.png" alt="Dansk mole der strækker sig ud i havet — klassisk sildeplads om foråret" loading="lazy" />
        <figcaption>Moler og havne er det klassiske udgangspunkt for sildefiskeri — særligt i april og start maj, når forårssilden trækker ind tæt på land.</figcaption>
      </figure>

      <article class="article">
        <h2>Hvordan fanger man sild?</h2>
        <p>Der er en måde at fange sild på, som overgår dem alle, og det er med sildeforfang. Sildeforfanget består af 3-6 sildefluer fæstet på en line, som slutter med et blylod eller et tungt blink. Dette lod eller blink er den primære vægt, der bruges som kastevægt. Hold øje med din stangs optimale kastevægt og køb et lod i samme størrelse.</p>

        <p>Fluerne på sildeforfanget vil bevæge sig i vandet, når du vipper/rykker med stangen, hvilket er det som lokker sildene til agnet. Som nævnt kommer sildene i store stimer, så hvis du kan mærke, at du har en sild på krogen, så vent med at hive den op. Oftes vil flere sild bide på fluerne, så du hiver 3-6 med op i stedet for den ene.</p>

        <TipBox>
          <p>Mærker du en sild på krogen, så <strong>vent 30-60 sekunder</strong> før du hiver op. Sildene kommer i stimer, og oftest vil flere fisk bide på fluerne på samme forfang. Tålmodigheden belønnes — du henter 3-6 sild op i stedet for den ene.</p>
        </TipBox>
      </article>

      <div class="rod-finder" id="rod-finder">
        <div class="rf-top">
          <span class="rf-eyebrow">Silde-vælger</span>
          <h3 class="rf-title">Vælg din situation — se opsætningen</h3>
        </div>

        <div class="rf-tabs" role="tablist" aria-label="Vælg silde-situation">
          {sildeItems.map((f, i) => (
            <button type="button" class={`rf-tab ${i === 0 ? 'is-active' : ''}`} data-key={f.key} role="tab" aria-selected={i === 0 ? 'true' : 'false'}>{f.label}</button>
          ))}
        </div>

        <div class="rf-specs" id="rf-specs">
          <div class="rf-spec"><span class="rf-spec-label">Opsætning</span><span class="rf-spec-value" id="rf-rig">{sildeItems[0].rig}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Vægt</span><span class="rf-spec-value" id="rf-weight">{sildeItems[0].weight}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Hvor</span><span class="rf-spec-value" id="rf-where">{sildeItems[0].where}</span></div>
          <div class="rf-spec"><span class="rf-spec-label">Teknik</span><span class="rf-spec-value" id="rf-technique">{sildeItems[0].technique}</span></div>
        </div>

        <p class="rf-note" id="rf-note">{sildeItems[0].note}</p>

        <div class="rf-products">
          {sildeItems.map((f, i) => (
            <article class={`rf-product ${i === 0 ? 'is-active' : ''}`} data-key={f.key}>
              <a class="rf-prod-img" href={f.product.url} target="_blank" rel="sponsored noopener" tabindex="-1" aria-hidden="true">
                <img src={f.product.image} alt={f.product.name} loading="lazy" width="120" height="120" />
              </a>
              <div class="rf-prod-body">
                <span class="rf-prod-badge">{f.badge}</span>
                <p class="rf-prod-brand">{f.product.brand}</p>
                <h4 class="rf-prod-name"><a href={f.product.url} target="_blank" rel="sponsored noopener">{f.product.name}</a></h4>
                <div class="rf-prod-buy">
                  <span class="rf-prod-price">{formatPrice(f.product.price)} <span class="rf-prod-cur">kr</span></span>
                  <a class="rf-prod-cta" href={f.product.url} target="_blank" rel="sponsored noopener">
                    <span>Se hos Fiskegrej</span>
                    <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" /></svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <script define:vars={{ sildeData: sildeFinder }}>
        (function () {
          const root = document.getElementById('rod-finder');
          if (!root) return;

          const byKey = {};
          sildeData.forEach((f) => { byKey[f.key] = f; });

          const els = {
            rig: document.getElementById('rf-rig'),
            weight: document.getElementById('rf-weight'),
            where: document.getElementById('rf-where'),
            technique: document.getElementById('rf-technique'),
            note: document.getElementById('rf-note'),
          };
          const specs = document.getElementById('rf-specs');
          const tabs = root.querySelectorAll('.rf-tab');
          const products = root.querySelectorAll('.rf-product');

          tabs.forEach(function (btn) {
            btn.addEventListener('click', function () {
              const key = btn.getAttribute('data-key');
              const d = byKey[key];
              if (!d) return;

              tabs.forEach((b) => { b.classList.remove('is-active'); b.setAttribute('aria-selected', 'false'); });
              btn.classList.add('is-active');
              btn.setAttribute('aria-selected', 'true');

              els.rig.textContent = d.rig;
              els.weight.textContent = d.weight;
              els.where.textContent = d.where;
              els.technique.textContent = d.technique;
              els.note.textContent = d.note;

              products.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-key') === key));

              specs.classList.remove('rf-flash');
              void specs.offsetWidth;
              specs.classList.add('rf-flash');
            });
          });
        })();
      </script>

      <PriceRunnerProductWidget
        productId="3204358997"
        productHref="https://www.pricerunner.dk/pl/647-3204358997/Fiskegrej/Kinetic-Sildeforfang-1-Sammenlign-Priser"
        title="Kinetic Sildeforfang"
        brand="Kinetic"
        eyebrow="Bedste pris lige nu"
        subtitle="Et klassisk sildeforfang — sammenlign live-priser fra danske forhandlere."
        note="Et velprøvet sildeforfang med flere fluer på linen. Sæt et lod eller en pirk for enden, vip stangen, og du kan fange 3-4 sild på samme træk, når stimen er tæt på."
      />

      <article class="article">
        <h2>Hvilken pirk fungerer bedst til sildefiskeri?</h2>
        <p>Når du fisker med sildeforfang har du brug for noget tungt for enden af sildeforfanget for at kaste det ud til hvor fiskene befinder sig. Du kan benytte blylodder, men normalt bruger man pirke til dette formål da pirke udfylder to roller. Først og fremmest er det en vægt til at kaste dit sildeforfang ud, men som sidegevinst kan du fange torsk på pirken da torsken ofte er at finde i samme områder hvor man kan fange sild. Dette er især relevant når man fisker efter sild fra båd.</p>

        <p>Som altid er der altid inspiration at hente på Youtube. Denne video fra Danmarks Sportfiskerforbund har en god guide til sildefiskeri.</p>

        <h2>Hvornår kan man fange sild?</h2>
        <p>Silden kommer til Danmark i to perioder. Den første er i foråret, hvor de første sildestimer ankommer til Danmark allerede i slutningen af marts, men jeg synes det rigtigt sildefiskeri begynder rigtigt i april. Silden er der typisk til midten af maj og i nogle tilfælde helt til juni, dog bliver det sværere og sværere at fange dem så sent. Silden som ankommer i foråret, kan nemt fanges fra moler og havne, hvilket netop også er årsagen til, at langt størstedelen af den danske befolkning fisker efter silden i foråret.</p>

        <p>Den anden periode på året hvor silden ankommer til Danmark, er fra september og helt frem til jul. Denne sild kaldes høstsilden, og den er typisk noget større og federe end silden, som ankommer i foråret. Det er fordi, at den har haft hele sommeren til at spise sig fed. Denne sild som kommer i efteråret foretrækker lidt dybere og varmere vand. Derfor er det også lidt sværere at fange denne fisk fra moler og havne, og langt størstedelen af sildene bliver taget fra båd.</p>

        <div class="prey-table-wrap" role="region" aria-label="Forårssild sammenlignet med høstsild">
          <table class="prey-table">
            <thead>
              <tr>
                <th scope="col">Sildetype</th>
                <th scope="col">Hvornår</th>
                <th scope="col">Hvor &amp; hvordan</th>
                <th scope="col">Størrelse</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row" data-label="Sildetype">Forårssild</th>
                <td data-label="Hvornår">April–maj</td>
                <td data-label="Hvor &amp; hvordan">Mole &amp; havn, tæt på land</td>
                <td data-label="Størrelse">Mindre &amp; slankere</td>
              </tr>
              <tr>
                <th scope="row" data-label="Sildetype">Høstsild</th>
                <td data-label="Hvornår">September–jul</td>
                <td data-label="Hvor &amp; hvordan">Dybere vand, oftest fra båd</td>
                <td data-label="Størrelse">Større &amp; federe</td>
              </tr>
            </tbody>
          </table>
        </div>

        <DidYouKnow>
          <strong>Høstsilden er typisk større og federe end forårssilden</strong> — forklaringen er enkel. Silden har haft hele sommeren til at spise sig fed, før den vender tilbage til danske farvande sent på året. Derfor jagter mange erfarne lystfiskere netop høstsilden fra båd, hvor kvaliteten er tydeligt bedre.
        </DidYouKnow>

        <StatHighlight
          icon="calendar"
          value="2 sæsoner"
          caption="Forårssilden trækker ind i april–maj, høstsilden i september–december — to klart adskilte sildeperioder hvert år."
        />
      </article>

      <figure class="full-bleed">
        <img src="/images/baad_hero.png" alt="Fiskeri fra båd — den foretrukne metode til høstsilden om efteråret" loading="lazy" />
        <figcaption>Høstsilden står dybere og varmere — fra båd kan du følge stimerne om efteråret, og pirken under sildeforfanget kan fange torsk som bonus.</figcaption>
      </figure>

      <article class="article">
        <h2>Hvilke tips øger fangsten af sild?</h2>
        <ul>
          <li>Gå efter at fange sild om foråret, april og start maj er de bedste måneder</li>
          <li>Brug et sildeforfang – der er fangstgaranti!</li>
          <li>Mærker du en fisk, så vent 30-60 sekunder, du fanger flere fisk på en gang</li>
          <li>Silden kan fanges stort set i hele Danmark</li>
          <li>Hold øje med sociale medier – er der meldinger om fangst i dit område, så er det med at komme afsted!</li>
        </ul>

        <p>Husk at man skal have statens lystfisketegn for at kunne fange sild hvis man er mellem 18-65. Det kan du få her: <a href="https://fisketegn.fiskeristyrelsen.dk/fisketegn/common/frontPageShow.jsp" target="_blank" rel="noopener">https://fisketegn.fiskeristyrelsen.dk/fisketegn/common/frontPageShow.jsp</a></p>

        <h2>FAQ</h2>

        <div class="faq-list">
          <details class="faq-item">
            <summary><h3>Hvor i Danmark kan man fange sild?</h3></summary>
            <div class="faq-answer">
              <p>Silden kan fanges stort set i hele landet, hvor der er saltvand. Det vigtigste er, at der er lidt dybde, hvor du fisker — derfor er moler og havne særdeles populære til sildefiskeri. Forårssilden står tæt på land, mens høstsilden står dybere og fanges oftest fra båd.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvornår er den bedste tid til sildefiskeri?</h3></summary>
            <div class="faq-answer">
              <p>Silden kommer til Danmark i to perioder. Forårssilden ankommer i slutningen af marts og kan fanges til midten af maj — april og start maj er de bedste måneder. Høstsilden ankommer i september og bliver i danske farvande helt frem til jul. Høstsilden er typisk større og federe.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvilket agn fungerer bedst til sild?</h3></summary>
            <div class="faq-answer">
              <p>Et sildeforfang overgår alt andet. Det består af 3-6 sildefluer fæstet på en line, som slutter med et blylod eller et tungt blink. Fluerne bevæger sig i vandet når du vipper med stangen, og lokker sildene til. Du kan fange 3-4 sild på samme tid med samme forfang.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvilket grej skal jeg bruge til sildefiskeri?</h3></summary>
            <div class="faq-answer">
              <p>Valg af stang og hjul er ikke vigtigt — har du allerede en spinnestang og et fastspolehjul, så kan de bruges. Vælg en line der kan klare minimum 4-5 kg, da man ofte fanger mere end 2-3 sild på én gang. Vægten kommer fra et blylod eller en pirk for enden af forfanget.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Hvad er forskellen på forårssild og høstsild?</h3></summary>
            <div class="faq-answer">
              <p>Forårssilden ankommer i april–maj og fanges nemt fra moler og havne tæt på land — det er silden langt størstedelen af danske lystfiskere fisker efter. Høstsilden ankommer i september og foretrækker dybere og varmere vand, så den fanges oftest fra båd. Høstsilden er større og federe efter en hel sommers fødeoptagelse.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary><h3>Skal jeg have fisketegn for at fiske sild?</h3></summary>
            <div class="faq-answer">
              <p>Ja, hvis du er mellem 18 og 65 år. Statens lystfisketegn købes online på fisketegn.fiskeristyrelsen.dk: dagkort, ugekort eller årskort. Under 18 og over 65 år fisker gratis. Husk at have det med eller tilgængeligt på telefonen når du er ude at fiske.</p>
            </div>
          </details>
        </div>
