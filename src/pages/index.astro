---
import MainLayout from '../layouts/MainLayout.astro';
import PriceRunner from '../components/PriceRunner.astro';

// 6-card showcase matching the live udeogfiske.dk homepage: 3 species + 3 techniques.
// Descriptions are 1:1 verbatim from the live front page per the content workflow memory.
const categories = [
  {
    title: "Havørred",
    chip: "Fiskeart",
    description: "Den ultimative guide til havørredfiskeri, indeholder udstyr, strategier samt hvor du kan finde havørrederne. Bliv klogere på havørredfiskeri her.",
    href: "/guide-til-fisk/havorredfiskeri/",
    image: "/images/havørred_card.jpeg",
  },
  {
    title: "Fladfisk",
    chip: "Fiskeart",
    description: "Fladfisk findes i alle vande omkring Danmark, og er derfor en populær fangst for lystfiskere. Bliv klogere på fiskeri efter fladfisk her.",
    href: "/guide-til-fisk/fladfisk-fiskeri/",
    image: "/images/fladfisk_card.jpeg",
  },
  {
    title: "Hornfisk",
    chip: "Fiskeart",
    description: "Hornfisk er en af de mest populære fisk man kan fange i Danmark, selv om det kun er en begrænset periode man kan fange dem i. Læs med her, og bliv klogere på hornfisk.",
    href: "/guide-til-fisk/hornfisk/",
    image: "/images/hornfisk_card.png",
  },
  {
    title: "Fluefiskeri",
    chip: "Teknik",
    description: "Nysgerrig på fluefiskeri? Læs mere her, og se hvad fluefiskeri egentligt er. Du kan læse alt fra grej til teknikker og hvilke fisk man kan fange med fluestangen.",
    href: "/fiskeguide/fluefiskeri/",
    image: "/images/fluefiskeri_card.jpg",
  },
  {
    title: "Molefiskeri",
    chip: "Teknik",
    description: "Fiskeri fra mole gør det muligt at fange mange slags fisk, og med det antal moler der er i Danmark, er det en atraktiv fiskelokation. Læs mere om molefiskeri her.",
    href: "/fiskeguide/fiskeri-paa-mole/",
    image: "/images/mole_hero.png",
  },
  {
    title: "Put & Take Fiskeri",
    chip: "Teknik",
    description: "Fiskeri i Put & Takes er populært grundet de mange tilgængelige søer, samt hvor nemt det kan være at fange fisk. Læs med her, og vær sikker på at fange noget næste gang du besøger en Put & Take.",
    href: "/fiskeguide/put-take-fiskeri/",
    image: "/images/put_take_fiskeri_card.png",
  },
];

const monthIndex = new Date().getMonth();
const monthNames = ["Januar","Februar","Marts","April","Maj","Juni","Juli","August","September","Oktober","November","December"];
const currentMonth = monthNames[monthIndex];

// Species name → guide URL. Used both for the chip-links below and for the sæsonguide page.
const speciesHref: Record<string, string> = {
  "Havørred": "/guide-til-fisk/havorredfiskeri/",
  "Makrel": "/guide-til-fisk/makrelfiskeri/",
  "Torsk": "/guide-til-fisk/torskefiskeri/",
  "Hornfisk": "/guide-til-fisk/hornfisk/",
  "Fladfisk": "/guide-til-fisk/fladfisk-fiskeri/",
  "Sild": "/guide-til-fisk/sildefiskeri/",
  "Regnbueørred": "/guide-til-fisk/regnbueorredfiskeri/",
  "Aborre": "/guide-til-fisk/aborrefiskeri/",
  "Gedde": "/guide-til-fisk/geddefiskeri/",
};

const monthData = [
  { season: "Vinter",  color: "#1e40af", bg: "#eff6ff", fish: ["Torsk","Regnbueørred","Aborre"],          tip: "Januar er en stille måned på vandet — men torsk og regnbueørred belønner den tålmodige fisker." },
  { season: "Vinter",  color: "#1e40af", bg: "#eff6ff", fish: ["Torsk","Regnbueørred","Gedde"],            tip: "Februar byder på koldt vand og aktive torsk fra kysten. Gedde er på toppen i ferskvand." },
  { season: "Forår",   color: "#2d6a4f", bg: "#f0faf4", fish: ["Havørred","Gedde","Regnbueørred"],         tip: "Marts markerer opvågningen — havørreden søger ind mod kysten og gedden er aggressiv i ferskvand." },
  { season: "Forår",   color: "#2d6a4f", bg: "#f0faf4", fish: ["Havørred","Hornfisk","Sild"],              tip: "April er forårets højdepunkt. Havørreden er aktiv langs hele kysten, hornfisken er på vej ind og sildestimerne starter." },
  { season: "Forår",   color: "#2d6a4f", bg: "#f0faf4", fish: ["Hornfisk","Havørred","Sild"],              tip: "Maj bringer hornfisken i store mængder og sildestimerne topper i de sydlige farvande." },
  { season: "Sommer",  color: "#b45309", bg: "#fffbeb", fish: ["Makrel","Hornfisk","Fladfisk"],             tip: "Juni er makrelfiskerens måned. Hornfisken er fortsat aktiv og fladfisken er udbredt på sandede bunde." },
  { season: "Sommer",  color: "#b45309", bg: "#fffbeb", fish: ["Makrel","Fladfisk","Havørred"],             tip: "Juli giver de varmeste vande — makrel og fladfisk er i topform, og havørreden søger dybere." },
  { season: "Sommer",  color: "#b45309", bg: "#fffbeb", fish: ["Makrel","Fladfisk","Aborre"],               tip: "August er sensommerens fiskemåned med masser af makrel og aktiv aborre i ferskvand." },
  { season: "Efterår", color: "#92400e", bg: "#fff7ed", fish: ["Havørred","Torsk","Sild"],                  tip: "September er efterårets første måned — havørreden er på vej op, torsken søger ind mod land og efterårets sildestimer ankommer." },
  { season: "Efterår", color: "#92400e", bg: "#fff7ed", fish: ["Havørred","Torsk","Sild"],                  tip: "Oktober er en af årets bedste måneder. Havørred og torsk er i topform, og efterårssilden er i de danske farvande." },
  { season: "Efterår", color: "#92400e", bg: "#fff7ed", fish: ["Havørred","Torsk","Regnbueørred"],          tip: "November byder på de klassiske efterårsfangster — havørred og torsk dominerer langs kysterne." },
  { season: "Vinter",  color: "#1e40af", bg: "#eff6ff", fish: ["Torsk","Regnbueørred","Havørred"],          tip: "December er torskens måned. Regnbueørreden er aktiv i put & take-søerne og havørreden er fortsat aktiv." },
];

const now = monthData[monthIndex];
---

<MainLayout
  title="Ude og Fiske – Inspiration til din fisketur"
  description="Din guide til fiskeri i Danmark. Find fiskeguides, udstyrsanbefalinger, fiskepladser og ekspert tips til din næste fisketur."
  canonical="https://udeogfiske.dk/"
>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-inner">
      <h1 class="hero-h1">
        Fiskeri for begyndere<br />
        <em>og alle andre</em>
      </h1>
      <p class="hero-sub">
        Komplette guides til kystfiskeri, fluefiskeri og put &amp; take — skrevet af en fisker, ikke en marketingafdeling. Konkrete pladser, ærligt grej og teknik der virker i danske farvande.
      </p>
      <div class="hero-actions">
        <a href="/fiskeguide/" class="btn-primary">Udforsk guider</a>
        <a href="/fiskepladser/" class="btn-ghost">Find fiskepladser</a>
      </div>
    </div>
    <div class="hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C240,90 480,0 720,30 C960,60 1200,80 1440,40 L1440,90 L0,90 Z" fill="#ffffff"/>
      </svg>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WELCOME — short intro just below hero
  ═══════════════════════════════════════════ -->
  <section class="sec sec-welcome">
    <div class="ctn">
      <div class="welcome">
        <span class="welcome-mark" aria-hidden="true"></span>
        <p class="welcome-lead">
          Fiskeri har siden tidernes morgen været en aktivitet mennesket har gjort brug af — først for at skaffe mad på bordet, i dag som en af Danmarks mest udbredte fritidsaktiviteter.
        </p>
        <p class="welcome-body">
          På Ude og Fiske finder du guides til alt fra havørred på kysten til regnbueørred i put &amp; take-søen — med konkrete pladser, ærlige grej-anbefalinger og teknik der virker i danske farvande. Hele siden er gratis, og du behøver ikke oprette en bruger for at læse.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CATEGORIES — BENTO GRID
  ═══════════════════════════════════════════ -->
  <section class="sec sec-cats">
    <div class="ctn">
      <div class="sec-hd">
        <span class="eyebrow">Mine guides</span>
        <h2 class="sec-title">Sådan kommer du i gang</h2>
        <p class="sec-sub">Vælg en fiskeart eller en fiskeform — komplette guides til Danmarks mest populære fisk og de mest brugte teknikker.</p>
      </div>

      <div class="bento">
        {categories.map((cat) => (
          <a
            href={cat.href}
            class="bcard"
            style={`--img: url('${cat.image}');`}
          >
            <div class="bcard-bg"></div>
            <div class="bcard-content">
              <span class="bcard-chip">{cat.chip}</span>
              <div class="bcard-bottom">
                <h3 class="bcard-title">{cat.title}</h3>
                <p class="bcard-desc">{cat.description}</p>
                <span class="bcard-arrow">
                  Læs guide
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PRICERUNNER — fiskegrej comparison widget
  ═══════════════════════════════════════════ -->
  <PriceRunner />


  <!-- ═══════════════════════════════════════════
       SÆSONGUIDE
  ═══════════════════════════════════════════ -->
  <section class="sec sec-season">
    <div class="ctn">
      <div class="sblock" style={`--sc: ${now.color}; --sb: ${now.bg};`}>
        <div class="sblock-left">
          <div class="sblock-badge">
            <span class="sblock-dot"></span>
            Nu i {currentMonth}
          </div>
          <p class="sblock-season">{now.season}</p>
          <h2 class="sblock-title">Hvad bider lige nu?</h2>
          <p class="sblock-tip">{now.tip}</p>
          <div class="month-strip" aria-label="Året rundt">
            {monthNames.map((name, i) => (
              <div class={`month-cell ${i === monthIndex ? 'is-now' : ''}`} title={name}>
                <span class="month-bar"></span>
                <span class="month-letter">{name.charAt(0)}</span>
              </div>
            ))}
          </div>
          <a href="/saesonguide/" class="season-cta">
            Se den fulde sæsonguide
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="sblock-right">
          <p class="sblock-fish-label">Bider nu</p>
          <ul class="fish-chips">
            {now.fish.map((f, i) => (
              <li>
                <a class={`fish-chip ${i === 0 ? 'is-top' : ''}`} href={speciesHref[f] ?? '#'}>
                  <span class="fish-chip-dot" aria-hidden="true"></span>
                  <span class="fish-chip-name">{f}</span>
                  <span class="fish-chip-tag">{i === 0 ? 'Top' : 'I sæson'}</span>
                  <svg class="fish-chip-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M2.5 7h9M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       INTRO
  ═══════════════════════════════════════════ -->
  <section class="sec sec-intro">
    <div class="ctn intro-layout">
      <div class="intro-text">
        <span class="eyebrow">Om Ude og Fiske</span>
        <h2 class="intro-h2">Fiskeri er for alle — også for dig</h2>
        <p class="intro-p">
          Hvad der engang var en nødvendighed er i dag en af Danmarks mest udbredte fritidsaktiviteter. Over 200.000 danskere køber statens lystfisketegn hvert år, og kysten, åen eller put &amp; take-søen er aldrig længere væk end en kort køretur. Det eneste der står mellem dig og din første fisk er en stang, et stykke endegrej og lidt viden om hvor og hvornår.
        </p>
        <p class="intro-p">
          Ude og Fiske er bygget op om syv komplette art-guider og en voksende samling af teknik- og udstyrs-guider. Hver fisk har sit eget vindue på året — havørreden i forår og efterår, makrellen i sommerstimerne, hornfisken i den korte april-juni-måned, torsken i de kolde måneder. Det er den slags timing-viden der gør forskellen på en nul-tur og en tur med fisk i tasken.
        </p>
        <p class="intro-p">
          Alle guides er skrevet med udgangspunkt i reel erfaring fra danske farvande, ikke oversatte versioner af amerikanske artikler. Når en guide nævner en specifik plads eller et specifikt blink, er det fordi jeg selv har fisket der eller brugt det. Sider er gratis, opdateres jævnligt, og du behøver ikke oprette en bruger for at læse dem.
        </p>
      </div>
      <div class="intro-stats">
        <div class="istat">
          <span class="istat-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 12s2-3 5-3 5 3 5 3-2 3-5 3-5-3-5-3z"/>
              <circle cx="7" cy="12" r="0.8" fill="currentColor"/>
              <path d="M14 9.5L20 4l-1 8 1 8-6-5.5"/>
            </svg>
          </span>
          <span class="istat-t">Egen erfaring</span>
          <span class="istat-l">Skrevet ud fra reelle ture i danske farvande — ikke oversatte artikler.</span>
        </div>
        <div class="istat">
          <span class="istat-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <span class="istat-t">Fokus på Danmark</span>
          <span class="istat-l">Konkrete pladser, arter og sæsoner for danske kyster, åer og søer.</span>
        </div>
        <div class="istat">
          <span class="istat-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 1 1-2.64-6.36"/>
              <path d="M21 3v6h-6"/>
            </svg>
          </span>
          <span class="istat-t">Opdateres løbende</span>
          <span class="istat-l">Guiderne holdes ved lige, så viden, grej og priser er aktuelle.</span>
        </div>
        <div class="istat">
          <span class="istat-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
            </svg>
          </span>
          <span class="istat-t">Gratis &amp; uden login</span>
          <span class="istat-l">Alt indhold er frit tilgængeligt — ingen betaling og ingen bruger.</span>
        </div>
      </div>
    </div>
  </section>

</MainLayout>

<style>
  /* ── Shared ── */
  .ctn {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .sec { padding: 5rem 0; }

  .eyebrow {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0d4a5e;
    margin-bottom: 0.625rem;
  }

  .sec-hd { margin-bottom: 2.5rem; }

  .sec-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: #111827;
    letter-spacing: -0.025em;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }

  .sec-sub {
    font-size: 1rem;
    color: #6b7280;
    font-weight: 400;
    max-width: 480px;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 64vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: url("/images/forside_hero.jpg") center 40% / cover no-repeat;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 20% 50%, rgba(13, 74, 94, 0.6) 0%, transparent 70%),
      radial-gradient(ellipse 50% 50% at 80% 30%, rgba(4, 18, 28, 0.7) 0%, transparent 60%),
      linear-gradient(180deg, rgba(4, 15, 24, 0.65) 0%, rgba(4, 15, 24, 0.45) 50%, rgba(4, 15, 24, 0.85) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 1.5rem 7rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.35rem 0.875rem;
    border-radius: 999px;
    margin-bottom: 1.75rem;
    width: fit-content;
  }

  .hero-badge-dot {
    width: 6px;
    height: 6px;
    background: #4ade80;
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.8); }
  }

  .hero-h1 {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 700;
    color: #ffffff;
    line-height: 1.08;
    letter-spacing: -0.035em;
    margin-bottom: 1.25rem;
    max-width: 680px;
  }

  .hero-h1 em {
    font-style: normal;
    color: rgba(255, 255, 255, 0.65);
  }

  .hero-sub {
    font-size: clamp(1rem, 1.75vw, 1.1875rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.65;
    max-width: 520px;
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: #c47d0a;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 500;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 14px rgba(196, 125, 10, 0.35);
  }

  .btn-primary:hover {
    background: #a86809;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(196, 125, 10, 0.4);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.9375rem;
    font-weight: 400;
    padding: 0.8rem 1.75rem;
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
    backdrop-filter: blur(4px);
  }

  .btn-ghost:hover {
    border-color: rgba(255, 255, 255, 0.65);
    background: rgba(255, 255, 255, 0.08);
  }

  /* Wave separator — soft curve transitioning the dark hero into the white welcome section below */
  .hero-wave {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    width: 100%;
    line-height: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hero-wave svg {
    display: block;
    width: 100%;
    height: 90px;
  }

  @media (max-width: 640px) {
    .hero-wave svg { height: 60px; }
  }


  /* ── Welcome (compact intro under hero) ── */
  .sec-welcome {
    background: #ffffff;
    padding: 4rem 0 3.5rem;
  }

  .welcome {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .welcome-mark {
    display: block;
    width: 56px;
    height: 3px;
    background: linear-gradient(90deg, #c47d0a 0%, #0d4a5e 100%);
    border-radius: 2px;
    margin: 0 auto 1.75rem;
  }

  .welcome-lead {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    font-weight: 400;
    color: #1f2937;
    letter-spacing: -0.015em;
    line-height: 1.55;
    margin-bottom: 1.125rem;
  }

  .welcome-body {
    font-size: 1rem;
    color: #6b7280;
    line-height: 1.75;
    max-width: 640px;
    margin: 0 auto;
  }

  /* ── Card grid ── */
  .sec-cats { background: #f8fafc; }

  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .bcard {
    position: relative;
    display: block;
    height: 260px;
    border-radius: 14px;
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .bcard:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
    z-index: 2;
  }

  .bcard-bg {
